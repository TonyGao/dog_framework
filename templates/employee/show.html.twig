            <!-- Clear Passkey Modal -->
            <div class="ef-modal-container" id="clearPasskeyModal" style="z-index: 1002; display: none;">
                <div class="ef-modal-mask" onclick="$('#clearPasskeyModal').hide()"></div>
                <div class="ef-modal-wrapper ef-modal-wrapper-align-center">
                    <div class="ef-modal">
                        <div class="ef-modal-header">
                            <div class="ef-modal-title ef-modal-title-align-left">
                                {{ 'employee.detail.action.clear_passkey'|trans({}, 'messages')|default('Clear Passkey') }}
                            </div>
                            <div tabindex="-1" role="button" aria-label="Close" class="ef-modal-close-btn" onclick="$('#clearPasskeyModal').hide()">
                                <span class="ef-icon-hover">
                                    <svg viewbox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" class="ef-icon ef-icon-close" stroke-width="4" stroke-linecap="butt" stroke-linejoin="miter">
                                        <path d="M9.857 9.858 24 24m0 0 14.142 14.142M24 24 38.142 9.858M24 24 9.857 38.142"></path>
                                    </svg>
                                </span>
                            </div>
