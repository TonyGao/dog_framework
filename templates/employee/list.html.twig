{% extends 'admin/layout.html.twig' %}
{% import 'components/tree.html.twig' as treeComponent %}
{% import 'ui/template/ui.html.twig' as ui %}

{% block title %}{{ 'employee.list.title'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" type="text/css" href="{{ asset('platform/treeLayout.css', 'admin') }}"/>
    <style>
        /* Draggable Column Styles */
        .column-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 12px;
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            cursor: default;
            transition: all 0.2s;
        }
        .column-item:hover {
            border-color: #3b82f6;
            background: #f8fafc;
        }
        .column-drag-handle {
            cursor: grab;
            color: #94a3b8;
            padding: 4px;
        }
        .column-drag-handle:active {
            cursor: grabbing;
        }
        .column-item.sortable-ghost {
            opacity: 0.4;
            background: #eff6ff;
            border: 1px dashed #3b82f6;
        }
        .column-item.sortable-chosen {
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        .custom-toolbar-box {
            background: #fff;
            padding: 15px 20px;
            margin-bottom: 20px;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
        }
        .custom-toolbar-wrap {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .custom-toolbar-content {
            display: flex;
            gap: 12px;
            align-items: center;
        }
        .right-content {
            padding: 20px;
            background-color: #f8fafc;
        }
        .right-content .ef-table {
            width: 100% !important;
        }
        
        /* Custom Checkbox */
        .custom-checkbox {
            appearance: none;
            background-color: #fff;
            margin: 0;
            font: inherit;
            color: currentColor;
            width: 18px;
            height: 18px;
            border: 1px solid #cbd5e1;
            border-radius: 4px;
            display: grid;
            place-content: center;
            cursor: pointer;
            transition: all 0.2s;
        }
        .custom-checkbox::before {
            content: "";
            width: 10px;
            height: 10px;
            transform: scale(0);
            transition: 120ms transform ease-in-out;
            box-shadow: inset 1em 1em #fff;
            transform-origin: center;
            clip-path: polygon(14% 44%, 0 65%, 50% 100%, 100% 16%, 80% 0%, 43% 62%);
        }
        .custom-checkbox:checked {
            background-color: #3b82f6;
            border-color: #3b82f6;
        }
        .custom-checkbox:checked::before {
            transform: scale(1);
        }

        /* Custom Avatar */
        .custom-avatar {
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #3b82f6;
            color: white;
            font-weight: 600;
            font-size: 11px;
            border-radius: 50%;
            width: 28px;
            height: 28px;
            text-transform: uppercase;
        }
        
        .card-custom-avatar {
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #3b82f6;
            color: white;
            font-weight: 600;
            font-size: 16px;
            border-radius: 50%;
            width: 48px;
            height: 48px;
            text-transform: uppercase;
        }

        /* Color variations for avatars based on name hash (simple cycle) */
        .avatar-color-0 { background-color: #3b82f6; } /* Blue */
        .avatar-color-1 { background-color: #ef4444; } /* Red */
        .avatar-color-2 { background-color: #10b981; } /* Emerald */
        .avatar-color-3 { background-color: #f59e0b; } /* Amber */
        .avatar-color-4 { background-color: #8b5cf6; } /* Violet */
        .avatar-color-5 { background-color: #ec4899; } /* Pink */
        .avatar-color-6 { background-color: #06b6d4; } /* Cyan */
        .avatar-color-7 { background-color: #f97316; } /* Orange */

        /* Left Tree Styling Refined */
        .left-tree {
            background: #fff !important;
            border-radius: 0 !important; /* Removed border-radius */
            border: 1px solid #e2e8f0;
            padding: 10px 0;
            /* margin-right: 20px; Removed margin, handled by container */
            width: 280px; /* Fixed width for transition */
            transition: all 0.3s ease;
            overflow: hidden;
            white-space: nowrap;
            flex-shrink: 0; /* Prevent shrinking */
        }
        .left-tree.collapsed {
            width: 0 !important;
            padding: 0 !important;
            border: none !important;
        }
        
        .fold-icon-wrapper {
            width: 20px;
            height: 40px;
            background: transparent;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            border-top-right-radius: 8px;
            border-bottom-right-radius: 8px;
            color: #94a3b8;
            align-self: center;
            margin-left: -1px; /* Overlap border */
            z-index: 1001;
            flex-shrink: 0;
            transition: all 0.3s ease;
        }
        .fold-icon-wrapper:hover {
            color: #475569;
            background: #f1f5f9;
        }

        .department-tree-wrapper {
            padding: 0 10px;
        }
        .search-department-wrapper {
            padding: 10px 15px;
            border-bottom: 1px solid #f1f5f9;
            margin-bottom: 10px;
        }
        .search-department-wrapper input {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 6px;
        }

        /* Stats Cards */
        .stats-container {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 20px;
        }

        .stats-container.hidden {
            display: none !important;
        }
        .stats-card {
            background: #fff;
            border-radius: 12px;
            padding: 20px;
            border: 1px solid #e2e8f0;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .stats-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: #64748b;
            font-size: 14px;
            font-weight: 500;
        }
        .stats-value {
            font-size: 24px;
            font-weight: 700;
            color: #0f172a;
        }
        .stats-trend {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 11px;
            font-weight: 600;
            padding: 2px 8px;
            border-radius: 6px;
        }
        .trend-up {
            background: #dcfce7;
            color: #166534;
        }
        .trend-down {
            background: #fee2e2;
            color: #991b1b;
        }
        
        /* Search Input Refined */
        .search-wrapper {
            position: relative;
            width: 240px;
        }
        .search-wrapper input {
            width: 100%;
            padding: 8px 10px 8px 32px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            background: #f8fafc;
            color: #334155;
            font-size: 13px;
            transition: all 0.2s;
        }
        .search-wrapper input:focus {
            background: #fff;
            border-color: #3b82f6;
            outline: none;
            box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.1);
        }
        .search-wrapper i {
            position: absolute;
            left: 10px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 13px;
        }

        /* Filter Tabs */
        .filter-tabs {
            display: flex;
            background: #f1f5f9;
            padding: 3px;
            border-radius: 6px;
            gap: 4px;
        }
        .filter-tab {
            padding: 5px 10px;
            border-radius: 5px;
            font-size: 12px;
            font-weight: 500;
            color: #64748b;
            cursor: pointer;
            transition: all 0.2s;
            border: none;
            background: transparent;
        }
        .filter-tab.active {
            background: #fff;
            color: #0f172a;
            box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        }

        /* View Toggle */
        .view-toggle {
            display: flex;
            background: #fff;
            padding: 3px;
            border-radius: 6px;
            margin-left: 10px;
            border: 1px solid #e2e8f0;
        }
        .view-toggle-btn {
            border: none;
            background: transparent;
            padding: 6px 8px;
            border-radius: 4px;
            cursor: pointer;
            color: #94a3b8;
            transition: all 0.2s;
            font-size: 12px;
        }
        .view-toggle-btn:hover {
            color: #64748b;
        }
        .view-toggle-btn.active {
            background: #f1f5f9;
            color: #0f172a;
        }
        
        /* Custom Table Styles */
        .custom-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            background: #fff;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            overflow: hidden;
        }
        .custom-table th {
            text-align: left;
            padding: 12px 20px;
            border-bottom: 1px solid #e2e8f0;
            color: #64748b;
            font-weight: 600;
            font-size: 12px;
            background: #fcfcfc;
            text-transform: uppercase;
            letter-spacing: 0.02em;
        }
        .custom-table th i {
            margin-left: 6px;
            font-size: 11px;
            color: #cbd5e1;
            cursor: pointer;
        }
        .custom-table td {
            padding: 12px 20px;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
            color: #334155;
            font-size: 13px;
            background: #fff;
        }
        .custom-table tr:last-child td {
            border-bottom: none;
        }
        .custom-table tr:hover td {
            background: #f8fafc;
        }
        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .user-avatar {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            object-fit: cover;
        }
        .user-name {
            font-weight: 500;
            color: #0f172a;
        }
        .status-pill {
            display: inline-flex;
            align-items: center;
            padding: 2px 8px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
            line-height: 1.4;
        }
        .status-active { background: #dcfce7; color: #166534; }
        .status-inactive { background: #fee2e2; color: #991b1b; }
        .status-vacation { background: #ffedd5; color: #9a3412; }
        
        .dept-dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            margin-right: 6px;
        }
        
        /* Card View Styles Refined */
        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 20px;
            padding: 20px 0;
        }
        .employee-card {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 16px;
            display: flex;
            flex-direction: column;
            transition: all 0.2s ease;
            position: relative;
        }
        .employee-card:hover {
            box-shadow: 0 12px 24px -8px rgba(0, 0, 0, 0.08);
            border-color: #cbd5e1;
        }
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 16px;
        }
        .card-avatar-wrapper {
            position: relative;
            width: 48px;
            height: 48px;
        }
        .card-avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            object-fit: cover;
        }
        .status-indicator {
            position: absolute;
            bottom: 2px;
            right: 2px;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            border: 2px solid #fff;
        }
        .indicator-active { background-color: #22c55e; }
        .indicator-inactive { background-color: #ef4444; }
        .indicator-vacation { background-color: #f59e0b; }

        .card-main-info {
            margin-bottom: 16px;
        }
        .card-name {
            font-size: 16px;
            font-weight: 600;
            color: #0f172a;
            margin-bottom: 4px;
            display: block;
        }
        .card-role {
            font-size: 13px;
            color: #64748b;
        }
        
        .card-details-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            padding: 16px 0;
            border-top: 1px solid #f1f5f9;
            margin-bottom: 16px;
        }
        .detail-item {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }
        .detail-label {
            font-size: 11px;
            color: #94a3b8;
            font-weight: 500;
        }
        .detail-value {
            font-size: 13px;
            font-weight: 600;
            color: #334155;
        }

        .card-contact-info {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .contact-item {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 14px;
            color: #0f172a;
            font-weight: 600;
        }
        .contact-item i {
            width: 16px;
            color: #64748b;
            font-size: 14px;
        }
        
        /* Action Button Style */
        .action-btn {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            border: none;
            background: transparent;
            color: #94a3b8;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease;
        }
        .action-btn:hover {
            background-color: #f1f5f9;
            color: #3b82f6;
            transform: scale(1.1);
        }

        /* Pagination Style Refined */
        .custom-pagination {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 20px;
            border-top: 1px solid #f1f5f9;
            margin-top: 20px;
            color: #64748b;
            font-size: 13px;
        }
        .pagination-info {
            font-weight: 500;
        }
        .pagination-controls {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .pagination-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 6px 12px;
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            color: #475569;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            height: 32px;
        }
        .pagination-btn:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
            color: #1e293b;
            box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        }
        .page-number-btn {
            width: 32px;
            padding: 0;
        }
        .page-number-btn.active {
            background: #f1f5f9;
            color: #0f172a;
            border-color: #cbd5e1;
            font-weight: 600;
        }
        .page-size-select {
            padding: 0 10px;
            height: 32px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            background: #fff;
            color: #475569;
            font-size: 13px;
            cursor: pointer;
            outline: none;
            margin-right: 12px;
        }
        .page-size-select:hover {
            border-color: #cbd5e1;
        }
        
        /* Ensure arrow icon is clickable */
        .common-tree-wrapper .arrow-icon {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 20px;
            cursor: pointer;
            z-index: 100;
        }
        .arrow-icon:hover {
            color: #3b82f6;
        }
    </style>
{% endblock %}

{% block app_content_container %}
<div class="org-structure-container">
    <div class="outside-wrapper">
        <div class="inside-wrapper">
            {# Left Tree #}
            <div class="left-tree visible" id="leftTree">
                <div class="left-tree-wrapper">
                    <div class="search-department-wrapper">
                        <span class="ef-input-wrapper">
                            <input class="ef-input ef-input-size-mini text" type="text" placeholder="{{ 'employee.list.search_department'|trans }}"/>
                            <span class="ef-input-suffix"><i class="fa-solid fa-magnifying-glass"></i></span>
                        </span>
                    </div>
                    <div class="department-tree-wrapper common-tree-wrapper">
                         {{ tree | raw }}
                    </div>
                </div>
            </div>
            
            <div class="fold-icon-wrapper" id="collapseTree">
                <i class="fa-solid fa-chevron-left"></i>
            </div>
            
            {# Right Content #}
            <div class="right-content">
                
                {# Stats Cards #}
                {% if stats is defined %}
                <div class="stats-container {% if not show_stats %}hidden{% endif %}">
            <div class="stats-card">
                        <div class="stats-header">
                            <span>{{ 'employee.stats.total_employees'|trans }}</span>
                            <i class="fa-solid fa-circle-info" style="color: #cbd5e1;"></i>
                        </div>
                        <div class="stats-value">{{ stats.total_employee.value }}</div>
                        <div class="stats-trend {{ stats.total_employee.trend == 'up' ? 'trend-up' : 'trend-down' }}">
                            <i class="fa-solid {{ stats.total_employee.trend == 'up' ? 'fa-arrow-trend-up' : 'fa-arrow-trend-down' }}"></i>
                            {{ stats.total_employee.change }} {{ 'employee.stats.increase_last_month'|trans }}
                        </div>
                    </div>
                    <div class="stats-card">
                        <div class="stats-header">
                            <span>{{ 'employee.stats.active_employees'|trans }}</span>
                            <i class="fa-solid fa-circle-info" style="color: #cbd5e1;"></i>
                        </div>
                        <div class="stats-value">{{ stats.active_employee.value }}</div>
                        <div class="stats-trend {{ stats.active_employee.trend == 'up' ? 'trend-up' : 'trend-down' }}">
                            <i class="fa-solid {{ stats.active_employee.trend == 'up' ? 'fa-arrow-trend-up' : 'fa-arrow-trend-down' }}"></i>
                            {{ stats.active_employee.change }} {{ 'employee.stats.decrease_yesterday'|trans }}
                        </div>
                    </div>
                    <div class="stats-card">
                        <div class="stats-header">
                            <span>{{ 'employee.stats.total_departments'|trans }}</span>
                            <i class="fa-solid fa-circle-info" style="color: #cbd5e1;"></i>
                        </div>
                        <div class="stats-value">{{ stats.total_department.value }}</div>
                        <div class="stats-trend {{ stats.total_department.trend == 'up' ? 'trend-up' : 'trend-down' }}">
                            <i class="fa-solid {{ stats.total_department.trend == 'up' ? 'fa-arrow-trend-up' : 'fa-arrow-trend-down' }}"></i>
                            {{ stats.total_department.change }} {{ 'employee.stats.increase_last_year'|trans }}
                        </div>
                    </div>
                    <div class="stats-card">
                        <div class="stats-header">
                            <span>{{ 'employee.stats.average_tenure'|trans }}</span>
                            <i class="fa-solid fa-circle-info" style="color: #cbd5e1;"></i>
                        </div>
                        <div class="stats-value">{{ stats.average_tenure.value }} <span style="font-size: 14px; font-weight: normal; color: #64748b;">{{ 'employee.stats.year_unit'|trans }}</span></div>
                        <div class="stats-trend {{ stats.average_tenure.trend == 'up' ? 'trend-up' : 'trend-down' }}">
                            <i class="fa-solid {{ stats.average_tenure.trend == 'up' ? 'fa-arrow-trend-up' : 'fa-arrow-trend-down' }}"></i>
                            {{ stats.average_tenure.change }} {{ 'employee.stats.increase_last_year'|trans }}
                        </div>
                    </div>
                </div>
                {% endif %}

                <h2 style="font-size: 18px; font-weight: 600; color: #0f172a; margin-bottom: 15px;">{{ 'employee.list.header'|trans }}</h2>

                {# Toolbar #}
                <div class="custom-toolbar-box">
                    <div class="custom-toolbar-wrap">
                        <div class="custom-toolbar-content">
                            <div class="search-wrapper">
                                <form action="{{ path('employee_list') }}" method="get" style="display: flex; align-items: center; width: 100%;">
                                    {% for key, value in app.request.query.all %}
                                        {% if key != 'q' and key != 'page' %}
                                            <input type="hidden" name="{{ key }}" value="{{ value }}">
                                        {% endif %}
                                    {% endfor %}
                                    <i class="fa-solid fa-magnifying-glass"></i>
                                    <input type="text" name="q" value="{{ app.request.query.get('q') }}" placeholder="{{ 'employee.list.search_placeholder'|trans }}" />
                                </form>
                            </div>
                            
                            <div class="filter-tabs">
                                {% set current_status = app.request.query.get('employment_status', 'active') %}
                                <button class="filter-tab {% if current_status == 'active' %}active{% endif %}" onclick="filterEmploymentStatus('active')"><i class="fa-regular fa-circle-check" style="margin-right: 4px;"></i> {{ 'employee.employment_status.active'|trans }}</button>
                                <button class="filter-tab {% if current_status == 'inactive' %}active{% endif %}" onclick="filterEmploymentStatus('inactive')"><i class="fa-solid fa-user-xmark" style="margin-right: 4px;"></i> {{ 'employee.employment_status.inactive'|trans }}</button>
                                <button class="filter-tab {% if current_status == 'all' %}active{% endif %}" onclick="filterEmploymentStatus('all')">{{ 'employee.filter.all'|trans }}</button>
                            </div>
                            
                            <button class="btn outline medium mini round icon" style="color: #64748b; border-color: #e2e8f0; margin-left: 10px;" onclick="openColumnModal()">
                                <i class="fa-solid fa-table-columns"></i>
                            </button>

                            <label class="switch-label" style="display: flex; align-items: center; gap: 8px; margin-left: 15px; cursor: pointer; color: #64748b; font-size: 13px; font-weight: 500; user-select: none;">
                                <input type="checkbox" id="includeSubToggle" class="custom-checkbox" {% if app.request.query.getBoolean('include_sub', true) %}checked{% endif %} style="width: 16px; height: 16px;">
                                <span>{{ 'employee.filter.include_sub'|trans({}, 'messages')|default('包含子部门') }}</span>
                            </label>
                        </div>
                         <div class="custom-toolbar-content">
                            <div id="selection-status" style="display: none; align-items: center; gap: 8px; margin-right: 12px; background: #eff6ff; padding: 4px 12px; border-radius: 20px; border: 1px solid #bfdbfe;">
                                <span style="font-size: 13px; color: #1e40af; font-weight: 500;">
                                    {{ 'employee.list.selected'|trans }}: <span id="selected-count">0</span>
                                </span>
                                <button onclick="clearSelection()" style="background: none; border: none; cursor: pointer; color: #60a5fa; padding: 0; margin-left: 4px; font-size: 14px; display: flex; align-items: center;">
                                    <i class="fa-solid fa-circle-xmark"></i>
                                </button>
                            </div>

                            <button class="btn outline medium mini round" style="color: #64748b; border-color: #e2e8f0; display: inline-flex; align-items: center; gap: 6px;" onclick="exportEmployees()">
                                <i class="fa-solid fa-file-export"></i> {{ 'employee.action.export'|trans({}, 'messages')|default('导出') }}
                            </button>
                            <button class="btn outline medium mini round" style="color: #64748b; border-color: #e2e8f0; display: inline-flex; align-items: center; gap: 6px;" onclick="openImportModal()">
                                <i class="fa-solid fa-file-import"></i> {{ 'employee.action.import'|trans({}, 'messages')|default('导入') }}
                            </button>
                            <a href="{{ path('test_employee_onboarding') }}" class="btn primary medium mini round icon" style="background-color: #f97316; border-color: #f97316;">
                                <i class="fa-solid fa-plus"></i>
                            </a>
                            
                            <div style="width: 1px; height: 24px; background: #e2e8f0; margin: 0 5px;"></div>

                            <div class="view-toggle">
                                <button class="view-toggle-btn active" onclick="switchView('list')" title="{{ 'employee.view.list'|trans }}">
                                    <i class="fa-solid fa-list"></i>
                                </button>
                                <button class="view-toggle-btn" onclick="switchView('card')" title="{{ 'employee.view.card'|trans }}">
                                    <i class="fa-solid fa-grip"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                {# List View #}
                <div id="listView">
                    <div>
                        <table class="custom-table">
                            <thead>
                                <tr>
                                    <th style="width: 40px;"><input type="checkbox" class="custom-checkbox" id="selectAll"></th>
                                    {% for key, config in columns %}
                                        <th>
                                            {% set sortIcon = 'fa-sort' %}
                                            {% if currentSort == key %}
                                                {% set sortIcon = currentOrder == 'asc' ? 'fa-sort-up' : 'fa-sort-down' %}
                                            {% endif %}
                                            <a href="{{ path('employee_list', app.request.query.all|merge({'sort': key, 'order': currentSort == key and currentOrder == 'desc' ? 'asc' : 'desc'})) }}" style="color: inherit; text-decoration: none; display: flex; align-items: center;">
                                                {{ config.label|trans }} <i class="fa-solid {{ sortIcon }}" style="margin-left: 6px;"></i>
                                            </a>
                                        </th>
                                    {% endfor %}
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in entities %}
                                <tr class="sync-row-emp" data-ef-sync="employee:{{ item.id }}">
                                    <td><input type="checkbox" class="custom-checkbox row-checkbox" value="{{ item.employeeNo }}"></td>
                                    {% for key, config in columns %}
                                        {% if key == 'name' %}
                                            <td>
                                                <div class="user-info">
                                                    <div id="list-avatar-img-{{ item.id }}" class="custom-avatar" data-ef-sync="employee:{{ item.id }}" data-name="{{ item.name }}">{% if item.avatar %}<img src="{{ item.avatar }}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">{% else %}{{ item.name|slice(-2, 2) }}{% endif %}</div>
                                                    <span class="user-name sync-val-name" onclick="openEmployeeDrawer('{{ item.id }}')" style="cursor: pointer; {% if item.employmentStatus == 'inactive' %}text-decoration: underline; text-decoration-color: #ef4444; text-underline-offset: 4px;{% endif %}">{{ item.name }}</span>
                                                </div>
                                            </td>
                                        {% elseif key == 'employeeNo' %}
                                            <td class="sync-val-employeeNo">{{ item.employeeNo }}</td>
                                        {% elseif key == 'department' %}
                                            <td class="sync-val-department">
                                                <span class="dept-dot" style="background-color: #f59e0b;"></span>
                                                <span class="dept-text">{{ item.department ? item.department.name : '' }}</span>
                                            </td>
                                        {% elseif key == 'position' %}
                                            <td class="sync-val-position">{{ item.position ? item.position.name : '' }}</td>
                                        {% elseif key == 'employmentStatus' %}
                                            <td class="sync-val-status">
                                                <div style="font-size: 14px; color: #334155; display: flex; align-items: center; gap: 6px;">
                                                    {% set status_icon = item.employmentStatus == 'active' ? 'fa-circle-check' : 'fa-user-xmark' %}
                                                    {% set status_color = item.employmentStatus == 'active' ? '#22c55e' : '#ef4444' %}
                                                    <i class="fa-solid {{ status_icon }}" style="color: {{ status_color }};"></i>
                                                    {{ ('employee.employment_status.' ~ item.employmentStatus)|trans }}
                                                </div>
                                            </td>
                                        {% elseif key == 'workStatus' %}
                                            <td>
                                                <div style="font-size: 14px; color: #334155; display: flex; align-items: center; gap: 6px;">
                                                    {% set work_icon = {
                                                        'working': 'fa-briefcase',
                                                        'vacation': 'fa-umbrella-beach',
                                                        'business_trip': 'fa-plane',
                                                        'out_of_office': 'fa-person-walking-arrow-right',
                                                        'in_meeting': 'fa-users'
                                                    }[item.workStatus] | default('fa-circle') %}
                                                    <i class="fa-solid {{ work_icon }}" style="color: #64748b;"></i>
                                                    {{ ('employee.work_status.' ~ item.workStatus)|trans }}
                                                </div>
                                            </td>
                                        {% elseif key == 'hireDate' %}
                                            <td class="sync-val-hireDate">{{ item.hireDate ? item.hireDate|date('Y-m-d') : '' }}</td>
                                        {% elseif key == 'email' %}
                                            <td>{{ item.email }}</td>
                                        {% elseif key == 'mobile' %}
                                            <td>{{ item.mobile }}</td>
                                        {% elseif key == 'gender' %}
                                            <td>{{ item.gender }}</td>
                                         {% elseif key == 'birthDate' %}
                                            <td>{{ item.birthDate ? item.birthDate|date('Y-m-d') : '' }}</td>
                                         {% elseif key == 'idCard' %}
                                            <td>{{ item.idCard }}</td>
                                         {% elseif key == 'englishName' %}
                                            <td>{{ item.englishName }}</td>
                                        {% else %}
                                            <td></td>
                                        {% endif %}
                                    {% endfor %}
                                    <td style="text-align: right;">
                                        <button class="action-btn"><i class="fa-solid fa-ellipsis-vertical"></i></button>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>

                {# Card View #}
                <div id="cardView" style="display: none;">
                    <div class="card-grid">
                        {% for item in entities %}
                        <div class="employee-card sync-row-emp" data-ef-sync="employee:{{ item.id }}">
                            <div class="card-header">
                                <div class="card-avatar-wrapper">
                                    <div id="card-avatar-img-{{ item.id }}" class="card-custom-avatar" data-ef-sync="employee:{{ item.id }}" data-name="{{ item.name }}">{% if item.avatar %}<img src="{{ item.avatar }}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">{% else %}{{ item.name|slice(-2, 2) }}{% endif %}</div>
                                    {% if item.employmentStatus == 'active' %}
                                        <span class="status-indicator indicator-active" title="{{ 'employee.employment_status.active'|trans }}"></span>
                                    {% else %}
                                        <span class="status-indicator indicator-inactive" title="{{ 'employee.employment_status.inactive'|trans }}"></span>
                                    {% endif %}
                                </div>
                                <button class="action-btn"><i class="fa-solid fa-ellipsis"></i></button>
                            </div>

                            <div class="card-main-info">
                                <span class="card-name sync-val-name" onclick="openEmployeeDrawer('{{ item.id }}')" style="cursor: pointer; {% if item.employmentStatus == 'inactive' %}text-decoration: underline; text-decoration-color: #ef4444; text-underline-offset: 4px;{% endif %}">{{ item.name }}</span>
                                <span class="card-role sync-val-position">{{ item.position ? item.position.name : '' }}</span>
                            </div>

                            <div class="card-details-grid">
                                <div class="detail-item">
                                    <span class="detail-label">{{ 'employee.field.department'|trans }}</span>
                                    <span class="detail-value sync-val-department">{{ item.department ? item.department.name : '' }}</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">{{ 'employee.field.entry_date'|trans }}</span>
                                    <span class="detail-value sync-val-hireDate">{{ item.hireDate ? item.hireDate|date('Y-m-d') : '' }}</span>
                                </div>
                            </div>

                            <div class="card-contact-info">
                                <div class="contact-item">
                                    <i class="fa-regular fa-envelope"></i>
                                    <span>{{ item.email }}</span>
                                </div>
                                <div class="contact-item">
                                    <i class="fa-solid fa-phone"></i>
                                    <span>{{ item.mobile }}</span>
                                </div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
                
                {# Pagination #}
                <div class="custom-pagination">
                    <div class="pagination-info">
                        {{ 'pagination.info'|trans({'%start%': pagination.start, '%end%': pagination.end, '%total%': pagination.totalItems}) }}
                    </div>
                    <div class="pagination-controls">
                        <span style="font-size: 13px; color: #64748b;">{{ 'pagination.per_page'|trans }}</span>
                        <select class="page-size-select" onchange="changePageSize(this.value)">
                            <option value="10" {% if pagination.limit == 10 %}selected{% endif %}>10</option>
                            <option value="20" {% if pagination.limit == 20 %}selected{% endif %}>20</option>
                            <option value="50" {% if pagination.limit == 50 %}selected{% endif %}>50</option>
                            <option value="100" {% if pagination.limit == 100 %}selected{% endif %}>100</option>
                        </select>
                        
                        {% if pagination.currentPage > 1 %}
                            <a href="{{ path('employee_list', app.request.query.all|merge({'page': pagination.currentPage - 1, 'limit': pagination.limit})) }}" class="pagination-btn"><i class="fa-solid fa-chevron-left"></i></a>
                        {% else %}
                            <button class="pagination-btn" style="color: #94a3b8;" disabled><i class="fa-solid fa-chevron-left"></i></button>
                        {% endif %}

                        {% for i in 1..pagination.totalPages %}
                            {% if i == pagination.currentPage %}
                                <button class="pagination-btn page-number-btn active">{{ i }}</button>
                            {% elseif i == 1 or i == pagination.totalPages or (i >= pagination.currentPage - 2 and i <= pagination.currentPage + 2) %}
                                <a href="{{ path('employee_list', app.request.query.all|merge({'page': i, 'limit': pagination.limit})) }}" class="pagination-btn page-number-btn">{{ i }}</a>
                            {% elseif i == pagination.currentPage - 3 or i == pagination.currentPage + 3 %}
                                <span style="color: #94a3b8; font-size: 12px;">...</span>
                            {% endif %}
                        {% endfor %}

                        {% if pagination.currentPage < pagination.totalPages %}
                            <a href="{{ path('employee_list', app.request.query.all|merge({'page': pagination.currentPage + 1, 'limit': pagination.limit})) }}" class="pagination-btn"><i class="fa-solid fa-chevron-right"></i></a>
                        {% else %}
                            <button class="pagination-btn" style="color: #94a3b8;" disabled><i class="fa-solid fa-chevron-right"></i></button>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="columnModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
    <div style="background: #fff; width: 420px; border-radius: 12px; padding: 24px; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);">
        <h3 style="margin-top: 0; margin-bottom: 20px; font-size: 18px; font-weight: 600; color: #0f172a; border-bottom: 1px solid #f1f5f9; padding-bottom: 12px;">{{ 'employee.list.customize_columns'|trans({}, 'messages')|default('Customize Columns') }}</h3>
        <div id="columnList" style="max-height: 450px; overflow-y: auto; display: flex; flex-direction: column; gap: 8px; padding-right: 4px;">
            {# 1. Render active columns in their saved order #}
            {% for key, config in columns %}
                <div class="column-item" data-id="{{ key }}">
                     <div class="column-drag-handle">
                         <i class="fa-solid fa-grip-vertical"></i>
                     </div>
                     <input type="checkbox" class="column-checkbox custom-checkbox" value="{{ key }}" checked>
                     <span style="font-size: 14px; color: #334155; font-weight: 500;">{{ config.label|trans }}</span>
                </div>
            {% endfor %}

            {# 2. Render inactive columns #}
            {% for key, config in allColumns %}
                {% if columns[key] is not defined %}
                <div class="column-item" data-id="{{ key }}">
                     <div class="column-drag-handle">
                         <i class="fa-solid fa-grip-vertical"></i>
                     </div>
                     <input type="checkbox" class="column-checkbox custom-checkbox" value="{{ key }}">
                     <span style="font-size: 14px; color: #334155; font-weight: 500;">{{ config.label|trans }}</span>
                </div>
                {% endif %}
            {% endfor %}
        </div>
        <div style="margin-top: 24px; display: flex; justify-content: flex-end; gap: 12px; border-top: 1px solid #f1f5f9; padding-top: 16px;">
            <button onclick="closeColumnModal()" class="btn outline medium" style="border: 1px solid #e2e8f0; color: #64748b; padding: 0 16px; border-radius: 8px; font-weight: 500; height: 36px; display: inline-flex; align-items: center; justify-content: center;">{{ 'action.cancel'|trans({}, 'messages')|default('Cancel') }}</button>
            <button onclick="saveColumns()" class="btn primary medium" style="background: #3b82f6; color: #fff; border: none; padding: 0 24px; border-radius: 8px; font-weight: 600; cursor: pointer; height: 36px; display: inline-flex; align-items: center; justify-content: center;">{{ 'action.save'|trans({}, 'messages')|default('Save') }}</button>
        </div>
    </div>
</div>

{% set importModalBody %}
    <div style="margin-bottom: 20px; font-size: 14px; color: #475569;">
        请先 <a href="{{ path('employee_import_template') }}" style="color: #3b82f6; text-decoration: none; font-weight: 500;"><i class="fa-solid fa-download"></i> 下载导入模板</a>，按照模板格式填写后上传。
    </div>

    <div id="uploadArea" style="border: 2px dashed #cbd5e1; border-radius: 8px; padding: 40px 20px; text-align: center; background: #f8fafc; cursor: pointer; transition: all 0.3s;"
            ondragover="event.preventDefault(); this.style.borderColor='#3b82f6'; this.style.background='#eff6ff';"
            ondragleave="event.preventDefault(); this.style.borderColor='#cbd5e1'; this.style.background='#f8fafc';"
            ondrop="handleDrop(event)"
            onclick="document.getElementById('fileInput').click()">
        
        <i class="fa-solid fa-cloud-arrow-up" style="font-size: 36px; color: #94a3b8; margin-bottom: 12px;"></i>
        <div style="font-size: 15px; color: #334155; font-weight: 500; margin-bottom: 4px;">点击或拖拽文件到此处上传</div>
        <div style="font-size: 13px; color: #94a3b8;">支持 .xlsx, .xls 格式</div>
        <input type="file" id="fileInput" style="display: none;" accept=".xlsx, .xls" onchange="handleFileSelect(this)">
    </div>

    <div id="uploadProgress" style="display: none; margin-top: 20px;">
        <div style="display: flex; justify-content: space-between; font-size: 13px; margin-bottom: 8px;">
            <span style="color: #334155; font-weight: 500;" id="progressText">正在导入...</span>
            <span style="color: #3b82f6; font-weight: 600;" id="progressPercentage">0%</span>
        </div>
        <div style="width: 100%; height: 8px; background: #e2e8f0; border-radius: 4px; overflow: hidden;">
            <div id="progressBar" style="height: 100%; width: 0%; background: #3b82f6; transition: width 0.3s;"></div>
        </div>
    </div>
    
    <div id="importResult" style="display: none; margin-top: 20px; padding: 15px; border-radius: 8px; background: #f0fdf4; border: 1px solid #bbf7d0;">
        <div style="display: flex; align-items: center; gap: 10px; color: #166534; font-weight: 500;">
            <i class="fa-solid fa-circle-check" style="font-size: 18px; color: #22c55e;"></i>
            <span>导入完成！共成功导入 <span id="successCount">0</span> 条数据。</span>
        </div>
    </div>
    
    <div id="importError" style="display: none; margin-top: 20px; padding: 15px; border-radius: 8px; background: #fef2f2; border: 1px solid #fecaca;">
        <div style="display: flex; align-items: center; gap: 10px; color: #991b1b; font-weight: 500;">
            <i class="fa-solid fa-circle-xmark" style="font-size: 18px; color: #ef4444;"></i>
            <span id="errorMsg">导入失败</span>
        </div>
    </div>
{% endset %}

{% set importModalFooter %}
    <button class="btn outline medium" type="button" onclick="closeImportModalLogic()">关闭</button>
{% endset %}

{{ ui.modal('importModal', '导入员工'|trans({}, 'messages'), importModalBody, importModalFooter, {
    'width': '500px',
    'onClose': 'closeImportModalLogic()'
}) }}

<script>
    window.exportEmployees = function() {
        const url = new URL('{{ path('employee_export') }}', window.location.origin);
        
        // Pass current filters to export
        const currentUrl = new URL(window.location.href);
        const searchParams = currentUrl.searchParams;
        
        if (searchParams.get('q')) url.searchParams.set('q', searchParams.get('q'));
        if (searchParams.get('employment_status')) url.searchParams.set('employment_status', searchParams.get('employment_status'));
        if (searchParams.get('department_id')) url.searchParams.set('department_id', searchParams.get('department_id'));
        if (searchParams.get('company_id')) url.searchParams.set('company_id', searchParams.get('company_id'));
        if (searchParams.get('include_sub')) url.searchParams.set('include_sub', searchParams.get('include_sub'));
        
        // 使用 AJAX 触发后台异步导出任务
        $.ajax({
            url: url.toString(),
            type: 'GET',
            success: function(res) {
                if (window.$.alert) {
                    window.$.alert.success(res.message || '导出任务已提交，系统将在后台处理。生成完毕后会自动发送通知。', {
                        title: '提示',
                        closable: true
                    });
                } else {
                    alert(res.message || '导出任务已提交，系统将在后台处理。生成完毕后会自动发送通知。');
                }
            },
            error: function(err) {
                if (window.$.alert) {
                    window.$.alert.error('导出任务提交失败，请重试');
                } else {
                    alert('导出任务提交失败，请重试');
                }
            }
        });
    }

    window.openImportModal = function() {
        resetImportUI();
        
        // 使用框架提供的 openModal 方法打开预先定义的静态模态框
        openModal('importModal');
    }

    function closeImportModalLogic() {
        if (window.importEventSource) {
            window.importEventSource.close();
            window.importEventSource = null;
        }
        
        // 关闭模态框
        closeModal('importModal');

        // Reload list if successful
        const modalResult = document.getElementById('importResult');
        if (modalResult && modalResult.style.display === 'block') {
            loadContent(window.location.href);
        }
    }

    window.handleDrop = function(e) {
        e.preventDefault();
        const modalBody = document.querySelector('.ef-modal-body');
        if(!modalBody) return;
        
        const uploadArea = modalBody.querySelector('#uploadArea');
        if(uploadArea) {
            uploadArea.style.borderColor = '#cbd5e1';
            uploadArea.style.background = '#f8fafc';
        }
        
        if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
            processImportFile(e.dataTransfer.files[0]);
        }
    }

    window.handleFileSelect = function(input) {
        if (input.files && input.files.length > 0) {
            processImportFile(input.files[0]);
        }
        input.value = ''; // Reset input
    }

    window.importEventSource = null;

    function resetImportUI() {
        const modal = document.getElementById('importModal');
        if(!modal) return;
        
        modal.querySelector('#uploadArea').style.display = 'block';
        modal.querySelector('#uploadProgress').style.display = 'none';
        modal.querySelector('#importResult').style.display = 'none';
        modal.querySelector('#importError').style.display = 'none';
        modal.querySelector('#progressBar').style.width = '0%';
        modal.querySelector('#progressPercentage').innerText = '0%';
    }

    function processImportFile(file) {
        const ext = file.name.split('.').pop().toLowerCase();
        if (ext !== 'xlsx' && ext !== 'xls') {
            showImportError('仅支持 .xlsx 或 .xls 格式的 Excel 文件');
            return;
        }

        const modalBody = document.querySelector('.ef-modal-body');
        if(!modalBody) return;

        modalBody.querySelector('#uploadArea').style.display = 'none';
        modalBody.querySelector('#uploadProgress').style.display = 'block';
        modalBody.querySelector('#importError').style.display = 'none';
        modalBody.querySelector('#progressText').innerText = '正在上传文件...';

        const formData = new FormData();
        formData.append('file', file);

        $.ajax({
            url: '{{ path('employee_import_upload') }}',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            success: function(res) {
                if (res.taskId) {
                    startImportProgress(res.taskId);
                } else {
                    showImportError('上传失败：未返回任务ID');
                }
            },
            error: function(err) {
                showImportError('上传失败：' + (err.responseJSON?.error || err.statusText));
            }
        });
    }

    function startImportProgress(taskId) {
        const modalBody = document.querySelector('.ef-modal-body');
        if(!modalBody) return;

        modalBody.querySelector('#progressText').innerText = '正在处理数据...';
        
        window.importEventSource = new EventSource('{{ path('employee_import_process') }}?taskId=' + taskId);
        
        window.importEventSource.onmessage = function(e) {
            const data = JSON.parse(e.data);
            
            if (data.error) {
                window.importEventSource.close();
                showImportError(data.error);
                return;
            }

            if (data.progress !== undefined) {
                modalBody.querySelector('#progressBar').style.width = data.progress + '%';
                modalBody.querySelector('#progressPercentage').innerText = data.progress + '%';
            }

            if (data.complete) {
                window.importEventSource.close();
                modalBody.querySelector('#uploadProgress').style.display = 'none';
                modalBody.querySelector('#importResult').style.display = 'block';
                modalBody.querySelector('#successCount').innerText = data.processed || 0;
            }
        };

        window.importEventSource.onerror = function() {
            window.importEventSource.close();
            showImportError('与服务器的连接中断');
        };
    }

    function showImportError(msg) {
        const modalBody = document.querySelector('.ef-modal-body');
        if(!modalBody) return;

        modalBody.querySelector('#uploadProgress').style.display = 'none';
        modalBody.querySelector('#importError').style.display = 'block';
        modalBody.querySelector('#errorMsg').innerText = msg;
        modalBody.querySelector('#uploadArea').style.display = 'block'; // Allow retry
    }

    // Column Customization Logic
    let columnSortable = null;

    window.openColumnModal = function() {
        document.getElementById('columnModal').style.display = 'flex';
        
        if (!columnSortable) {
            const el = document.getElementById('columnList');
            columnSortable = new Sortable(el, {
                animation: 150,
                handle: '.column-drag-handle',
                ghostClass: 'sortable-ghost',
                chosenClass: 'sortable-chosen',
                onEnd: function() {
                    console.log('Column order changed');
                }
            });
        }
    }

    window.closeColumnModal = function() {
        document.getElementById('columnModal').style.display = 'none';
    }

    window.saveColumns = function() {
        const newColumns = {};
        
        // Use the actual DOM order from Sortable
        const columnItems = document.querySelectorAll('#columnList .column-item');
        columnItems.forEach(item => {
            const cb = item.querySelector('.column-checkbox');
            if (cb.checked) {
                newColumns[cb.value] = { sortable: true }; 
            }
        });
        
        const currentSort = '{{ currentSort }}';
        const currentOrder = '{{ currentOrder }}';
        
        const data = {
            key: 'employee_list_columns',
            value: {
                columns: newColumns,
                sort: currentSort,
                order: currentOrder
            }
        };
        
        const saveBtn = document.querySelector('#columnModal button[onclick="saveColumns()"]');
        const originalText = saveBtn.innerText;
        saveBtn.innerText = '{{ "action.saving"|trans|default("Saving...") }}';
        saveBtn.disabled = true;
        
        fetch('/api/user/preference/save', {
            method: 'POST',
            body: JSON.stringify(data),
            headers: {
                'Content-Type': 'application/json'
            }
        }).then(res => {
            if(res.ok) {
                closeColumnModal();
                loadContent(window.location.href);
            } else {
                alert('Failed to save preferences');
            }
        }).finally(() => {
            saveBtn.innerText = originalText;
            saveBtn.disabled = false;
        });
    }

    // Open Employee Drawer
    window.openEmployeeDrawer = function(id) {
        const drawerId = 'employee-detail-drawer-' + id;
        // Remove existing drawer and its associated modals if they exist to ensure fresh content
        if ($('#' + drawerId).length > 0) {
            $('#' + drawerId).remove();
        }
        // Also remove any associated modals that were moved to body
        $('#avatarModal-' + id).remove();
        $('#clearPasskeyModal-' + id).remove();
        
        // Create and show loading overlay
        const loadingId = 'drawer-loading-' + id;
        if ($('#' + loadingId).length === 0) {
            $('body').append(`
                <div id="${loadingId}" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255, 255, 255, 0.7); z-index: 9999; display: flex; justify-content: center; align-items: center;">
                    <div class="spinner" style="width: 40px; height: 40px; border: 4px solid #f3f3f3; border-top: 4px solid #3b82f6; border-radius: 50%; animation: spin 1s linear infinite;"></div>
                    <style>@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }</style>
                </div>
            `);
        } else {
            $('#' + loadingId).show();
        }
        
        $.ajax({
            url: '/employee/' + id,
            method: 'GET',
            success: function(html) {
                $('#' + loadingId).remove();
                $('body').append(html);
                // 将 drawer 内的所有 modal 移到 body 直接子级
                // 原因：ef-drawer-container 有 position:fixed + z-index:1001，会创建独立的
                // 层叠上下文，导致 drawer 内的 modal（即便 z-index:9999）无法显示在第二层
                // drawer 的遮罩之上。移到 body 后，modal 直接参与 body 层叠上下文比较。
                $('#' + drawerId + ' .ef-modal-container').each(function() {
                    $(this).appendTo(document.body);
                });
                $().showDrawer(drawerId);
            },
            error: function(xhr) {
                $('#' + loadingId).remove();
                console.error('Error loading employee details:', xhr);
                // Optional: Show error toast
            }
        });
    }

    // View Switcher
    function switchView(view) {
        const listView = document.getElementById('listView');
        const cardView = document.getElementById('cardView');
        const btns = document.querySelectorAll('.view-toggle-btn');
        
        if (view === 'list') {
            if(listView) listView.style.display = 'block';
            if(cardView) cardView.style.display = 'none';
            if(btns.length > 0) btns[0].classList.add('active');
            if(btns.length > 1) btns[1].classList.remove('active');
        } else {
            if(listView) listView.style.display = 'none';
            if(cardView) cardView.style.display = 'block';
            if(btns.length > 0) btns[0].classList.remove('active');
            if(btns.length > 1) btns[1].classList.add('active');
        }
    }

    // Selection Logic
    const STORAGE_KEY = 'employee_selection';
    
    function getSelection() {
        const stored = sessionStorage.getItem(STORAGE_KEY);
        return stored ? JSON.parse(stored) : [];
    }
    
    function saveSelection(selection) {
        sessionStorage.setItem(STORAGE_KEY, JSON.stringify(selection));
        updateSelectionUI();
    }
    
    function updateSelectionUI() {
        const selection = getSelection();
        const statusEl = document.getElementById('selection-status');
        const countEl = document.getElementById('selected-count');
        const selectAllCheckbox = document.getElementById('selectAll');
        
        if (statusEl && countEl) {
            if (selection.length > 0) {
                statusEl.style.display = 'flex';
                countEl.textContent = selection.length;
            } else {
                statusEl.style.display = 'none';
            }
        }

        // Update row checkboxes
        const checkboxes = document.querySelectorAll('.row-checkbox');
        let allChecked = true;
        let hasCheckbox = false;

        checkboxes.forEach(cb => {
            hasCheckbox = true;
            if (selection.includes(cb.value)) {
                cb.checked = true;
            } else {
                cb.checked = false;
                allChecked = false;
            }
        });

        // Update Select All checkbox state
        if (selectAllCheckbox) {
            if (hasCheckbox && allChecked) {
                selectAllCheckbox.checked = true;
                selectAllCheckbox.indeterminate = false;
            } else if (hasCheckbox && document.querySelectorAll('.row-checkbox:checked').length > 0) {
                selectAllCheckbox.checked = false;
                selectAllCheckbox.indeterminate = true;
            } else {
                selectAllCheckbox.checked = false;
                selectAllCheckbox.indeterminate = false;
            }
        }
    }
    
    function clearSelection() {
        sessionStorage.removeItem(STORAGE_KEY);
        updateSelectionUI();
    }
    
    // Page Size Change Handler (Global)
    window.changePageSize = function(limit) {
         const url = new URL(window.location.href);
         url.searchParams.set('limit', limit);
         url.searchParams.set('page', 1); // Reset to page 1
         loadContent(url.toString());
    }

    window.filterEmploymentStatus = function(status) {
        const url = new URL(window.location.href);
        if (status) {
            url.searchParams.set('employment_status', status);
        } else {
            url.searchParams.delete('employment_status');
        }
        url.searchParams.set('page', 1);
        loadContent(url.toString());
    }

    // PJAX Loading Function
    async function loadContent(url, updateHistory = true) {
        const rightContent = document.querySelector('.right-content');
        if (rightContent) {
            rightContent.style.opacity = '0.6';
            rightContent.style.pointerEvents = 'none';
        }

        try {
            const response = await fetch(url, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });
            const html = await response.text();
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');

            // Replace content
            const newContent = doc.querySelector('.right-content');
            if (newContent && rightContent) {
                rightContent.innerHTML = newContent.innerHTML;
            }

            // Update URL
            if (updateHistory) {
                window.history.pushState({}, '', url);
            }

            // Restore View
             const isCardView = $('.view-toggle-btn[onclick="switchView(\'card\')"]').hasClass('active');
             if (isCardView) {
                 switchView('card');
             } else {
                 switchView('list');
             }
             
             // Re-initialize UI
             updateSelectionUI();
             
             // Re-highlight active node based on new URL params
             highlightActiveNode();

        } catch (error) {
            console.error('PJAX Error:', error);
            window.location.href = url; // Fallback
        } finally {
            if (rightContent) {
                rightContent.style.opacity = '1';
                rightContent.style.pointerEvents = 'auto';
            }
        }
    }

    // Highlight Active Node Function
    function highlightActiveNode() {
        const urlParams = new URLSearchParams(window.location.search);
        const deptId = urlParams.get('department_id');
        const compId = urlParams.get('company_id');
        
        $('.org-text-content').removeClass('active-node');

        if (deptId) {
             const $target = $(`.org-text-content[id="${deptId}"]`);
             $target.addClass('active-node');
             // Expand parents
             $target.parents('.sub-tree-content').show().prev('.tree-indent').show();
             $target.parents('.sub-tree-content').prevAll('.item-content').find('.arrow-icon i').removeClass('fa-caret-right').addClass('fa-caret-down');
         } else if (compId) {
             const $target = $(`.org-text-content[id="${compId}"]`);
             $target.addClass('active-node');
             $target.parents('.sub-tree-content').show().prev('.tree-indent').show();
             $target.parents('.sub-tree-content').prevAll('.item-content').find('.arrow-icon i').removeClass('fa-caret-right').addClass('fa-caret-down');
         }
    }

    // Initialize & Bind Events
    $(document).ready(function() {
        // Initialize Selection UI
        updateSelectionUI();
        highlightActiveNode();
        
        // Handle Browser Back/Forward
        window.addEventListener('popstate', function() {
            loadContent(window.location.href, false);
        });

        // Event Delegation for Selection
        $('body').on('change', '#selectAll', function() {
            const checkboxes = document.querySelectorAll('.row-checkbox');
            let selection = getSelection();
            const isChecked = this.checked;
            
            checkboxes.forEach(checkbox => {
                checkbox.checked = isChecked;
                const value = checkbox.value;
                
                if (isChecked) {
                    if (!selection.includes(value)) {
                        selection.push(value);
                    }
                } else {
                    selection = selection.filter(id => id !== value);
                }
            });
            
            saveSelection(selection);
        });

        $('body').on('change', '.row-checkbox', function() {
            let selection = getSelection();
            const value = this.value;
            
            if (this.checked) {
                if (!selection.includes(value)) {
                    selection.push(value);
                }
            } else {
                selection = selection.filter(id => id !== value);
            }
            
            saveSelection(selection);
        });

        // Tree Fold Logic
        const leftTree = $("#leftTree");
        const btn = $("#collapseTree");
        btn.on("click", function() {
            leftTree.toggleClass("collapsed");
            const icon = $(this).find("i");
            if (leftTree.hasClass("collapsed")) {
                icon.removeClass("fa-chevron-left").addClass("fa-chevron-right");
            } else {
                icon.removeClass("fa-chevron-right").addClass("fa-chevron-left");
            }
        });

        // Remove any existing click handlers on tree nodes to prevent conflict
        $('.org-text-content').off('click');

        // PJAX: Tree Click - Bind to #leftTree to catch event before body delegation
        $('#leftTree').on('click', '.org-text-content', function(e) {
            e.preventDefault();
            e.stopPropagation(); 
            
            const $this = $(this);
            const type = $this.attr('type') || 'corperations'; 
            const id = $this.attr('id');
            
            let newUrl = window.location.pathname;
            const params = new URLSearchParams(window.location.search);

            // Update department or company
            if (type === 'department' && id) {
                params.set('department_id', id);
                params.delete('company_id');
            } else if (type === 'company' && id) {
                params.set('company_id', id);
                params.delete('department_id');
            } else {
                params.delete('department_id');
                params.delete('company_id');
            }
            
            // Include sub-departments toggle state
            const includeSub = $('#includeSubToggle').is(':checked');
            params.set('include_sub', includeSub ? '1' : '0');
            
            // Reset to page 1
            params.set('page', 1);

            if (params.toString()) {
                newUrl += '?' + params.toString();
            }

            // UI Update is handled in loadContent -> highlightActiveNode
            loadContent(newUrl);
        });
        
        // PJAX: Toggle Include Sub-departments
        $('body').on('change', '#includeSubToggle', function() {
            const url = new URL(window.location.href);
            if (this.checked) {
                url.searchParams.set('include_sub', '1');
            } else {
                url.searchParams.set('include_sub', '0');
            }
            url.searchParams.set('page', 1); // Reset to page 1
            loadContent(url.toString());
        });
        
        // PJAX: Pagination Click
        $('body').on('click', '.pagination-btn', function(e) {
            const href = $(this).attr('href');
            if (href && href !== '#' && !$(this).attr('disabled') && !$(this).hasClass('active')) {
                e.preventDefault();
                
                // Robustness: Merge current filters if missing in the link
                const urlObj = new URL(href, window.location.origin);
                const currentParams = new URLSearchParams(window.location.search);
                
                // Preserve filters if they exist in current view but not in link
                if (currentParams.has('department_id') && !urlObj.searchParams.has('department_id')) {
                    urlObj.searchParams.set('department_id', currentParams.get('department_id'));
                }
                if (currentParams.has('company_id') && !urlObj.searchParams.has('company_id')) {
                    urlObj.searchParams.set('company_id', currentParams.get('company_id'));
                }
                if (currentParams.has('include_sub') && !urlObj.searchParams.has('include_sub')) {
                    urlObj.searchParams.set('include_sub', currentParams.get('include_sub'));
                }
                
                loadContent(urlObj.toString());
            }
        });

        // PJAX: Search Submit
        $('body').on('submit', 'form[action*="employee"]', function(e) {
            e.preventDefault();
            const url = new URL(this.action, window.location.origin);
            const formData = new FormData(this);
            const params = new URLSearchParams(url.search); // Start with existing params in action if any
            
            for (const [key, value] of formData.entries()) {
                params.set(key, value);
            }
            
            // Also merge current filters if they are not in the form
            const currentParams = new URLSearchParams(window.location.search);
             if (currentParams.has('department_id') && !params.has('department_id')) {
                params.set('department_id', currentParams.get('department_id'));
            }
            if (currentParams.has('company_id') && !params.has('company_id')) {
                params.set('company_id', currentParams.get('company_id'));
            }
            
            // Explicitly set include_sub from toggle
            const includeSub = $('#includeSubToggle').is(':checked');
            params.set('include_sub', includeSub ? '1' : '0');

            url.search = params.toString();
            loadContent(url.toString());
        });
        
        $('<style>.active-node { color: #3b82f6; font-weight: bold; }</style>').appendTo('head');

        // 监听来自 Mercure 的数据同步事件 (基于 ef-mercure.js)
        $(document).on('ef:sync', '[data-ef-sync^="employee:"]', function(e, data) {
            const $el = $(this);
            
            // 1. 处理头像容器更新 (div 或 img)
            if (typeof data.avatarUrl !== 'undefined') {
                if ($el.is('img')) {
                    $el.attr('src', data.avatarUrl || '');
                } else if ($el.hasClass('profile-avatar') || $el.hasClass('card-custom-avatar') || $el.hasClass('card-avatar-img') || $el.hasClass('custom-avatar')) {
                    // 如果是自定义头像容器 div
                    if (data.avatarUrl) {
                        $el.html(`<img src="${data.avatarUrl}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">`);
                        $el.css('background-color', 'transparent');
                    } else {
                        // 降级回名字缩写
                        const name = data.name || $el.attr('data-name') || '';
                        if (name) {
                            $el.text(name.slice(-2));
                        }
                        $el.css('background-color', '#3b82f6');
                    }
                }
            }
            
            // 2. 如果是整行数据更新 (tr 或 .employee-card)
            if (($el.is('tr') || $el.hasClass('employee-card')) && data.name) {
                const $nameSpan = $el.find('.sync-val-name');
                $nameSpan.text(data.name);
                
                // 离职红线逻辑
                if (data.employmentStatus === 'inactive') {
                    $nameSpan.css({
                        'text-decoration': 'underline',
                        'text-decoration-color': '#ef4444',
                        'text-underline-offset': '4px'
                    });
                } else {
                    $nameSpan.css({
                        'text-decoration': 'none'
                    });
                }

                $el.find('.sync-val-employeeNo').text(data.employeeNo);
                
                // 部门和职位
                const $deptText = $el.find('.dept-text');
                if ($deptText.length) {
                    $deptText.text(' ' + data.department);
                } else {
                    $el.find('.sync-val-department').text(data.department);
                }
                
                $el.find('.sync-val-position').text(data.position);
                $el.find('.sync-val-hireDate').text(data.hireDate);
                
                // 状态 - HTML 重构 (仅显示工作状态)
                if (data.workStatus) {
                    const $statusTd = $el.find('.sync-val-status');
                    if ($statusTd.length) {
                        let workIcon = 'fa-circle';
                        if (data.workStatus === 'working') workIcon = 'fa-briefcase';
                        else if (data.workStatus === 'vacation') workIcon = 'fa-umbrella-beach';
                        else if (data.workStatus === 'business_trip') workIcon = 'fa-plane';
                        else if (data.workStatus === 'out_of_office') workIcon = 'fa-person-walking-arrow-right';
                        else if (data.workStatus === 'in_meeting') workIcon = 'fa-users';

                        $statusTd.html(`
                            <div style="font-size: 14px; color: #334155; display: flex; align-items: center; gap: 6px;">
                                <i class="fa-solid ${workIcon}" style="color: #64748b;"></i>
                                ${data.workStatusTrans || data.workStatus}
                            </div>
                        `);
                    }
                    
                    // 卡片视图的状态点
                    const $cardStatus = $el.find('.status-indicator');
                    if ($cardStatus.length) {
                        $cardStatus.removeClass('indicator-active indicator-inactive indicator-vacation');
                        $cardStatus.addClass('indicator-' + data.employmentStatus);
                    }
                }
            }
        });
        
        // 监听 Mercure 异步导出完成事件
        if (window.EF && window.EF.Mercure) {
            const userId = '{{ app.user.id ?? app.user.userIdentifier }}';
            const topic = 'https://enterprise.local/user/' + userId + '/export';
            window.EF.Mercure.subscribe(topic);
            
            window.EF.Mercure.on('export_complete', function(data) {
                    if (window.$.alert) {
                        window.$.alert.success(data.message + ' <br><br><a href="' + data.download_url + '" class="btn primary small round" style="text-decoration: none; display: inline-flex; align-items: center; gap: 6px;" target="_blank"><i class="fa-solid fa-download"></i> 立即下载</a>', {
                            percent: '320px', 
                            title: data.title || '处理完成', 
                            closable: true
                        });
                    } else {
                        // 降级处理，以防 Alert 组件未加载
                        alert(data.message + '\n请访问此链接下载: ' + data.download_url);
                    }
                });
        }
    });
</script>
{% endblock %}
