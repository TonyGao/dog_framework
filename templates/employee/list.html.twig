{% extends 'admin/layout.html.twig' %}
{% import 'components/tree.html.twig' as treeComponent %}
{% import 'ui/template/ui.html.twig' as ui %}

{% block title %}{{ 'employee.list.title'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" type="text/css" href="{{ asset('platform/treeLayout.css', 'admin') }}"/>
    <style>
        .custom-toolbar-box {
            background: #fff;
            padding: 15px 20px;
            margin-bottom: 20px;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
        }
        .custom-toolbar-wrap {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .custom-toolbar-content {
            display: flex;
            gap: 12px;
            align-items: center;
        }
        .right-content {
            padding: 20px;
            background-color: #f8fafc;
        }
        .right-content .ef-table {
            width: 100% !important;
        }
        
        /* Custom Checkbox */
        .custom-checkbox {
            appearance: none;
            background-color: #fff;
            margin: 0;
            font: inherit;
            color: currentColor;
            width: 18px;
            height: 18px;
            border: 1px solid #cbd5e1;
            border-radius: 4px;
            display: grid;
            place-content: center;
            cursor: pointer;
            transition: all 0.2s;
        }
        .custom-checkbox::before {
            content: "";
            width: 10px;
            height: 10px;
            transform: scale(0);
            transition: 120ms transform ease-in-out;
            box-shadow: inset 1em 1em #fff;
            transform-origin: center;
            clip-path: polygon(14% 44%, 0 65%, 50% 100%, 100% 16%, 80% 0%, 43% 62%);
        }
        .custom-checkbox:checked {
            background-color: #3b82f6;
            border-color: #3b82f6;
        }
        .custom-checkbox:checked::before {
            transform: scale(1);
        }

        /* Custom Avatar */
        .custom-avatar {
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #3b82f6;
            color: white;
            font-weight: 600;
            font-size: 11px;
            border-radius: 50%;
            width: 28px;
            height: 28px;
            text-transform: uppercase;
        }
        
        .card-custom-avatar {
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #3b82f6;
            color: white;
            font-weight: 600;
            font-size: 16px;
            border-radius: 50%;
            width: 48px;
            height: 48px;
            text-transform: uppercase;
        }

        /* Color variations for avatars based on name hash (simple cycle) */
        .avatar-color-0 { background-color: #3b82f6; } /* Blue */
        .avatar-color-1 { background-color: #ef4444; } /* Red */
        .avatar-color-2 { background-color: #10b981; } /* Emerald */
        .avatar-color-3 { background-color: #f59e0b; } /* Amber */
        .avatar-color-4 { background-color: #8b5cf6; } /* Violet */
        .avatar-color-5 { background-color: #ec4899; } /* Pink */
        .avatar-color-6 { background-color: #06b6d4; } /* Cyan */
        .avatar-color-7 { background-color: #f97316; } /* Orange */

        /* Left Tree Styling Refined */
        .left-tree {
            background: #fff !important;
            border-radius: 0 !important; /* Removed border-radius */
            border: 1px solid #e2e8f0;
            padding: 10px 0;
            /* margin-right: 20px; Removed margin, handled by container */
            width: 280px; /* Fixed width for transition */
            transition: all 0.3s ease;
            overflow: hidden;
            white-space: nowrap;
            flex-shrink: 0; /* Prevent shrinking */
        }
        .left-tree.collapsed {
            width: 0 !important;
            padding: 0 !important;
            border: none !important;
        }
        
        .fold-icon-wrapper {
            width: 20px;
            height: 40px;
            background: transparent;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            border-top-right-radius: 8px;
            border-bottom-right-radius: 8px;
            color: #94a3b8;
            align-self: center;
            margin-left: -1px; /* Overlap border */
            z-index: 1001;
            flex-shrink: 0;
            transition: all 0.3s ease;
        }
        .fold-icon-wrapper:hover {
            color: #475569;
            background: #f1f5f9;
        }

        .department-tree-wrapper {
            padding: 0 10px;
        }
        .search-department-wrapper {
            padding: 10px 15px;
            border-bottom: 1px solid #f1f5f9;
            margin-bottom: 10px;
        }
        .search-department-wrapper input {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 6px;
        }

        /* Stats Cards */
        .stats-container {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 20px;
        }

        .stats-container.hidden {
            display: none !important;
        }
        .stats-card {
            background: #fff;
            border-radius: 12px;
            padding: 20px;
            border: 1px solid #e2e8f0;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .stats-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: #64748b;
            font-size: 14px;
            font-weight: 500;
        }
        .stats-value {
            font-size: 24px;
            font-weight: 700;
            color: #0f172a;
        }
        .stats-trend {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 11px;
            font-weight: 600;
            padding: 2px 8px;
            border-radius: 6px;
        }
        .trend-up {
            background: #dcfce7;
            color: #166534;
        }
        .trend-down {
            background: #fee2e2;
            color: #991b1b;
        }
        
        /* Search Input Refined */
        .search-wrapper {
            position: relative;
            width: 240px;
        }
        .search-wrapper input {
            width: 100%;
            padding: 8px 10px 8px 32px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            background: #f8fafc;
            color: #334155;
            font-size: 13px;
            transition: all 0.2s;
        }
        .search-wrapper input:focus {
            background: #fff;
            border-color: #3b82f6;
            outline: none;
            box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.1);
        }
        .search-wrapper i {
            position: absolute;
            left: 10px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 13px;
        }

        /* Filter Tabs */
        .filter-tabs {
            display: flex;
            background: #f1f5f9;
            padding: 3px;
            border-radius: 6px;
            gap: 4px;
        }
        .filter-tab {
            padding: 5px 10px;
            border-radius: 5px;
            font-size: 12px;
            font-weight: 500;
            color: #64748b;
            cursor: pointer;
            transition: all 0.2s;
            border: none;
            background: transparent;
        }
        .filter-tab.active {
            background: #fff;
            color: #0f172a;
            box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        }

        /* View Toggle */
        .view-toggle {
            display: flex;
            background: #fff;
            padding: 3px;
            border-radius: 6px;
            margin-left: 10px;
            border: 1px solid #e2e8f0;
        }
        .view-toggle-btn {
            border: none;
            background: transparent;
            padding: 6px 8px;
            border-radius: 4px;
            cursor: pointer;
            color: #94a3b8;
            transition: all 0.2s;
            font-size: 12px;
        }
        .view-toggle-btn:hover {
            color: #64748b;
        }
        .view-toggle-btn.active {
            background: #f1f5f9;
            color: #0f172a;
        }
        
        /* Custom Table Styles */
        .custom-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            background: #fff;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            overflow: hidden;
        }
        .custom-table th {
            text-align: left;
            padding: 12px 20px;
            border-bottom: 1px solid #e2e8f0;
            color: #64748b;
            font-weight: 600;
            font-size: 12px;
            background: #fcfcfc;
            text-transform: uppercase;
            letter-spacing: 0.02em;
        }
        .custom-table th i {
            margin-left: 6px;
            font-size: 11px;
            color: #cbd5e1;
            cursor: pointer;
        }
        .custom-table td {
            padding: 12px 20px;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
            color: #334155;
            font-size: 13px;
            background: #fff;
        }
        .custom-table tr:last-child td {
            border-bottom: none;
        }
        .custom-table tr:hover td {
            background: #f8fafc;
        }
        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .user-avatar {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            object-fit: cover;
        }
        .user-name {
            font-weight: 500;
            color: #0f172a;
        }
        .status-pill {
            display: inline-flex;
            align-items: center;
            padding: 2px 8px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
            line-height: 1.4;
        }
        .status-active { background: #dcfce7; color: #166534; }
        .status-inactive { background: #fee2e2; color: #991b1b; }
        .status-vacation { background: #ffedd5; color: #9a3412; }
        
        .dept-dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            margin-right: 6px;
        }
        
        /* Card View Styles Refined */
        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 20px;
            padding: 20px 0;
        }
        .employee-card {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 16px;
            display: flex;
            flex-direction: column;
            transition: all 0.2s ease;
            position: relative;
        }
        .employee-card:hover {
            box-shadow: 0 12px 24px -8px rgba(0, 0, 0, 0.08);
            border-color: #cbd5e1;
        }
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 16px;
        }
        .card-avatar-wrapper {
            position: relative;
            width: 48px;
            height: 48px;
        }
        .card-avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            object-fit: cover;
        }
        .status-indicator {
            position: absolute;
            bottom: 2px;
            right: 2px;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            border: 2px solid #fff;
        }
        .indicator-active { background-color: #22c55e; }
        .indicator-inactive { background-color: #ef4444; }
        .indicator-vacation { background-color: #f59e0b; }

        .card-main-info {
            margin-bottom: 16px;
        }
        .card-name {
            font-size: 16px;
            font-weight: 600;
            color: #0f172a;
            margin-bottom: 4px;
            display: block;
        }
        .card-role {
            font-size: 13px;
            color: #64748b;
        }
        
        .card-details-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            padding: 16px 0;
            border-top: 1px solid #f1f5f9;
            margin-bottom: 16px;
        }
        .detail-item {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }
        .detail-label {
            font-size: 11px;
            color: #94a3b8;
            font-weight: 500;
        }
        .detail-value {
            font-size: 13px;
            font-weight: 600;
            color: #334155;
        }

        .card-contact-info {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .contact-item {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 14px;
            color: #0f172a;
            font-weight: 600;
        }
        .contact-item i {
            width: 16px;
            color: #64748b;
            font-size: 14px;
        }
        
        /* Action Button Style */
        .action-btn {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            border: none;
            background: transparent;
            color: #94a3b8;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease;
        }
        .action-btn:hover {
            background-color: #f1f5f9;
            color: #3b82f6;
            transform: scale(1.1);
        }

        /* Pagination Style Refined */
        .custom-pagination {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 20px;
            border-top: 1px solid #f1f5f9;
            margin-top: 20px;
            color: #64748b;
            font-size: 13px;
        }
        .pagination-info {
            font-weight: 500;
        }
        .pagination-controls {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .pagination-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 6px 12px;
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            color: #475569;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            height: 32px;
        }
        .pagination-btn:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
            color: #1e293b;
            box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        }
        .page-number-btn {
            width: 32px;
            padding: 0;
        }
        .page-number-btn.active {
            background: #f1f5f9;
            color: #0f172a;
            border-color: #cbd5e1;
            font-weight: 600;
        }
        .page-size-select {
            padding: 0 10px;
            height: 32px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            background: #fff;
            color: #475569;
            font-size: 13px;
            cursor: pointer;
            outline: none;
            margin-right: 12px;
        }
        .page-size-select:hover {
            border-color: #cbd5e1;
        }
        
        /* Ensure arrow icon is clickable */
        .common-tree-wrapper .arrow-icon {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 20px;
            cursor: pointer;
            z-index: 100;
        }
        .arrow-icon:hover {
            color: #3b82f6;
        }
    </style>
{% endblock %}

{% block app_content_container %}
<div class="org-structure-container">
    <div class="outside-wrapper">
        <div class="inside-wrapper">
            {# Left Tree #}
            <div class="left-tree visible" id="leftTree">
                <div class="left-tree-wrapper">
                    <div class="search-department-wrapper">
                        <span class="ef-input-wrapper">
                            <input class="ef-input ef-input-size-mini text" type="text" placeholder="{{ 'employee.list.search_department'|trans }}"/>
                            <span class="ef-input-suffix"><i class="fa-solid fa-magnifying-glass"></i></span>
                        </span>
                    </div>
                    <div class="department-tree-wrapper common-tree-wrapper">
                         {{ tree | raw }}
                    </div>
                </div>
            </div>
            
            <div class="fold-icon-wrapper" id="collapseTree">
                <i class="fa-solid fa-chevron-left"></i>
            </div>
            
            {# Right Content #}
            <div class="right-content">
                
                {# Stats Cards #}
                {% if stats is defined %}
                <div class="stats-container {% if not show_stats %}hidden{% endif %}">
            <div class="stats-card">
                        <div class="stats-header">
                            <span>{{ 'employee.stats.total_employees'|trans }}</span>
                            <i class="fa-solid fa-circle-info" style="color: #cbd5e1;"></i>
                        </div>
                        <div class="stats-value">{{ stats.total_employee.value }}</div>
                        <div class="stats-trend {{ stats.total_employee.trend == 'up' ? 'trend-up' : 'trend-down' }}">
                            <i class="fa-solid {{ stats.total_employee.trend == 'up' ? 'fa-arrow-trend-up' : 'fa-arrow-trend-down' }}"></i>
                            {{ stats.total_employee.change }} {{ 'employee.stats.increase_last_month'|trans }}
                        </div>
                    </div>
                    <div class="stats-card">
                        <div class="stats-header">
                            <span>{{ 'employee.stats.active_employees'|trans }}</span>
                            <i class="fa-solid fa-circle-info" style="color: #cbd5e1;"></i>
                        </div>
                        <div class="stats-value">{{ stats.active_employee.value }}</div>
                        <div class="stats-trend {{ stats.active_employee.trend == 'up' ? 'trend-up' : 'trend-down' }}">
                            <i class="fa-solid {{ stats.active_employee.trend == 'up' ? 'fa-arrow-trend-up' : 'fa-arrow-trend-down' }}"></i>
                            {{ stats.active_employee.change }} {{ 'employee.stats.decrease_yesterday'|trans }}
                        </div>
                    </div>
                    <div class="stats-card">
                        <div class="stats-header">
                            <span>{{ 'employee.stats.total_departments'|trans }}</span>
                            <i class="fa-solid fa-circle-info" style="color: #cbd5e1;"></i>
                        </div>
                        <div class="stats-value">{{ stats.total_department.value }}</div>
                        <div class="stats-trend {{ stats.total_department.trend == 'up' ? 'trend-up' : 'trend-down' }}">
                            <i class="fa-solid {{ stats.total_department.trend == 'up' ? 'fa-arrow-trend-up' : 'fa-arrow-trend-down' }}"></i>
                            {{ stats.total_department.change }} {{ 'employee.stats.increase_last_year'|trans }}
                        </div>
                    </div>
                    <div class="stats-card">
                        <div class="stats-header">
                            <span>{{ 'employee.stats.average_tenure'|trans }}</span>
                            <i class="fa-solid fa-circle-info" style="color: #cbd5e1;"></i>
                        </div>
                        <div class="stats-value">{{ stats.average_tenure.value }} <span style="font-size: 14px; font-weight: normal; color: #64748b;">{{ 'employee.stats.year_unit'|trans }}</span></div>
                        <div class="stats-trend {{ stats.average_tenure.trend == 'up' ? 'trend-up' : 'trend-down' }}">
                            <i class="fa-solid {{ stats.average_tenure.trend == 'up' ? 'fa-arrow-trend-up' : 'fa-arrow-trend-down' }}"></i>
                            {{ stats.average_tenure.change }} {{ 'employee.stats.increase_last_year'|trans }}
                        </div>
                    </div>
                </div>
                {% endif %}

                <h2 style="font-size: 18px; font-weight: 600; color: #0f172a; margin-bottom: 15px;">{{ 'employee.list.header'|trans }}</h2>

                {# Toolbar #}
                <div class="custom-toolbar-box">
                    <div class="custom-toolbar-wrap">
                        <div class="custom-toolbar-content">
                            <div class="search-wrapper">
                                <form action="{{ path('employee_list') }}" method="get" style="display: flex; align-items: center; width: 100%;">
                                    {% for key, value in app.request.query.all %}
                                        {% if key != 'q' and key != 'page' %}
                                            <input type="hidden" name="{{ key }}" value="{{ value }}">
                                        {% endif %}
                                    {% endfor %}
                                    <i class="fa-solid fa-magnifying-glass"></i>
                                    <input type="text" name="q" value="{{ app.request.query.get('q') }}" placeholder="{{ 'employee.list.search_placeholder'|trans }}" />
                                </form>
                            </div>
                            
                            <div class="filter-tabs">
                                <button class="filter-tab active">{{ 'employee.filter.all'|trans }}</button>
                                <button class="filter-tab"><i class="fa-regular fa-circle-check" style="margin-right: 4px;"></i> {{ 'employee.filter.active'|trans }}</button>
                                <button class="filter-tab"><i class="fa-solid fa-user-clock" style="margin-right: 4px;"></i> {{ 'employee.filter.pending'|trans }}</button>
                            </div>
                            
                            <button class="btn outline medium mini round icon" style="color: #64748b; border-color: #e2e8f0; margin-left: 10px;" onclick="openColumnModal()">
                                <i class="fa-solid fa-table-columns"></i>
                            </button>

                            <label class="switch-label" style="display: flex; align-items: center; gap: 8px; margin-left: 15px; cursor: pointer; color: #64748b; font-size: 13px; font-weight: 500; user-select: none;">
                                <input type="checkbox" id="includeSubToggle" class="custom-checkbox" {% if app.request.query.getBoolean('include_sub', true) %}checked{% endif %} style="width: 16px; height: 16px;">
                                <span>{{ 'employee.filter.include_sub'|trans({}, 'messages')|default('包含子部门') }}</span>
                            </label>
                        </div>
                         <div class="custom-toolbar-content">
                            <div id="selection-status" style="display: none; align-items: center; gap: 8px; margin-right: 12px; background: #eff6ff; padding: 4px 12px; border-radius: 20px; border: 1px solid #bfdbfe;">
                                <span style="font-size: 13px; color: #1e40af; font-weight: 500;">
                                    {{ 'employee.list.selected'|trans }}: <span id="selected-count">0</span>
                                </span>
                                <button onclick="clearSelection()" style="background: none; border: none; cursor: pointer; color: #60a5fa; padding: 0; margin-left: 4px; font-size: 14px; display: flex; align-items: center;">
                                    <i class="fa-solid fa-circle-xmark"></i>
                                </button>
                            </div>

                            <button class="btn outline medium mini round icon" style="color: #64748b; border-color: #e2e8f0;">
                                <i class="fa-solid fa-file-export"></i>
                            </button>
                             <button class="btn outline medium mini round icon" style="color: #64748b; border-color: #e2e8f0;">
                                <i class="fa-solid fa-file-import"></i>
                            </button>
                            <a href="{{ path('test_employee_onboarding') }}" class="btn primary medium mini round icon" style="background-color: #f97316; border-color: #f97316;">
                                <i class="fa-solid fa-plus"></i>
                            </a>
                            
                            <div style="width: 1px; height: 24px; background: #e2e8f0; margin: 0 5px;"></div>

                            <div class="view-toggle">
                                <button class="view-toggle-btn active" onclick="switchView('list')" title="{{ 'employee.view.list'|trans }}">
                                    <i class="fa-solid fa-list"></i>
                                </button>
                                <button class="view-toggle-btn" onclick="switchView('card')" title="{{ 'employee.view.card'|trans }}">
                                    <i class="fa-solid fa-grip"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                {# List View #}
                <div id="listView">
                    <div>
                        <table class="custom-table">
                            <thead>
                                <tr>
                                    <th style="width: 40px;"><input type="checkbox" class="custom-checkbox" id="selectAll"></th>
                                    {% for key, config in columns %}
                                        {% set sortIcon = 'fa-sort' %}
                                        {% if currentSort == key %}
                                            {% set sortIcon = currentOrder == 'asc' ? 'fa-sort-up' : 'fa-sort-down' %}
                                        {% endif %}
                                        <th>
                                            <a href="{{ path('employee_list', app.request.query.all|merge({'sort': key, 'order': currentSort == key and currentOrder == 'desc' ? 'asc' : 'desc'})) }}" style="color: inherit; text-decoration: none; display: flex; align-items: center;">
                                                {{ config.label|trans }} <i class="fa-solid {{ sortIcon }}" style="margin-left: 6px;"></i>
                                            </a>
                                        </th>
                                    {% endfor %}
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in entities %}
                                <tr>
                                    <td><input type="checkbox" class="custom-checkbox row-checkbox" value="{{ item.employeeNo }}"></td>
                                    {% for key, config in columns %}
                                        {% if key == 'name' %}
                                            <td>
                                                <div class="user-info">
                                                    {% set avatarColorIndex = item.name|length % 8 %}
                                                    <div class="custom-avatar avatar-color-{{ avatarColorIndex }}">
                                                        {{ item.name|slice(-2) }}
                                                    </div>
                                                    <span class="user-name" onclick="openEmployeeDrawer('{{ item.id }}')" style="cursor: pointer;">{{ item.name }}</span>
                                                </div>
                                            </td>
                                        {% elseif key == 'employeeNo' %}
                                            <td>{{ item.employeeNo }}</td>
                                        {% elseif key == 'department' %}
                                            <td>
                                                <span class="dept-dot" style="background-color: #f59e0b;"></span>
                                                {{ item.department ? item.department.name : '' }}
                                            </td>
                                        {% elseif key == 'position' %}
                                            <td>{{ item.position ? item.position.name : '' }}</td>
                                        {% elseif key == 'status' %}
                                            <td>
                                                {% if item.status == 'active' %}
                                                    <span class="status-pill status-active"><i class="fa-solid fa-check" style="margin-right:4px;"></i> {{ 'employee.status.active'|trans }}</span>
                                                {% elseif item.status == 'inactive' %}
                                                    <span class="status-pill status-inactive"><i class="fa-solid fa-xmark" style="margin-right:4px;"></i> {{ 'employee.status.inactive'|trans }}</span>
                                                {% else %}
                                                    <span class="status-pill status-vacation"><i class="fa-solid fa-umbrella-beach" style="margin-right:4px;"></i> {{ 'employee.status.vacation'|trans }}</span>
                                                {% endif %}
                                            </td>
                                        {% elseif key == 'hireDate' %}
                                            <td>{{ item.hireDate ? item.hireDate|date('Y-m-d') : '' }}</td>
                                        {% elseif key == 'email' %}
                                            <td>{{ item.email }}</td>
                                        {% elseif key == 'mobile' %}
                                            <td>{{ item.mobile }}</td>
                                        {% elseif key == 'gender' %}
                                            <td>{{ item.gender }}</td>
                                         {% elseif key == 'birthDate' %}
                                            <td>{{ item.birthDate ? item.birthDate|date('Y-m-d') : '' }}</td>
                                         {% elseif key == 'idCard' %}
                                            <td>{{ item.idCard }}</td>
                                         {% elseif key == 'englishName' %}
                                            <td>{{ item.englishName }}</td>
                                        {% else %}
                                            <td></td>
                                        {% endif %}
                                    {% endfor %}
                                    <td style="text-align: right;">
                                        <button class="action-btn"><i class="fa-solid fa-ellipsis-vertical"></i></button>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>

                {# Card View #}
                <div id="cardView" style="display: none;">
                    <div class="card-grid">
                        {% for item in entities %}
                        <div class="employee-card">
                            <div class="card-header">
                                <div class="card-avatar-wrapper">
                                    {% set avatarColorIndex = item.name|length % 8 %}
                                    <div class="card-custom-avatar avatar-color-{{ avatarColorIndex }}">
                                        {{ item.name|slice(-2) }}
                                    </div>
                                    {% if item.status == 'active' %}
                                        <span class="status-indicator indicator-active"></span>
                                    {% elseif item.status == 'inactive' %}
                                        <span class="status-indicator indicator-inactive"></span>
                                    {% else %}
                                        <span class="status-indicator indicator-vacation"></span>
                                    {% endif %}
                                </div>
                                <button class="action-btn"><i class="fa-solid fa-ellipsis"></i></button>
                            </div>

                            <div class="card-main-info">
                                <span class="card-name" onclick="openEmployeeDrawer('{{ item.id }}')" style="cursor: pointer;">{{ item.name }}</span>
                                <span class="card-role">{{ item.position ? item.position.name : '' }}</span>
                            </div>

                            <div class="card-details-grid">
                                <div class="detail-item">
                                    <span class="detail-label">{{ 'employee.field.department'|trans }}</span>
                                    <span class="detail-value">{{ item.department ? item.department.name : '' }}</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">{{ 'employee.field.entry_date'|trans }}</span>
                                    <span class="detail-value">{{ item.hireDate ? item.hireDate|date('Y-m-d') : '' }}</span>
                                </div>
                            </div>

                            <div class="card-contact-info">
                                <div class="contact-item">
                                    <i class="fa-regular fa-envelope"></i>
                                    <span>{{ item.email }}</span>
                                </div>
                                <div class="contact-item">
                                    <i class="fa-solid fa-phone"></i>
                                    <span>{{ item.mobile }}</span>
                                </div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
                
                {# Pagination #}
                <div class="custom-pagination">
                    <div class="pagination-info">
                        {{ 'pagination.info'|trans({'%start%': pagination.start, '%end%': pagination.end, '%total%': pagination.totalItems}) }}
                    </div>
                    <div class="pagination-controls">
                        <span style="font-size: 13px; color: #64748b;">{{ 'pagination.per_page'|trans }}</span>
                        <select class="page-size-select" onchange="changePageSize(this.value)">
                            <option value="10" {% if pagination.limit == 10 %}selected{% endif %}>10</option>
                            <option value="20" {% if pagination.limit == 20 %}selected{% endif %}>20</option>
                            <option value="50" {% if pagination.limit == 50 %}selected{% endif %}>50</option>
                            <option value="100" {% if pagination.limit == 100 %}selected{% endif %}>100</option>
                        </select>
                        
                        {% if pagination.currentPage > 1 %}
                            <a href="{{ path('employee_list', app.request.query.all|merge({'page': pagination.currentPage - 1, 'limit': pagination.limit})) }}" class="pagination-btn"><i class="fa-solid fa-chevron-left"></i></a>
                        {% else %}
                            <button class="pagination-btn" style="color: #94a3b8;" disabled><i class="fa-solid fa-chevron-left"></i></button>
                        {% endif %}

                        {% for i in 1..pagination.totalPages %}
                            {% if i == pagination.currentPage %}
                                <button class="pagination-btn page-number-btn active">{{ i }}</button>
                            {% elseif i == 1 or i == pagination.totalPages or (i >= pagination.currentPage - 2 and i <= pagination.currentPage + 2) %}
                                <a href="{{ path('employee_list', app.request.query.all|merge({'page': i, 'limit': pagination.limit})) }}" class="pagination-btn page-number-btn">{{ i }}</a>
                            {% elseif i == pagination.currentPage - 3 or i == pagination.currentPage + 3 %}
                                <span style="color: #94a3b8; font-size: 12px;">...</span>
                            {% endif %}
                        {% endfor %}

                        {% if pagination.currentPage < pagination.totalPages %}
                            <a href="{{ path('employee_list', app.request.query.all|merge({'page': pagination.currentPage + 1, 'limit': pagination.limit})) }}" class="pagination-btn"><i class="fa-solid fa-chevron-right"></i></a>
                        {% else %}
                            <button class="pagination-btn" style="color: #94a3b8;" disabled><i class="fa-solid fa-chevron-right"></i></button>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="columnModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
    <div style="background: #fff; width: 400px; border-radius: 12px; padding: 20px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
        <h3 style="margin-top: 0; margin-bottom: 15px; font-size: 18px; font-weight: 600; color: #0f172a;">{{ 'employee.list.customize_columns'|trans({}, 'messages')|default('Customize Columns') }}</h3>
        <div id="columnList" style="max-height: 400px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px;">
            {% for key, config in allColumns %}
            <div style="display: flex; align-items: center; gap: 10px;">
                 <input type="checkbox" class="column-checkbox custom-checkbox" value="{{ key }}" {% if columns[key] is defined %}checked{% endif %}>
                 <span>{{ config.label|trans }}</span>
            </div>
            {% endfor %}
        </div>
        <div style="margin-top: 20px; display: flex; justify-content: flex-end; gap: 10px;">
            <button onclick="closeColumnModal()" class="btn outline medium" style="border: 1px solid #e2e8f0; color: #64748b;">{{ 'action.cancel'|trans({}, 'messages')|default('Cancel') }}</button>
            <button onclick="saveColumns()" class="btn primary medium" style="background: #3b82f6; color: #fff; border-color: #3b82f6;">{{ 'action.save'|trans({}, 'messages')|default('Save') }}</button>
        </div>
    </div>
</div>

<script>
    // Column Customization Logic
    window.openColumnModal = function() {
        document.getElementById('columnModal').style.display = 'flex';
    }

    window.closeColumnModal = function() {
        document.getElementById('columnModal').style.display = 'none';
    }

    window.saveColumns = function() {
        const newColumns = {};
        
        // Iterate all checkboxes to preserve original order
        const allCheckboxes = document.querySelectorAll('.column-checkbox');
        allCheckboxes.forEach(cb => {
            if (cb.checked) {
                newColumns[cb.value] = { sortable: true }; 
            }
        });
        
        const currentSort = '{{ currentSort }}';
        const currentOrder = '{{ currentOrder }}';
        
        const data = {
            key: 'employee_list_columns',
            value: {
                columns: newColumns,
                sort: currentSort,
                order: currentOrder
            }
        };
        
        fetch('/api/user/preference/save', {
            method: 'POST',
            body: JSON.stringify(data)
        }).then(res => {
            if(res.ok) {
                location.reload();
            } else {
                alert('Failed to save preferences');
            }
        });
    }

    // Open Employee Drawer
    window.openEmployeeDrawer = function(id) {
        const drawerId = 'employee-detail-drawer-' + id;
        // Remove existing drawer if it exists to ensure fresh content
        if ($('#' + drawerId).length > 0) {
            $('#' + drawerId).remove();
        }
        
        // Create and show loading overlay
        const loadingId = 'drawer-loading-' + id;
        if ($('#' + loadingId).length === 0) {
            $('body').append(`
                <div id="${loadingId}" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255, 255, 255, 0.7); z-index: 9999; display: flex; justify-content: center; align-items: center;">
                    <div class="spinner" style="width: 40px; height: 40px; border: 4px solid #f3f3f3; border-top: 4px solid #3b82f6; border-radius: 50%; animation: spin 1s linear infinite;"></div>
                    <style>@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }</style>
                </div>
            `);
        } else {
            $('#' + loadingId).show();
        }
        
        $.ajax({
            url: '/employee/' + id,
            method: 'GET',
            success: function(html) {
                $('#' + loadingId).remove();
                $('body').append(html);
                $().showDrawer(drawerId);
            },
            error: function(xhr) {
                $('#' + loadingId).remove();
                console.error('Error loading employee details:', xhr);
                // Optional: Show error toast
            }
        });
    }

    // View Switcher
    function switchView(view) {
        const listView = document.getElementById('listView');
        const cardView = document.getElementById('cardView');
        const btns = document.querySelectorAll('.view-toggle-btn');
        
        if (view === 'list') {
            if(listView) listView.style.display = 'block';
            if(cardView) cardView.style.display = 'none';
            if(btns.length > 0) btns[0].classList.add('active');
            if(btns.length > 1) btns[1].classList.remove('active');
        } else {
            if(listView) listView.style.display = 'none';
            if(cardView) cardView.style.display = 'block';
            if(btns.length > 0) btns[0].classList.remove('active');
            if(btns.length > 1) btns[1].classList.add('active');
        }
    }

    // Selection Logic
    const STORAGE_KEY = 'employee_selection';
    
    function getSelection() {
        const stored = sessionStorage.getItem(STORAGE_KEY);
        return stored ? JSON.parse(stored) : [];
    }
    
    function saveSelection(selection) {
        sessionStorage.setItem(STORAGE_KEY, JSON.stringify(selection));
        updateSelectionUI();
    }
    
    function updateSelectionUI() {
        const selection = getSelection();
        const statusEl = document.getElementById('selection-status');
        const countEl = document.getElementById('selected-count');
        const selectAllCheckbox = document.getElementById('selectAll');
        
        if (statusEl && countEl) {
            if (selection.length > 0) {
                statusEl.style.display = 'flex';
                countEl.textContent = selection.length;
            } else {
                statusEl.style.display = 'none';
            }
        }

        // Update row checkboxes
        const checkboxes = document.querySelectorAll('.row-checkbox');
        let allChecked = true;
        let hasCheckbox = false;

        checkboxes.forEach(cb => {
            hasCheckbox = true;
            if (selection.includes(cb.value)) {
                cb.checked = true;
            } else {
                cb.checked = false;
                allChecked = false;
            }
        });

        // Update Select All checkbox state
        if (selectAllCheckbox) {
            if (hasCheckbox && allChecked) {
                selectAllCheckbox.checked = true;
                selectAllCheckbox.indeterminate = false;
            } else if (hasCheckbox && document.querySelectorAll('.row-checkbox:checked').length > 0) {
                selectAllCheckbox.checked = false;
                selectAllCheckbox.indeterminate = true;
            } else {
                selectAllCheckbox.checked = false;
                selectAllCheckbox.indeterminate = false;
            }
        }
    }
    
    function clearSelection() {
        sessionStorage.removeItem(STORAGE_KEY);
        updateSelectionUI();
    }
    
    // Page Size Change Handler (Global)
    window.changePageSize = function(limit) {
         const url = new URL(window.location.href);
         url.searchParams.set('limit', limit);
         url.searchParams.set('page', 1); // Reset to page 1
         loadContent(url.toString());
    }

    // PJAX Loading Function
    async function loadContent(url, updateHistory = true) {
        const rightContent = document.querySelector('.right-content');
        if (rightContent) {
            rightContent.style.opacity = '0.6';
            rightContent.style.pointerEvents = 'none';
        }

        try {
            const response = await fetch(url, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });
            const html = await response.text();
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');

            // Replace content
            const newContent = doc.querySelector('.right-content');
            if (newContent && rightContent) {
                rightContent.innerHTML = newContent.innerHTML;
            }

            // Update URL
            if (updateHistory) {
                window.history.pushState({}, '', url);
            }

            // Restore View
             const isCardView = $('.view-toggle-btn[onclick="switchView(\'card\')"]').hasClass('active');
             if (isCardView) {
                 switchView('card');
             } else {
                 switchView('list');
             }
             
             // Re-initialize UI
             updateSelectionUI();
             
             // Re-highlight active node based on new URL params
             highlightActiveNode();

        } catch (error) {
            console.error('PJAX Error:', error);
            window.location.href = url; // Fallback
        } finally {
            if (rightContent) {
                rightContent.style.opacity = '1';
                rightContent.style.pointerEvents = 'auto';
            }
        }
    }

    // Highlight Active Node Function
    function highlightActiveNode() {
        const urlParams = new URLSearchParams(window.location.search);
        const deptId = urlParams.get('department_id');
        const compId = urlParams.get('company_id');
        
        $('.org-text-content').removeClass('active-node');

        if (deptId) {
             const $target = $(`.org-text-content[id="${deptId}"]`);
             $target.addClass('active-node');
             // Expand parents
             $target.parents('.sub-tree-content').show().prev('.tree-indent').show();
             $target.parents('.sub-tree-content').prevAll('.item-content').find('.arrow-icon i').removeClass('fa-caret-right').addClass('fa-caret-down');
         } else if (compId) {
             const $target = $(`.org-text-content[id="${compId}"]`);
             $target.addClass('active-node');
             $target.parents('.sub-tree-content').show().prev('.tree-indent').show();
             $target.parents('.sub-tree-content').prevAll('.item-content').find('.arrow-icon i').removeClass('fa-caret-right').addClass('fa-caret-down');
         }
    }

    // Initialize & Bind Events
    $(document).ready(function() {
        // Initialize Selection UI
        updateSelectionUI();
        highlightActiveNode();
        
        // Handle Browser Back/Forward
        window.addEventListener('popstate', function() {
            loadContent(window.location.href, false);
        });

        // Event Delegation for Selection
        $('body').on('change', '#selectAll', function() {
            const checkboxes = document.querySelectorAll('.row-checkbox');
            let selection = getSelection();
            const isChecked = this.checked;
            
            checkboxes.forEach(checkbox => {
                checkbox.checked = isChecked;
                const value = checkbox.value;
                
                if (isChecked) {
                    if (!selection.includes(value)) {
                        selection.push(value);
                    }
                } else {
                    selection = selection.filter(id => id !== value);
                }
            });
            
            saveSelection(selection);
        });

        $('body').on('change', '.row-checkbox', function() {
            let selection = getSelection();
            const value = this.value;
            
            if (this.checked) {
                if (!selection.includes(value)) {
                    selection.push(value);
                }
            } else {
                selection = selection.filter(id => id !== value);
            }
            
            saveSelection(selection);
        });

        // Tree Fold Logic
        const leftTree = $("#leftTree");
        const btn = $("#collapseTree");
        btn.on("click", function() {
            leftTree.toggleClass("collapsed");
            const icon = $(this).find("i");
            if (leftTree.hasClass("collapsed")) {
                icon.removeClass("fa-chevron-left").addClass("fa-chevron-right");
            } else {
                icon.removeClass("fa-chevron-right").addClass("fa-chevron-left");
            }
        });

        // Remove any existing click handlers on tree nodes to prevent conflict
        $('.org-text-content').off('click');

        // PJAX: Tree Click - Bind to #leftTree to catch event before body delegation
        $('#leftTree').on('click', '.org-text-content', function(e) {
            e.preventDefault();
            e.stopPropagation(); 
            
            const $this = $(this);
            const type = $this.attr('type') || 'corperations'; 
            const id = $this.attr('id');
            
            let newUrl = window.location.pathname;
            const params = new URLSearchParams();

            if (type === 'department' && id) {
                params.set('department_id', id);
            } else if (type === 'company' && id) {
                params.set('company_id', id);
            }
            
            // Include sub-departments toggle state
            const includeSub = $('#includeSubToggle').is(':checked');
            params.set('include_sub', includeSub ? '1' : '0');

            if (params.toString()) {
                newUrl += '?' + params.toString();
            }

            // UI Update is handled in loadContent -> highlightActiveNode
            loadContent(newUrl);
        });
        
        // PJAX: Toggle Include Sub-departments
        $('body').on('change', '#includeSubToggle', function() {
            const url = new URL(window.location.href);
            if (this.checked) {
                url.searchParams.set('include_sub', '1');
            } else {
                url.searchParams.set('include_sub', '0');
            }
            url.searchParams.set('page', 1); // Reset to page 1
            loadContent(url.toString());
        });
        
        // PJAX: Pagination Click
        $('body').on('click', '.pagination-btn', function(e) {
            const href = $(this).attr('href');
            if (href && href !== '#' && !$(this).attr('disabled') && !$(this).hasClass('active')) {
                e.preventDefault();
                
                // Robustness: Merge current filters if missing in the link
                const urlObj = new URL(href, window.location.origin);
                const currentParams = new URLSearchParams(window.location.search);
                
                // Preserve filters if they exist in current view but not in link
                if (currentParams.has('department_id') && !urlObj.searchParams.has('department_id')) {
                    urlObj.searchParams.set('department_id', currentParams.get('department_id'));
                }
                if (currentParams.has('company_id') && !urlObj.searchParams.has('company_id')) {
                    urlObj.searchParams.set('company_id', currentParams.get('company_id'));
                }
                if (currentParams.has('include_sub') && !urlObj.searchParams.has('include_sub')) {
                    urlObj.searchParams.set('include_sub', currentParams.get('include_sub'));
                }
                
                loadContent(urlObj.toString());
            }
        });

        // PJAX: Search Submit
        $('body').on('submit', 'form[action*="employee"]', function(e) {
            e.preventDefault();
            const url = new URL(this.action, window.location.origin);
            const formData = new FormData(this);
            const params = new URLSearchParams(url.search); // Start with existing params in action if any
            
            for (const [key, value] of formData.entries()) {
                params.set(key, value);
            }
            
            // Also merge current filters if they are not in the form
            const currentParams = new URLSearchParams(window.location.search);
             if (currentParams.has('department_id') && !params.has('department_id')) {
                params.set('department_id', currentParams.get('department_id'));
            }
            if (currentParams.has('company_id') && !params.has('company_id')) {
                params.set('company_id', currentParams.get('company_id'));
            }
            
            // Explicitly set include_sub from toggle
            const includeSub = $('#includeSubToggle').is(':checked');
            params.set('include_sub', includeSub ? '1' : '0');

            url.search = params.toString();
            loadContent(url.toString());
        });
        
        $('<style>.active-node { color: #3b82f6; font-weight: bold; }</style>').appendTo('head');
    });
</script>
{% endblock %}
