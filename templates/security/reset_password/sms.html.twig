{% extends 'base.html.twig' %}

{% block title %}Verify SMS{% endblock %}

{% block body %}
<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-sm" style="width: 100%; max-width: 400px;">
        <div class="card-body p-4 text-center">
            <h3 class="mb-4">Verify SMS</h3>
            <p class="mb-4">We sent a verification code to <strong>{{ user.mobile }}</strong></p>
            
            {% for message in app.flashes('error') %}
                <div class="alert alert-danger">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('info') %}
                <div class="alert alert-info">{{ message }}</div>
            {% endfor %}

            <form action="{{ path('app_reset_password_sms_check', {id: id}) }}" method="post">
                <div class="mb-3">
                    <input type="text" name="code" class="form-control form-control-lg text-center" placeholder="Enter 6-digit code" maxlength="6" required autocomplete="off">
                </div>
                <button type="submit" class="btn btn-primary btn-lg w-100 mb-3">
                    Verify Code
                </button>
            </form>
            
            <div class="d-flex justify-content-between mt-3">
                <a href="{{ path('app_reset_password') }}" class="text-decoration-none">Try another way</a>
                <a href="{{ path('app_reset_password_sms', {id: id, resend: 1}) }}" class="text-decoration-none">Resend Code</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
