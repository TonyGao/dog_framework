{% extends 'security/reset_password/layout.html.twig' %}

{% block reset_content %}
    <h2>{{ 'security.reset_password.page_title'|trans }}</h2>
    
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    {% if user and availableMethods|length > 0 %}
        <p style="color: #6b7280; margin-bottom: 24px; font-size: 14px;">{{ 'security.reset_password.select_method'|trans }}</p>
        <div style="display: flex; flex-direction: column; gap: 12px;">
            {% for method in availableMethods %}
                {% if method.methodKey == 'email' %}
                    <a href="{{ path('app_reset_password_email', {'id': user.id}) }}" class="btn-outline">
                        <i class="fas fa-envelope"></i> {{ 'security.reset_password.send_email_link'|trans }}
                    </a>
                {% elseif method.methodKey == 'sms' %}
                    <a href="{{ path('app_reset_password_sms', {'id': user.id}) }}" class="btn-outline">
                        <i class="fas fa-mobile-alt"></i> {{ 'security.reset_password.send_sms_code'|trans }}
                    </a>
                {% elseif method.methodKey == 'qa' %}
                    <a href="{{ path('app_reset_password_qa', {'id': user.id}) }}" class="btn-outline">
                        <i class="fas fa-question-circle"></i> {{ 'security.reset_password.answer_question'|trans }}
                    </a>
                {% elseif method.methodKey == 'passkey' %}
                    <a href="{{ path('app_reset_password_passkey', {'id': user.id}) }}" class="btn-outline">
                        <i class="fas fa-fingerprint"></i> {{ 'security.reset_password.use_passkey'|trans }}
                    </a>
                {% endif %}
            {% endfor %}
        </div>
    {% else %}
        <form action="{{ path('app_reset_password_check') }}" method="post">
            <div class="form-group">
                <label for="identifier" class="form-label">{{ 'login.form.label.username'|trans }}</label>
                <input type="text" class="form-control" id="identifier" name="identifier" value="{{ username }}" placeholder="{{ 'login.form.label.username'|trans }}" required autofocus>
            </div>
            <button type="submit" class="btn-primary btn-block">{{ 'security.reset_password.next_step'|trans }}</button>
        </form>
    {% endif %}

    <a href="{{ path('app_login') }}" class="back-link">{{ 'security.reset_password.back_to_login'|trans }}</a>
{% endblock %}
