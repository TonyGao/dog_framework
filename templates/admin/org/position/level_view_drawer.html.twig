<link rel="stylesheet" href="{{ asset('sunui/components/position-drawer.css') }}">
<div class="ef-drawer-container" style="z-index: 1001; display: none;" id="{{ drawerId }}">
    <div class="ef-drawer-mask" maskid="{{ drawerId }}"></div>
    <div class="ef-drawer" style="right: -650px; width: 650px; box-shadow: -4px 0 20px rgba(0,0,0,0.15);">
        <div class="ef-drawer-header">
            <div class="ef-drawer-title">
                <i class="fa-solid fa-layer-group" style="margin-right: 12px; font-size: 18px;"></i>
                {{ positionLevel.name }}
                <span style="font-size: 14px; font-weight: 400; margin-left: 8px; opacity: 0.8;">岗位级别详情</span>
            </div>
            <div tabindex="-1" role="button" aria-label="Close" class="ef-drawer-close-btn">
                <span class="ef-icon-hover">
                    <svg viewbox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" class="ef-icon ef-icon-close" stroke-width="4" stroke-linecap="butt" stroke-linejoin="miter">
                        <path d="M9.857 9.858 24 24m0 0 14.142 14.142M24 24 38.142 9.858M24 24 9.857 38.142"></path>
                    </svg>
                </span>
            </div>
        </div>
        <div class="ef-drawer-body">
            <div class="ef-drawer-content">
                <!-- 基本信息 -->
                <div class="ef-section">
                    <div class="ef-section-header">
                        <i class="fa-solid fa-info-circle"></i>
                        <span>基本信息</span>
                    </div>
                    <div class="ef-detail-view ef-detail-two-columns">
                        <div class="ef-detail-row-group">
                            <div class="ef-detail-item">
                                <div class="ef-detail-label">级别名称</div>
                                <div class="ef-detail-value">{{ positionLevel.name }}</div>
                            </div>
                            <div class="ef-detail-item">
                                <div class="ef-detail-label">级别编码</div>
                                <div class="ef-detail-value">{{ positionLevel.code ?: '无' }}</div>
                            </div>
                        </div>
                        <div class="ef-detail-row-group">
                            <div class="ef-detail-item">
                                <div class="ef-detail-label">级别序号</div>
                                <div class="ef-detail-value">{{ positionLevel.levelOrder }}</div>
                            </div>
                            <div class="ef-detail-item">
                                <div class="ef-detail-label">状态</div>
                                <div class="ef-detail-value">
                                    {% if positionLevel.state %}
                                        <span class="ef-badge ef-badge-success">✓ 启用</span>
                                    {% else %}
                                        <span class="ef-badge ef-badge-danger">✗ 停用</span>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                        <div class="ef-detail-row-group">
                            <div class="ef-detail-item">
                                <div class="ef-detail-label">薪资范围下限</div>
                                <div class="ef-detail-value">{{ positionLevel.salaryMin ? positionLevel.salaryMin|number_format(2) : '未设置' }}</div>
                            </div>
                            <div class="ef-detail-item">
                                <div class="ef-detail-label">薪资范围上限</div>
                                <div class="ef-detail-value">{{ positionLevel.salaryMax ? positionLevel.salaryMax|number_format(2) : '未设置' }}</div>
                            </div>
                        </div>
                    </div>
                </div>

                {% if positionLevel.description %}
                <!-- 描述 -->
                <div class="ef-section">
                    <div class="ef-section-header">
                        <i class="fa-solid fa-align-left"></i>
                        <span>描述</span>
                    </div>
                    <div class="ef-detail-content">
                        {{ positionLevel.description|nl2br }}
                    </div>
                </div>
                {% endif %}

            </div>
        </div>
        <div class="ef-drawer-footer">
            <button class="cancelDrawer ef-drawer-btn ef-drawer-btn-secondary" type="button">关闭</button>
            <button type="button" class="ef-drawer-btn ef-drawer-btn-primary edit-button" onclick="openPositionLevelEditDrawer({{ positionLevel.id }})">
                    <i class="fa-solid fa-edit"></i>
                    编辑
            </button>
        </div>
    </div>
</div>

<script>
// 抽屉打开时添加body类，防止页面布局变化
function addDrawerOpenClass() {
    $('body').addClass('ef-drawer-open');
}

// 抽屉关闭时移除body类
function removeDrawerOpenClass() {
    $('body').removeClass('ef-drawer-open');
}

// 监听抽屉显示事件
$(document).ready(function() {
    // 当前抽屉显示时添加类
    addDrawerOpenClass();
    
    // 监听关闭按钮点击
    $('.ef-drawer-close-btn, .cancelDrawer').on('click', function() {
        removeDrawerOpenClass();
        $().hideDrawer('{{ drawerId }}');
    });
    
    // 监听遮罩层点击
    $('.ef-drawer-mask').on('click', function() {
        removeDrawerOpenClass();
        $().hideDrawer('{{ drawerId }}');
    });
});
</script>
