<div class="ef-drawer-container" style="z-index: 1001; display: none;" id="{{ drawerId }}">
    <div class="ef-drawer-mask" maskid="{{ drawerId }}"></div>
    <div class="ef-drawer" style="right: -650px; width: 650px; box-shadow: -4px 0 20px rgba(0,0,0,0.15);">
        <div class="ef-drawer-header">
            <div class="ef-drawer-title">
                <i class="fa-solid fa-eye" style="margin-right: 12px; font-size: 18px;"></i>
                存储配置详情
            </div>
            <div tabindex="-1" role="button" aria-label="Close" class="ef-drawer-close-btn" onclick="closeDrawer('{{ drawerId }}')">
                <span class="ef-icon-hover">
                    <svg viewbox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" class="ef-icon ef-icon-close" stroke-width="4" stroke-linecap="butt" stroke-linejoin="miter">
                        <path d="M9.857 9.858 24 24m0 0 14.142 14.142M24 24 38.142 9.858M24 24 9.857 38.142"></path>
                    </svg>
                </span>
            </div>
        </div>
        <div class="ef-drawer-body">
            <div class="ef-drawer-content">
                <div class="ef-form">
                    <div class="ef-card" style="border: 1px solid #e5e6eb; border-radius: 4px; padding: 20px; margin-bottom: 20px;">
                        <h4 style="margin-bottom: 20px; font-size: 16px; font-weight: 600;">基本信息</h4>
                        
                        <div class="ef-form-item ef-row">
                            <div class="ef-form-label ef-col" style="flex: 0 0 160px;">存储名称</div>
                            <div class="ef-form-item-content ef-form-item-content-flex ef-col" style="padding-top: 5px;">
                                {{ storage_config.name }}
                             </div>
                         </div>
 
                         <div class="ef-form-item ef-row">
                             <div class="ef-form-label ef-col" style="flex: 0 0 160px;">驱动类型</div>
                             <div class="ef-form-item-content ef-form-item-content-flex ef-col" style="padding-top: 5px;">
                                 {% if storage_config.adapterType == 'local' %}
                                     <span class="ef-tag ef-tag-blue">本地存储</span>
                                 {% elseif storage_config.adapterType == 's3' %}
                                     <span class="ef-tag ef-tag-orange">S3 兼容存储</span>
                                 {% else %}
                                     {{ storage_config.adapterType }}
                                 {% endif %}
                             </div>
                         </div>
 
                         <div class="ef-form-item ef-row">
                             <div class="ef-form-label ef-col" style="flex: 0 0 160px;">设为默认</div>
                             <div class="ef-form-item-content ef-form-item-content-flex ef-col" style="padding-top: 5px;">
                                 {% if storage_config.isDefault %}
                                     <span class="ef-tag ef-tag-green">是</span>
                                 {% else %}
                                     <span class="ef-tag ef-tag-grey">否</span>
                                 {% endif %}
                             </div>
                         </div>
 
                         <div class="ef-form-item ef-row">
                            <div class="ef-form-label ef-col" style="flex: 0 0 160px;">CDN 域名</div>
                            <div class="ef-form-item-content ef-form-item-content-flex ef-col" style="padding-top: 5px;">
                                {{ storage_config.cdnDomain|default('-') }}
                            </div>
                        </div>
                    </div>

                    <div class="ef-card" id="storage-config-details-card" style="border: 1px solid #e5e6eb; border-radius: 4px; padding: 20px;">
                        {% if storage_config.adapterType == 'local' %}
                            <div id="local-config-section-drawer">
                                <h4 style="margin-bottom: 20px; font-size: 16px; font-weight: 600;">Local 配置</h4>
                                
                                <div class="ef-form-item ef-row">
                                    <div class="ef-form-label ef-col" style="flex: 0 0 160px;">文件存储策略</div>
                                    <div class="ef-form-item-content ef-form-item-content-flex ef-col" style="padding-top: 5px;">
                                        {% set strategy = storage_config.config.directory_strategy|default('Y/m') %}
                                        {% if strategy == 'Y/m/d' %}按年月日 (YYYY/MM/DD)
                                        {% elseif strategy == 'Y/m' %}按年月 (YYYY/MM)
                                        {% elseif strategy == 'Y' %}按年份 (YYYY)
                                        {% elseif strategy == 'none' %}不创建子目录
                                        {% else %}按年月 (YYYY/MM){% endif %}
                                    </div>
                                </div>
 
                                 <div class="ef-form-item ef-row">
                                     <div class="ef-form-label ef-col" style="flex: 0 0 160px;">存储目录（相对于 public）</div>
                                     <div class="ef-form-item-content ef-form-item-content-flex ef-col" style="padding-top: 5px;">
                                         {{ storage_config.config.directory|default('-') }}
                                     </div>
                                 </div>
                             </div>
                         {% endif %}
 
                         {% if storage_config.adapterType == 's3' %}
                             <div id="s3-config-section-drawer">
                                 <h4 style="margin-bottom: 20px; font-size: 16px; font-weight: 600;">S3 配置</h4>
                                 
                                 <div class="ef-form-item ef-row">
                                     <div class="ef-form-label ef-col" style="flex: 0 0 160px;">Endpoint</div>
                                     <div class="ef-form-item-content ef-form-item-content-flex ef-col" style="padding-top: 5px;">
                                         {{ storage_config.config.endpoint|default('-') }}
                                     </div>
                                 </div>
 
                                 <div class="ef-form-item ef-row">
                                     <div class="ef-form-label ef-col" style="flex: 0 0 160px;">Region</div>
                                     <div class="ef-form-item-content ef-form-item-content-flex ef-col" style="padding-top: 5px;">
                                         {{ storage_config.config.region|default('-') }}
                                     </div>
                                 </div>
 
                                 <div class="ef-form-item ef-row">
                                     <div class="ef-form-label ef-col" style="flex: 0 0 160px;">Bucket</div>
                                     <div class="ef-form-item-content ef-form-item-content-flex ef-col" style="padding-top: 5px;">
                                         {{ storage_config.config.bucket|default('-') }}
                                     </div>
                                 </div>
 
                                 <div class="ef-form-item ef-row">
                                     <div class="ef-form-label ef-col" style="flex: 0 0 160px;">Access Key</div>
                                     <div class="ef-form-item-content ef-form-item-content-flex ef-col" style="padding-top: 5px;">
                                         {{ storage_config.config.access_key|default('-') }}
                                    </div>
                                </div>

                                <div class="ef-form-item ef-row">
                                    <div class="ef-form-label ef-col" style="flex: 0 0 160px;">Secret Key</div>
                                    <div class="ef-form-item-content ef-form-item-content-flex ef-col" style="padding-top: 5px;">
                                        ********
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    </div>

                    <div class="ef-row" style="margin-top: 24px;">
                        <div class="ef-col">
                            <div class="ef-space ef-space-horizontal">
                                <div class="ef-space-item">
                                    <button class="btn secondary medium" type="button" onclick="closeDrawer('{{ drawerId }}')">关闭</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // 抽屉打开时添加body类
    if (typeof addDrawerOpenClass === 'undefined') {
        window.addDrawerOpenClass = function() {
            $('body').addClass('ef-drawer-open');
        }
    }
    if (typeof removeDrawerOpenClass === 'undefined') {
        window.removeDrawerOpenClass = function() {
            $('body').removeClass('ef-drawer-open');
        }
    }
    
    addDrawerOpenClass();

    // 关闭抽屉函数
    window.closeDrawer = function(id) {
        removeDrawerOpenClass();
        $().hideDrawer(id);
        setTimeout(function() {
            $('#' + id).remove();
        }, 300);
    };

    // 监听适配器类型变化 (已移除，因为是纯文本展示，不需要动态显隐)
    window.initStorageViewDrawer = function() {
        // 不需要任何逻辑
    };

    $(document).ready(function() {
        initStorageViewDrawer();
    });
</script>
