                tracking_link: 'https://example.com/track',
                event_name: '2023 年度开发者大会',
                event_time: '2023-11-15 09:00',
                join_link: 'https://example.com/event/join'
            };

            return text.replace(/\{\{\s*([a-zA-Z0-9_]+)\s*\}\}/g, function(match, key) {
                return mockData[key] !== undefined ? mockData[key] : '[' + key + ']';
            });
        }
        function renderPresetPreview(key, mountId) {
            if (!presetTemplates[key]) return;
            const mount = document.getElementById(mountId);
            if (!mount) return;
            
            const html = sampleRender(presetTemplates[key]);
            mount.innerHTML = '<div class="preview-canvas">' + html + '</div>';
        }

        function applyPreset(key) {
            if (!innerTemplates[key]) return;
            const html = innerTemplates[key];
            if (editor) {
                editor.setHtml(html);
                document.getElementById('editorBodyHtml').value = editor.getHtml();
            }
        }

        function previewEmail() {
            const html = editor ? editor.getHtml() : document.getElementById('editorBodyHtml').value;
            const rendered = sampleRender(html);
            const fullHtml = emailWrapperStart + rendered + emailWrapperEnd;
            
            // Create a hidden form to submit the HTML to the new tab
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/admin/email/template/preview';
            form.target = '_blank';
            
            const htmlInput = document.createElement('input');
            htmlInput.type = 'hidden';
            htmlInput.name = 'html';
            htmlInput.value = fullHtml;
            form.appendChild(htmlInput);
            
            const subjectInput = document.createElement('input');
            subjectInput.type = 'hidden';
            subjectInput.name = 'subject';
            const rawSubject = document.getElementById('editorSubjectHidden').value || 'Preview Email';
            subjectInput.value = sampleRender(rawSubject);
            form.appendChild(subjectInput);
            
            document.body.appendChild(form);
            form.submit();
            document.body.removeChild(form);
        }

        function testTemplateEmail() {
            openModal('testTemplateEmailModal');
            setTimeout(() => {
                document.getElementById('templateTestEmailInput').focus();
            }, 100);
        }

        function closeTestTemplateEmailModal() {
            closeModal('testTemplateEmailModal');
            document.getElementById('templateTestEmailInput').value = '';
        }

        function executeTestTemplateEmail() {
            const testEmailInput = document.getElementById('templateTestEmailInput');
            
            if (!testEmailInput) {
                let alert = new Alert($('#testTemplateEmailModal .ef-modal-body'));
                alert.error('无法找到测试邮箱输入框', { title: "错误", closable: true });
                return;
            }
            
            const testEmail = testEmailInput.value;
            
            if (testEmail.trim() === '') {
                let alert = new Alert($('#testTemplateEmailModal .ef-modal-body'));
                alert.error('测试接收邮箱不能为空', { title: "错误", closable: true });
                return;
            }
            
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(testEmail.trim())) {
                let alert = new Alert($('#testTemplateEmailModal .ef-modal-body'));
                alert.error('请输入有效的邮箱地址', { title: "错误", closable: true });
                return;
            }

            const form = document.getElementById('editorForm');
            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());
            data.testEmail = testEmail.trim();
            data.bodyHtml = editor ? editor.getHtml() : document.getElementById('editorBodyHtml').value;
            
            const btn = document.getElementById('confirmTestTemplateEmailBtn');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> 发送中...';
            btn.disabled = true;

            $.ajax({
                method: 'POST',
                url: '/admin/email/template/test-send',
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (response) {
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                    
                    if (response.code === 200) {
                        closeTestTemplateEmailModal();
                        let alert = new Alert($('#testAlertContainer'));
                        alert.success(response.message || '测试邮件发送成功', { title: "成功", closable: true });
                    } else {
                        let alert = new Alert($('#testTemplateEmailModal .ef-modal-body'));
                        alert.error(response.message || '发送失败', { title: "错误", closable: true });
                    }
                },
                error: function (xhr, status, errorMsg) {
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                    const errorMessage = xhr.responseJSON && xhr.responseJSON.message ? xhr.responseJSON.message : errorMsg;
                    let alert = new Alert($('#testTemplateEmailModal .ef-modal-body'));
                    alert.error(errorMessage || '请求发生错误', { title: "错误", closable: true });
                }
            });
        }

        function promptForSubjectAndSubmit() {
            const form = document.getElementById('editorForm');
            if (!form.reportValidity()) {
                return;
            }
            // open drawer
            $().showDrawer('subjectModal');
            setTimeout(() => {
                const subjectInput = document.getElementById('templateSubjectInput');
                if (subjectInput) subjectInput.focus();
            }, 300);
        }

        function closeSubjectModal() {
            $().hideDrawer('subjectModal');
        }

        function confirmSubjectAndSubmit() {
            const subjectInputWrapper = document.getElementById('templateSubjectInput');
            if (!subjectInputWrapper) return;
            
            const subjectInput = subjectInputWrapper.tagName === 'INPUT' ? subjectInputWrapper : subjectInputWrapper.querySelector('input');
            
            if (!subjectInput || !subjectInput.value.trim()) {
                let alert = new Alert($('#subjectModal .ef-drawer-body'));
                alert.error('请输入邮件主题', { title: "错误", closable: true });
                return;
            }
            document.getElementById('editorSubjectHidden').value = subjectInput.value.trim();
            
            // update bodyHtml before submit
            if (editor) {
                document.getElementById('editorBodyHtml').value = editor.getHtml();
            }
            
            document.getElementById('editorForm').submit();
        }

        function togglePresetPanel() {
            const grid = document.getElementById('mainGrid');
            const panel = document.getElementById('presetPanel');
            const icon = document.getElementById('presetToggleIcon');
            if (panel.style.display === 'none') {
                panel.style.display = 'block';
                grid.style.gridTemplateColumns = '500px 1fr';
                if (icon) {
                    icon.innerHTML = '<polyline points="15 18 9 12 15 6"></polyline>';
                }
            } else {
                panel.style.display = 'none';
                grid.style.gridTemplateColumns = '1fr';
                if (icon) {
                    icon.innerHTML = '<polyline points="9 18 15 12 9 6"></polyline>';
                }
            }
        }

