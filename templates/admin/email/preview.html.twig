<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Email Preview</title>
    <link rel="stylesheet" href="{{ asset('/lib/font-awesome-642/css/all.min.css', 'static') }}">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background-color: #f9fafb;
            color: #111827;
            height: 100vh;
            display: flex;
            overflow: hidden;
        }

        /* Top bar from design (if needed, but design has a header on top) */
        .header {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 64px;
            background: #fff;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            z-index: 10;
        }

        .header-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 600;
        }

        .header-logo img {
            width: 32px;
            height: 32px;
            border-radius: 50%;
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .header-user {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            color: #4b5563;
        }
        
        .header-user img {
            width: 32px;
            height: 32px;
            border-radius: 50%;
        }

        /* Sidebar */
        .sidebar {
            width: 240px;
            background: #fff;
            border-right: 1px solid #e5e7eb;
            padding: 80px 16px 24px; /* padding-top accounts for header */
            display: flex;
            flex-direction: column;
            gap: 24px;
            height: 100%;
        }

        .nav-section {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .nav-section-title {
            font-size: 12px;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            padding-left: 12px;
            margin-bottom: 4px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px 12px;
            border-radius: 6px;
            color: #4b5563;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
        }

        .nav-item:hover {
            background: #f3f4f6;
        }

        .nav-item.active {
            background: #f3f4f6;
            color: #111827;
            font-weight: 600;
        }

        .nav-item i {
            font-size: 16px;
            width: 20px;
            text-align: center;
            color: #6b7280;
        }

        /* Main Content */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            height: 100%;
            padding-top: 64px; /* accounts for header */
        }

        .page-header {
            padding: 24px 32px;
            background: #fff;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
        }

        .page-title h1 {
            font-size: 24px;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .page-title p {
            font-size: 14px;
            color: #6b7280;
        }

        .page-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .btn {
            padding: 8px 16px;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            border: 1px solid #d1d5db;
            background: #fff;
            color: #374151;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn:hover {
            background: #f9fafb;
        }

        .content-area {
            flex: 1;
            display: flex;
            overflow: hidden;
        }

        /* Icon Sidebar (next to list) */
        .icon-sidebar {
            width: 48px;
            background: #fff;
            border-right: 1px solid #e5e7eb;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 16px 0;
            gap: 16px;
        }

        .icon-sidebar-btn {
            width: 32px;
            height: 32px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #6b7280;
            cursor: pointer;
        }

        .icon-sidebar-btn:hover {
            background: #f3f4f6;
            color: #111827;
        }

        .icon-sidebar-btn.active {
            background: #e5e7eb;
            color: #111827;
        }

        /* List View */
        .list-view {
            width: 320px;
            background: #fff;
            border-right: 1px solid #e5e7eb;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .list-header {
            padding: 16px;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .search-bar {
            position: relative;
            display: flex;
            align-items: center;
        }

        .search-bar i {
            position: absolute;
            left: 12px;
            color: #9ca3af;
        }

        .search-bar input {
            width: 100%;
            padding: 8px 12px 8px 36px;
            border: 1px solid #d1d5db;
            border-radius: 6px;
            font-size: 14px;
            outline: none;
        }

        .tabs {
            display: flex;
            gap: 16px;
            border-bottom: 1px solid #e5e7eb;
            padding: 0 16px;
        }

        .tab {
            padding: 12px 0;
            font-size: 14px;
            font-weight: 500;
            color: #6b7280;
            cursor: pointer;
            position: relative;
        }

        .tab.active {
            color: #111827;
        }

        .tab.active::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            right: 0;
            height: 2px;
            background: #111827;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 2px 6px;
            border-radius: 9999px;
            font-size: 12px;
            font-weight: 600;
            background: #f3f4f6;
            color: #4b5563;
            margin-left: 6px;
        }

        .list-content {
            flex: 1;
            overflow-y: auto;
        }

        .list-item {
            padding: 16px;
            border-bottom: 1px solid #e5e7eb;
            cursor: pointer;
            display: flex;
            gap: 12px;
            position: relative;
        }

        .list-item:hover {
            background: #f9fafb;
        }

        .list-item.active {
            background: #f3f4f6;
            border-left: 3px solid #111827;
        }

        .list-item-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: #e5e7eb;
            flex-shrink: 0;
        }

        .list-item-details {
            flex: 1;
            overflow: hidden;
        }

        .list-item-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 4px;
        }

        .list-item-name {
            font-size: 14px;
            font-weight: 600;
            color: #111827;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .list-item-id {
            font-size: 12px;
            color: #6b7280;
        }

        .list-item-preview {
            font-size: 13px;
            color: #4b5563;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            margin-bottom: 8px;
            line-height: 1.4;
        }

        .list-item-meta {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 12px;
            color: #6b7280;
        }

        .status-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #10b981;
            position: absolute;
            top: 16px;
            right: 16px;
        }

        /* Detail View */
        .detail-view {
            flex: 1;
            background: #fff;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
        }

        .detail-toolbar {
            padding: 16px 32px;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            background: rgba(255,255,255,0.9);
            backdrop-filter: blur(8px);
            z-index: 5;
        }

        .detail-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .icon-btn {
            width: 32px;
            height: 32px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #4b5563;
            cursor: pointer;
            border: 1px solid transparent;
        }

        .icon-btn:hover {
            background: #f3f4f6;
            border-color: #d1d5db;
        }

        .detail-body {
            padding: 32px;
            max-width: 800px;
            margin: 0 auto;
            width: 100%;
        }

        .email-meta {
            margin-bottom: 32px;
            padding-bottom: 24px;
            border-bottom: 1px solid #e5e7eb;
        }

        .email-sender {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            margin-bottom: 8px;
        }

        .email-sender-label {
            color: #6b7280;
        }

        .email-sender-value {
            font-weight: 500;
            color: #111827;
            background: #f3f4f6;
            padding: 2px 8px;
            border-radius: 4px;
        }

        .email-id, .email-date {
            font-size: 13px;
            color: #6b7280;
            margin-bottom: 4px;
        }

        .email-subject {
            font-size: 24px;
            font-weight: 700;
            color: #111827;
            margin-top: 16px;
            line-height: 1.3;
        }

        .email-content {
            font-size: 15px;
            line-height: 1.6;
            color: #374151;
            margin-bottom: 40px;
        }

        .email-content img {
            max-width: 100%;
            height: auto;
        }

        .action-buttons {
            display: flex;
            gap: 12px;
            margin-top: 32px;
            padding-top: 24px;
            border-top: 1px solid #e5e7eb;
        }

        .reply-box {
            margin-top: 24px;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 16px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .reply-input {
            width: 100%;
            border: none;
            outline: none;
            resize: none;
            font-size: 14px;
            min-height: 60px;
        }

        .reply-actions {
            display: flex;
            justify-content: flex-end;
        }

        .btn-black {
            background: #111827;
            color: #fff;
            border: none;
        }

        .btn-black:hover {
            background: #374151;
        }
        
        .header-bg-wave {
            position: absolute;
            top: 0;
            right: 200px;
            height: 64px;
            width: 400px;
            opacity: 0.1;
            background-image: url('data:image/svg+xml;utf8,<svg viewBox="0 0 100 20" xmlns="http://www.w3.org/2000/svg"><path d="M0,10 Q10,0 20,10 T40,10 T60,10 T80,10 T100,10" fill="none" stroke="black" stroke-width="0.5"/></svg>');
            background-size: cover;
        }

    </style>
</head>
<body>

    <!-- Header -->
    <header class="header">
        <div class="header-logo">
            <div style="width: 32px; height: 32px; background: #111827; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff;">
                <i class="fa-solid fa-shield-halved" style="font-size: 14px;"></i>
            </div>
            {{ 'admin_email.preview.enterprise'|trans }}
        </div>
        <div class="header-bg-wave"></div>
        <div class="header-actions">
            <span style="font-size: 12px; font-weight: 600; color: #6b7280; letter-spacing: 1px;">{{ 'admin_email.preview.admin'|trans }}</span>
            <div class="icon-btn" style="border:none;">
                <i class="fa-regular fa-circle-question"></i>
            </div>
            <div class="header-user">
                <div style="width: 32px; height: 32px; border-radius: 50%; background: #6b7280; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 14px;">A</div>
            </div>
        </div>
    </header>

    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="nav-section">
            <a href="#" class="nav-item">
                <i class="fa-solid fa-chart-pie"></i>
                {{ 'admin_email.preview.menu.dashboard'|trans }}
            </a>
            <a href="#" class="nav-item">
                <i class="fa-solid fa-house"></i>
                {{ 'admin_email.preview.menu.control_panel'|trans }}
            </a>
        </div>

        <div class="nav-section">
            <div class="nav-section-title">{{ 'admin_email.preview.menu.management'|trans }}</div>
            <a href="#" class="nav-item">
                <i class="fa-regular fa-folder"></i>
                {{ 'admin_email.preview.menu.employees'|trans }}
            </a>
            <a href="#" class="nav-item">
                <i class="fa-regular fa-folder"></i>
                {{ 'admin_email.preview.menu.clients'|trans }}
            </a>
            <a href="#" class="nav-item active">
                <i class="fa-regular fa-file-lines"></i>
                {{ 'admin_email.preview.menu.reports'|trans }}
            </a>
            <a href="#" class="nav-item">
                <i class="fa-solid fa-scale-balanced"></i>
                {{ 'admin_email.preview.menu.trials'|trans }}
            </a>
        </div>

        <div style="flex: 1;"></div>

        <div class="nav-section">
            <div class="nav-section-title">{{ 'admin_email.preview.menu.tools'|trans }}</div>
            <a href="#" class="nav-item">
                <i class="fa-solid fa-plug"></i>
                {{ 'admin_email.preview.menu.integrations'|trans }}
            </a>
            <a href="#" class="nav-item">
                <i class="fa-solid fa-layer-group"></i>
                {{ 'admin_email.preview.menu.resources'|trans }}
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <div class="page-header">
            <div class="page-title">
                <h1>{{ 'admin_email.preview.page_title.reports'|trans }}</h1>
                <p>{{ 'admin_email.preview.page_desc.reports'|trans }}</p>
            </div>
            <div class="page-actions">
                <button class="btn">
                    <i class="fa-solid fa-sliders"></i>
                    {{ 'admin_email.preview.action.display'|trans }}
                </button>
            </div>
        </div>

        <div class="content-area">
            <!-- Icon Sidebar -->
            <div class="icon-sidebar">
                <div class="icon-sidebar-btn active">
                    <i class="fa-regular fa-paper-plane"></i>
                </div>
                <div class="icon-sidebar-btn">
                    <i class="fa-solid fa-thumbtack"></i>
                </div>
                <div class="icon-sidebar-btn">
                    <i class="fa-solid fa-download"></i>
                </div>
                <div class="icon-sidebar-btn">
                    <i class="fa-regular fa-trash-can"></i>
                </div>
            </div>

            <!-- List View -->
            <div class="list-view">
                <div class="list-header">
                    <div class="search-bar">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="text" placeholder="{{ 'admin_email.preview.search.placeholder'|trans }}">
                        <button class="btn" style="position: absolute; right: 4px; padding: 4px 8px; border: none; font-size: 12px; height: 26px;">{{ 'admin_email.preview.action.filter'|trans }} <i class="fa-solid fa-chevron-down" style="position: static; margin-left: 4px;"></i></button>
                    </div>
                </div>
                
                <div class="tabs">
                    <div class="tab active">{{ 'admin_email.preview.tab.pending'|trans }} <span class="badge">84</span></div>
                    <div class="tab">{{ 'admin_email.preview.tab.reviewed'|trans }} <span class="badge">14</span></div>
                </div>

                <div class="list-content">
                    <div class="list-item">
                        <div class="list-item-avatar" style="background: #fcd34d; color: #b45309; display: flex; align-items: center; justify-content: center; font-weight: 600;">G</div>
                        <div class="list-item-details">
                            <div class="list-item-header">
                                <div class="list-item-name">Grace Foster <span class="list-item-id">(4394)</span></div>
                            </div>
                            <div class="list-item-preview">
                                {{ 'admin_email.preview.mock.desc1'|trans }}
                            </div>
                            <div class="list-item-meta">
                                <span style="color: #d97706; background: #fef3c7; padding: 2px 6px; border-radius: 4px; font-size: 10px; font-weight: 600;">{{ 'admin_email.preview.status.in_review'|trans }}</span>
                                <span>{{ 'admin_email.preview.time.days_3'|trans }}</span>
                                <i class="fa-regular fa-image"></i>
                                <i class="fa-solid fa-paperclip"></i>
                            </div>
                        </div>
                        <div class="status-dot"></div>
                    </div>

                    <div class="list-item">
                        <div class="list-item-avatar" style="background: #fbcfe8; color: #b45309; display: flex; align-items: center; justify-content: center; font-weight: 600;">Z</div>
                        <div class="list-item-details">
                            <div class="list-item-header">
                                <div class="list-item-name">Zoe Carter <span class="list-item-id">(4395)</span></div>
                            </div>
                            <div class="list-item-preview">
                                {{ 'admin_email.preview.mock.desc2'|trans }}
                            </div>
                            <div class="list-item-meta">
                                <span>{{ 'admin_email.preview.time.days_2'|trans }}</span>
                                <i class="fa-regular fa-image"></i>
                                <i class="fa-solid fa-paperclip"></i>
                            </div>
                        </div>
                        <div class="status-dot"></div>
                    </div>

                    <div class="list-item active">
                        <div class="list-item-avatar" style="background: #bfdbfe; color: #be185d; display: flex; align-items: center; justify-content: center; font-weight: 600;">L</div>
                        <div class="list-item-details">
                            <div class="list-item-header">
                                <div class="list-item-name">Liam Heyes <span class="list-item-id">(4396)</span></div>
                                <div style="display: flex; gap: 4px; color: #6b7280; font-size: 12px;">
                                    <i class="fa-regular fa-trash-can" style="padding: 4px; border: 1px solid #e5e7eb; border-radius: 4px; background: #fff;"></i>
                                    <i class="fa-regular fa-folder" style="padding: 4px; border: 1px solid #e5e7eb; border-radius: 4px; background: #fff;"></i>
                                    <i class="fa-solid fa-ellipsis" style="padding: 4px; border: 1px solid #e5e7eb; border-radius: 4px; background: #fff;"></i>
                                </div>
                            </div>
                            <div class="list-item-preview">
                                {{ 'admin_email.preview.mock.desc3'|trans }}
                            </div>
                            <div class="list-item-meta">
                                <span>{{ 'admin_email.preview.time.days_5'|trans }}</span>
                                <i class="fa-regular fa-image"></i>
                                <i class="fa-solid fa-paperclip"></i>
                            </div>
                        </div>
                        <div class="status-dot"></div>
                    </div>

                    <div class="list-item">
                        <div class="list-item-avatar" style="background: #bbf7d0; color: #1d4ed8; display: flex; align-items: center; justify-content: center; font-weight: 600;">N</div>
                        <div class="list-item-details">
                            <div class="list-item-header">
                                <div class="list-item-name">Noah Blake <span class="list-item-id">(4397)</span></div>
                            </div>
                            <div class="list-item-preview">
                                {{ 'admin_email.preview.mock.desc4'|trans }}
                            </div>
                            <div class="list-item-meta">
                                <span>{{ 'admin_email.preview.time.week_1'|trans }}</span>
                            </div>
                        </div>
                        <div class="status-dot"></div>
                    </div>
                </div>
            </div>

            <!-- Detail View -->
            <div class="detail-view">
                <div class="detail-toolbar">
                    <div class="detail-actions">
                        <button class="icon-btn"><i class="fa-solid fa-arrow-left"></i></button>
                        <button class="icon-btn"><i class="fa-solid fa-arrow-right"></i></button>
                    </div>
                    <div class="detail-actions">
                        <button class="icon-btn"><i class="fa-solid fa-download"></i></button>
                        <button class="icon-btn"><i class="fa-solid fa-bell-slash"></i></button>
                        <button class="icon-btn"><i class="fa-regular fa-trash-can"></i></button>
                    </div>
                </div>

                <div class="detail-body">
                    <div class="email-meta">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                            <div>
                                <div class="email-sender">
                                    <span class="email-sender-label">{{ 'admin_email.preview.email.from'|trans }}</span>
                                    <span class="email-sender-value">liamheyes@gmail.com</span>
                                </div>
                                <div class="email-id">{{ 'admin_email.preview.email.report_id'|trans }} 4396</div>
                                <div class="email-date">{{ 'admin_email.preview.email.date'|trans }} {{ "now"|date("d/m/Y") }}</div>
                            </div>
                            <div>
                                <button class="btn" style="padding: 4px 12px; font-size: 13px;">{{ 'admin_email.preview.email.status'|trans }} <i class="fa-solid fa-chevron-down" style="margin-left: 4px; font-size: 10px;"></i></button>
                            </div>
                        </div>
                        <h2 class="email-subject">{{ subject|default('Concerns Regarding Local Construction Project Operating Outside Allowed Hours') }}</h2>
                    </div>

                    <div class="email-content">
                        {{ html|raw }}
                    </div>

                    <div class="action-buttons">
                        <button class="btn"><i class="fa-regular fa-circle-check"></i> {{ 'admin_email.preview.action.accept'|trans }}</button>
                        <button class="btn"><i class="fa-solid fa-xmark"></i> {{ 'admin_email.preview.action.decline'|trans }}</button>
                    </div>

                    <div class="reply-box">
                        <textarea class="reply-input" placeholder="{{ 'admin_email.preview.input.write_message'|trans }}"></textarea>
                        <div class="reply-actions">
                            <button class="btn btn-black"><i class="fa-regular fa-paper-plane" style="margin-right: 6px;"></i> {{ 'admin_email.preview.action.send_message'|trans }}</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

</body>
</html>