{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'admin_email.title'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="/lib/wangeditor/style.css" rel="stylesheet">
    <style>
        .w-e-text-container {
            z-index: 100 !important;
        }
        .w-e-toolbar {
            z-index: 101 !important;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .w-e-menu-panel {
            z-index: 10000 !important;
            min-width: 360px;
            max-width: 70vw;
        }
        .w-e-toolbar [data-menu-key="insertVariable"] {
            margin-left: auto;
            max-width: 140px;
            display: inline-flex;
            align-items: center;
            justify-content: flex-end;
        }
        .email-page {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            color: #1d1d1f;
        }
        .email-title {
            font-size: 28px;
            font-weight: 600;
            margin-bottom: 24px;
        }
        .email-tabs {
            display: flex;
            border-bottom: 1px solid #e5e5ea;
            margin-bottom: 32px;
        }
        .email-tab {
            padding: 12px 0;
            margin-right: 32px;
            font-size: 15px;
            font-weight: 500;
            color: #86868b;
            cursor: pointer;
        }
        .email-tab.active {
            color: #0066cc;
            border-bottom: 2px solid #0066cc;
        }
        .config-form, .template-list, .binding-list {
            display: none;
        }
        .config-form.active, .template-list.active, .binding-list.active {
            display: block;
        }
        
        .form-group {
            margin-bottom: 20px;
        }
        .form-label {
            display: block;
            font-size: 14px;
            font-weight: 500;
            color: #374151;
            margin-bottom: 8px;
        }
        
        .method-list {
            border-top: 1px solid #e5e5ea;
        }
        .method-item {
            display: flex;
            align-items: center;
            padding: 24px 0;
            border-bottom: 1px solid #e5e5ea;
            background: #fff;
        }
        .method-icon {
            font-size: 24px;
            width: 48px;
            color: #1d1d1f;
            display: flex;
            align-items: center;
        }
        .method-content {
            flex: 1;
        }
        .method-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 4px;
        }
        .method-subtitle {
            font-size: 12px;
            color: #86868b;
        }
        .method-actions {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        /* Drawer Settings Form Styles (Notion/Linear style) */
        .settings-drawer-form {
            padding: 24px;
            background: #f8fafc;
            min-height: 100%;
        }
        .settings-group {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 24px;
            box-shadow: 0 1px 2px rgba(0,0,0,0.02);
        }
        .settings-group-title {
            font-size: 12px;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
            margin-bottom: 16px;
            letter-spacing: 0.5px;
        }
        .settings-drawer-form .form-group {
            margin-bottom: 16px;
        }
        .settings-drawer-form .form-group:last-child {
            margin-bottom: 0;
        }
        .settings-drawer-form .form-label {
            display: block;
            font-size: 13px;
            font-weight: 500;
            color: #374151;
            margin-bottom: 6px;
        }
        .settings-drawer-form .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }
        .settings-drawer-form .checkbox-wrapper {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .settings-drawer-form .checkbox-wrapper input[type="checkbox"] {
            width: 16px;
            height: 16px;
            border: 1px solid #d1d5db;
            border-radius: 4px;
            accent-color: #0066cc;
            cursor: pointer;
            margin: 0;
        }
        .settings-drawer-form .checkbox-wrapper label {
            font-size: 14px;
            color: #374151;
            cursor: pointer;
            user-select: none;
            margin: 0;
        }
    </style>
{% endblock %}

{% import 'ui/template/ui.html.twig' as ui %}

{% block app_content_container %}
<div class="org-structure-container email-page">
    <div class="outside-wrapper" style="padding: 40px; max-width: 1200px; margin: 0; background: #fff; min-height: calc(100vh - 60px);">
        
        <div class="email-title">{{ 'admin_email.title'|trans }}</div>
        
        <div class="email-tabs">
            <div class="email-tab active" onclick="switchTab('config', this)">{{ 'admin_email.tabs.config'|trans }}</div>
            <div class="email-tab" onclick="switchTab('templates', this)">{{ 'admin_email.tabs.templates'|trans }}</div>
            <div class="email-tab" onclick="switchTab('bindings', this)">{{ 'admin_email.tabs.bindings'|trans }}</div>
        </div>

        <div class="ef-row ef-row-align-start ef-row-justify-start">
            <div class="ef-col-16" style="padding-right: 60px;">
                
                {% for message in app.flashes('success') %}
                    <div role="alert" class="ef-alert ef-alert-success" style="margin-bottom: 32px; border-radius: 12px; padding: 20px;">
                        <div class="ef-alert-icon"><i class="fa-solid fa-circle-check"></i></div>
                        <div class="ef-alert-body">
                            <div class="ef-alert-content">{{ message }}</div>
                        </div>
                    </div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div role="alert" class="ef-alert ef-alert-error" style="margin-bottom: 32px; border-radius: 12px; padding: 20px; background-color: #fef2f2; color: #991b1b;">
                        <div class="ef-alert-icon" style="color: #dc2626;"><i class="fa-solid fa-circle-exclamation"></i></div>
                        <div class="ef-alert-body">
                            <div class="ef-alert-content">{{ message }}</div>
                        </div>
                    </div>
                {% endfor %}

                <!-- Config Form -->
                <div id="config-section" class="config-form active">
                    <div class="ef-row ef-row-align-center ef-row-justify-between" style="margin-bottom: 16px;">
                        <div>
                            <div style="font-size: 18px; font-weight: 600; margin-bottom: 4px;">{{ 'admin_email.config.title'|trans }}</div>
                            <div style="font-size: 14px; color: #86868b;">{{ 'admin_email.config.desc'|trans }}</div>
                        </div>
                        <div>
                            <button class="btn primary medium" style="border-radius: 20px;" onclick="openConfigDrawerWithData()">{{ 'admin_email.config.add_server'|trans }}</button>
                        </div>
                    </div>

                    <div class="method-list">
                        {% for config in configs %}
                        <div class="method-item">
                            <div class="method-icon">
                                <i class="fa-solid fa-server"></i>
                            </div>
                            <div class="method-content">
                                <div class="method-title">
                                    {{ config.name ?: ('admin_email.config.unnamed'|trans) }}
                                    {% if config.isDefault %}
                                        <span style="font-size: 12px; background: #e5f0ff; color: #0066cc; padding: 2px 6px; border-radius: 4px; margin-left: 8px;">{{ 'admin_email.config.default'|trans }}</span>
                                    {% endif %}
                                </div>
                                <div class="method-subtitle">主机: {{ config.host }}:{{ config.port }} ({{ config.protocol|upper }}) | 发件人: {{ config.senderAddress }}</div>
                            </div>
                            <div class="method-actions">
                                <button class="btn secondary medium only-icon circle" style="border:none; background:transparent; box-shadow:none; color: #1d1d1f; font-size: 18px;" onclick="openConfigDrawerWithData('{{ config.id }}', '{{ config.name|e('js') }}', '{{ config.isDefault ? 1 : 0 }}', '{{ config.protocol|e('js') }}', '{{ config.host|e('js') }}', '{{ config.port }}', '{{ config.encryption|e('js') }}', '{{ config.username|e('js') }}', '{{ config.senderName|e('js') }}', '{{ config.senderAddress|e('js') }}')">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </button>
                                <form action="{{ path('admin_email_config_delete', {id: config.id}) }}" method="post" style="display:inline;" onsubmit="return confirm('{{ 'admin_email.config.delete_confirm'|trans }}');">
                                    <button type="submit" class="btn secondary medium only-icon circle" style="border:none; background:transparent; box-shadow:none; color: #dc3545; font-size: 18px;">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                        {% else %}
                        <div style="padding: 40px 0; text-align: center; color: #86868b;">
                            {{ 'admin_email.config.empty'|trans }}
                        </div>
                        {% endfor %}
                    </div>
                </div>

                <!-- Templates List -->
                <div id="templates-section" class="template-list">
                    <div class="ef-row ef-row-align-center ef-row-justify-between" style="margin-bottom: 16px;">
                        <div>
                            <div style="font-size: 18px; font-weight: 600; margin-bottom: 4px;">{{ 'admin_email.templates.title'|trans }}</div>
                            <div style="font-size: 14px; color: #86868b;">{{ 'admin_email.templates.desc'|trans }}</div>
                        </div>
                        <div>
                            <button class="btn primary medium" style="border-radius: 20px;" onclick="window.open('{{ path('admin_email_template_editor') }}', '_blank')">{{ 'admin_email.editor.open_full'|trans }}</button>
                        </div>
                    </div>

                    <div class="method-list">
                        {% for template in templates %}
                        <div class="method-item">
                            <div class="method-icon">
                                <i class="fa-regular fa-file-code"></i>
                            </div>
                            <div class="method-content">
                                <div class="method-title">{{ template.name }} ({{ template.code }})</div>
                                <div class="method-subtitle">主题: {{ template.subject }}</div>
                            </div>
                            <div class="method-actions">
                                <button class="btn secondary medium only-icon circle" style="border:none; background:transparent; box-shadow:none; color: #1d1d1f; font-size: 18px;" onclick="openTemplateDrawerWithData('{{ template.id }}', '{{ template.name|e('js') }}', '{{ template.subject|e('js') }}', '{{ template.description|e('js') }}', '{{ template.bodyHtml|e('js')|replace({"\n": "\\n", "\r": "\\r"}) }}', '{{ template.emailConfig ? template.emailConfig.id : '' }}')">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </button>
                                <form action="{{ path('admin_email_template_delete', {id: template.id}) }}" method="post" style="display:inline;" onsubmit="return confirm('{{ 'admin_email.templates.delete_confirm'|trans }}');">
                                    <button type="submit" class="btn secondary medium only-icon circle" style="border:none; background:transparent; box-shadow:none; color: #dc3545; font-size: 18px;">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                        {% else %}
                        <div style="padding: 40px 0; text-align: center; color: #86868b;">
                            {{ 'admin_email.templates.empty'|trans }}
                        </div>
                        {% endfor %}
                    </div>
                </div>

                <!-- Bindings List -->
                <div id="bindings-section" class="binding-list">
                    <div class="ef-row ef-row-align-center ef-row-justify-between" style="margin-bottom: 16px;">
                        <div>
                            <div style="font-size: 18px; font-weight: 600; margin-bottom: 4px;">{{ 'admin_email.bindings.title'|trans }}</div>
                            <div style="font-size: 14px; color: #86868b;">{{ 'admin_email.bindings.desc'|trans }}</div>
                        </div>
                    </div>

                    <div class="method-list">
                        {% for binding in bindings %}
                        <div class="method-item" style="padding-bottom: 24px; padding-top: 24px; display: block;">
                            <form action="{{ path('admin_email_binding_save') }}" method="post" style="display: flex; align-items: center; width: 100%;">
                                <input type="hidden" name="id" value="{{ binding.id }}">
                                
                                <div class="method-icon">
                                    <i class="fa-solid fa-link"></i>
                                </div>
                                <div class="method-content" style="flex: 1; padding-right: 20px;">
                                    <div class="method-title">{{ ('function_binding.' ~ binding.functionCode)|trans }}</div>
                                    <div class="method-subtitle">{{ 'function_binding.function_code'|trans }}: <code>{{ binding.functionCode }}</code></div>
                                </div>
                                
                                <div class="binding-selectors" style="display: flex; gap: 16px; align-items: center;">
                                    <div style="min-width: 200px;">
                                        <div style="font-size:12px; color:#86868b; margin-bottom: 4px;">{{ 'function_binding.server'|trans }}</div>
                                        <select name="emailConfigId" class="ef-input-wrapper-full-width ef-input-rounded" style="padding: 8px 12px; outline: none; border: 1px solid #d1d5db; border-radius: 6px; background-color: white;">
                                            <option value="">-- {{ 'function_binding.system_default'|trans }} --</option>
                                            {% for config in configs %}
                                                <option value="{{ config.id }}" {% if binding.emailConfig and binding.emailConfig.id == config.id %}selected{% endif %}>{{ config.name }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                    
                                    <div style="min-width: 200px;">
                                        <div style="font-size:12px; color:#86868b; margin-bottom: 4px;">{{ 'function_binding.template'|trans }}</div>
                                        <select name="emailTemplateId" class="ef-input-wrapper-full-width ef-input-rounded" style="padding: 8px 12px; outline: none; border: 1px solid #d1d5db; border-radius: 6px; background-color: white;" required>
                                            <option value="">-- {{ 'function_binding.select_template'|trans }} --</option>
                                            {% for template in templates %}
                                                <option value="{{ template.id }}" {% if binding.emailTemplate and binding.emailTemplate.id == template.id %}selected{% endif %}>{{ template.name }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                    
                                    <div style="padding-top: 20px;">
                                        <button type="submit" class="btn primary small" style="border-radius: 6px;">{{ 'function_binding.save_binding'|trans }}</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                        {% else %}
                        <div style="padding: 40px 0; text-align: center; color: #86868b;">
                            {{ 'admin_email.bindings.empty'|trans }}
                        </div>
                        {% endfor %}
                    </div>
                </div>

            </div>
            
            <div class="ef-col-8">
                <div class="side-card" style="background: #f5f5f7; border-radius: 16px; padding: 24px; margin-bottom: 16px;">
                    <div class="side-card-title" style="font-size: 16px; font-weight: 600; margin-bottom: 8px;">{{ 'admin_email.side_card.config.title'|trans }}</div>
                    <div class="side-card-text" style="font-size: 14px; color: #555; margin-bottom: 16px; line-height: 1.5;">
                        {{ 'admin_email.side_card.config.text'|trans|raw }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Config Drawer -->
<div class="ef-drawer-container" id="configDrawer" style="z-index: 1001; display: none;">
    <div class="ef-drawer-mask" maskid="configDrawer"></div>
    <div class="ef-drawer" style="right: -600px; width: 600px;">
        <div class="ef-drawer-header">
            <div class="ef-drawer-title" id="configDrawerTitle">{{ 'admin_email.drawer.add_title'|trans }}</div>
            <div tabindex="-1" role="button" aria-label="Close" class="ef-drawer-close-btn" onclick="$().hideDrawer('configDrawer')">
                <span class="ef-icon-hover">
                    <svg viewbox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" class="ef-icon ef-icon-close" stroke-width="4" stroke-linecap="butt" stroke-linejoin="miter">
                        <path d="M9.857 9.858 24 24m0 0 14.142 14.142M24 24 38.142 9.858M24 24 9.857 38.142"></path>
                    </svg>
                </span>
            </div>
        </div>
        <div class="ef-drawer-body" style="overflow-y: auto; background: #f8fafc;">
            <form action="{{ path('admin_email_config_save') }}" method="post" id="configForm" class="settings-drawer-form">
                <input type="hidden" name="id" id="configId">
                
                <div class="settings-group">
                    <div class="settings-group-title">{{ 'admin_email.drawer.basic_info'|trans }}</div>
                    <div class="form-group">
                        <label class="form-label">{{ 'admin_email.drawer.name'|trans }}</label>
                        {{ ui.input('configName', 'text', 'admin_email.drawer.name_placeholder'|trans, '', 'ef-input-wrapper-full-width ef-input-rounded', 'ef-input-size-medium', {'name': 'name', 'style': 'width: 100%;'}) }}
                    </div>
                    <div class="form-group" style="margin-top: 16px;">
                        <input type="hidden" name="isDefault" value="0">
                        {{ ui.checkbox('configIsDefault', 'admin_email.drawer.is_default'|trans, '1', false, '', 'isDefault') }}
                    </div>
                </div>

                <div class="settings-group">
                    <div class="settings-group-title">{{ 'admin_email.drawer.conn_settings'|trans }}</div>
                    <div class="grid-2">
                        <div class="form-group">
                            <label class="form-label">{{ 'admin_email.drawer.host'|trans }} *</label>
                            {{ ui.input('configHost', 'text', 'admin_email.drawer.host_placeholder'|trans, '', 'ef-input-wrapper-full-width ef-input-rounded', 'ef-input-size-medium', {'name': 'host', 'required': 'required', 'style': 'width: 100%;'}) }}
                        </div>
                        <div class="form-group">
                            <label class="form-label">{{ 'admin_email.drawer.port'|trans }} *</label>
                            {{ ui.inputNumber('configPort', null, null, 1, 0, '', 'ef-input-wrapper-full-width ef-input-rounded', 'port', '465', {'required': 'required', 'style': 'width: 100%;'}) }}
                        </div>
                        <div class="form-group">
                            <label class="form-label">{{ 'admin_email.drawer.protocol'|trans }} *</label>
                            {% set protocol_options = [
                                {'label': 'SMTP', 'value': 'smtp'},
                                {'label': 'Sendgrid', 'value': 'sendgrid'},
                                {'label': 'Mailgun', 'value': 'mailgun'},
                                {'label': 'Aliyun', 'value': 'aliyun'}
                            ] %}
                            {{ ui.select(protocol_options, 'admin_email.drawer.protocol_select'|trans, '120px', 'ef-input-rounded', 'protocol', 'configProtocol', 'smtp') }}
                        </div>
                        <div class="form-group">
                            <label class="form-label">{{ 'admin_email.drawer.encryption'|trans }}</label>
                            {% set encryption_options = [
                                {'label': 'None', 'value': ''},
                                {'label': 'SSL', 'value': 'ssl'},
                                {'label': 'TLS', 'value': 'tls'}
                            ] %}
                            {{ ui.select(encryption_options, 'admin_email.drawer.encryption_select'|trans, '120px', 'ef-input-rounded', 'encryption', 'configEncryption', 'ssl') }}
                        </div>
                    </div>
                </div>

                <div class="settings-group">
                    <div class="settings-group-title">{{ 'admin_email.drawer.auth'|trans }}</div>
                    <div class="grid-2">
                        <div class="form-group">
                            <label class="form-label">{{ 'admin_email.drawer.username'|trans }}</label>
                            {{ ui.input('configUsername', 'text', 'admin_email.drawer.username_placeholder'|trans, '', 'ef-input-wrapper-full-width ef-input-rounded', 'ef-input-size-medium', {'name': 'username', 'style': 'width: 100%;'}) }}
                        </div>
                        <div class="form-group">
                            <label class="form-label">{{ 'admin_email.drawer.password'|trans }}</label>
                            {{ ui.input('configPassword', 'password', 'admin_email.drawer.password_hint'|trans, '', 'ef-input-wrapper-full-width ef-input-rounded', 'ef-input-size-medium', {'name': 'password', 'style': 'width: 100%;'}) }}
                        </div>
                    </div>
                </div>

                <div class="settings-group">
                    <div class="settings-group-title">{{ 'admin_email.drawer.sender_info'|trans }}</div>
                    <div class="grid-2">
                        <div class="form-group">
                            <label class="form-label">{{ 'admin_email.drawer.sender_name'|trans }}</label>
                            {{ ui.input('configSenderName', 'text', 'admin_email.drawer.sender_name_placeholder'|trans, '', 'ef-input-wrapper-full-width ef-input-rounded', 'ef-input-size-medium', {'name': 'senderName', 'style': 'width: 100%;'}) }}
                        </div>
                        <div class="form-group">
                            <label class="form-label">{{ 'admin_email.drawer.sender_address'|trans }} *</label>
                            {{ ui.input('configSenderAddress', 'text', 'admin_email.drawer.sender_address_placeholder'|trans, '', 'ef-input-wrapper-full-width ef-input-rounded', 'ef-input-size-medium', {'name': 'senderAddress', 'required': 'required', 'style': 'width: 100%;'}) }}
                        </div>
                    </div>
                </div>
            </form>
        </div>
        <div class="ef-drawer-footer">
            <button class="btn outline medium" type="button" onclick="testConnection()" id="testConnectionBtn">{{ 'admin_email.drawer.test_conn'|trans }}</button>
            <button class="cancelDrawer btn outline medium" type="button" onclick="$().hideDrawer('configDrawer')">{{ 'action.cancel'|trans }}</button>
            <button type="submit" form="configForm" class="btn primary medium">{{ 'action.save'|trans }}</button>
        </div>
    </div>
</div>

<!-- Template Drawer -->
<div class="ef-drawer-container" id="templateDrawer" style="z-index: 1001; display: none;">
    <div class="ef-drawer-mask" maskid="templateDrawer"></div>
    <div class="ef-drawer" style="right: -80% !important; width: 80% !important;">
        <div class="ef-drawer-header">
            <div class="ef-drawer-title" id="templateDrawerTitle">{{ 'admin_email.drawer.add_template'|trans }}</div>
            <div tabindex="-1" role="button" aria-label="Close" class="ef-drawer-close-btn" onclick="$().hideDrawer('templateDrawer')">
                <span class="ef-icon-hover">
                    <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" class="ef-icon ef-icon-close" stroke-width="4" stroke-linecap="butt" stroke-linejoin="miter">
                        <path d="M9.857 9.858 24 24m0 0 14.142 14.142M24 24 38.142 9.858M24 24 9.857 38.142"></path>
                    </svg>
                </span>
            </div>
        </div>
        <div class="ef-drawer-body" style="overflow-y: auto; background: #f8fafc; padding: 0;">
            <form action="{{ path('admin_email_template_save') }}" method="post" id="templateForm" class="settings-drawer-form" style="padding: 24px;">
                <input type="hidden" name="id" id="templateId">
                <input type="hidden" name="bodyHtml" id="templateBody">
                <input type="hidden" name="description" id="templateDescription">
                
                <div class="ef-row" style="gap: 24px; margin-bottom: 24px;">
                    <div class="ef-col-16">
                        <div class="settings-group" style="padding: 0; margin: 0; background: transparent; border: none;">
                            <div class="grid-2">
                                <div class="form-group">
                                    <label class="form-label">{{ 'admin_email.form.name'|trans }}</label>
                                    {{ ui.input('templateName', 'text', 'admin_email.form.name_placeholder'|trans, '', 'ef-input-wrapper-full-width ef-input-rounded', 'ef-input-size-medium', {'name': 'name', 'required': 'required', 'style': 'width: 100%;'}) }}
                                </div>
                                <div class="form-group">
                                    <label class="form-label">{{ 'admin_email.form.subject'|trans }}</label>
                                    {{ ui.input('templateSubject', 'text', 'admin_email.form.subject_placeholder'|trans, '', 'ef-input-wrapper-full-width ef-input-rounded', 'ef-input-size-medium', {'name': 'subject', 'required': 'required', 'style': 'width: 100%;'}) }}
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="ef-col-8">
                        <div class="form-group">
                            <label class="form-label">{{ 'admin_email.form.server'|trans }}</label>
                            {% set server_options = [{'label': 'admin_email.form.default_server'|trans, 'value': ''}] %}
                            {% for config in configs %}
                                {% set server_options = server_options|merge([{'label': config.name, 'value': config.id}]) %}
                            {% endfor %}
                            {{ ui.select(server_options, 'admin_email.form.server_select'|trans, '100%', 'ef-input-rounded', 'emailConfigId', 'templateServer', '') }}
                        </div>
                    </div>
                </div>

                <div class="editor-section" style="background: white; border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden;">
                    <div class="editor-toolbar-wrapper" style="border-bottom: 1px solid #e5e7eb;">
                        <div id="toolbar-container"></div>
                    </div>
                    <div class="editor-content-wrapper" style="height: 500px;">
                        <div id="editor-text-container" style="height: 100%;"></div>
                    </div>
                </div>
                
                <div style="margin-top: 24px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                        <div style="font-size: 14px; font-weight: 600; color: #1d1d1f;">{{ 'admin_email.editor.preset.title'|trans }}</div>
                        <div style="display: flex; gap: 8px;">
                            <select id="presetTemplate" class="ef-input-rounded" style="padding: 4px 8px; font-size: 13px; border: 1px solid #e5e7eb;">
                                <option value="">{{ 'admin_email.templates.preset.select_label'|trans }}</option>
                                <option value="welcome">{{ 'admin_email.templates.preset.option.welcome'|trans }}</option>
                                <option value="verification_code">{{ 'admin_email.templates.preset.option.verification_code'|trans }}</option>
                                <option value="password_reset">{{ 'admin_email.templates.preset.option.password_reset'|trans }}</option>
                                <option value="announcement">{{ 'admin_email.templates.preset.option.announcement'|trans }}</option>
                            </select>
                            <button type="button" class="btn secondary small" onclick="applyPresetTemplate()">{{ 'admin_email.templates.preset.apply'|trans }}</button>
                        </div>
                    </div>
                </div>

                <div style="margin-top: 16px;">
                    <div style="font-size: 14px; font-weight: 600; color: #1d1d1f; margin-bottom: 8px;">变量配置</div>
                    <div id="variablesList" style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 12px;">
                        <!-- Variables will be rendered here -->
                    </div>
                    <div style="display: flex; gap: 8px; align-items: center;">
                        <input type="text" id="newVariableName" placeholder="变量名 (如: username)" class="ef-input-rounded" style="flex: 1; padding: 8px 12px; border: 1px solid #e5e7eb;">
                        <input type="text" id="newVariableDesc" placeholder="描述 (如: 用户姓名)" class="ef-input-rounded" style="flex: 1; padding: 8px 12px; border: 1px solid #e5e7eb;">
                        <button type="button" class="btn outline small" onclick="addVariable()">添加变量</button>
                    </div>
                </div>
            </form>
        </div>
        <div class="ef-drawer-footer">
            <button class="btn outline medium" type="button" onclick="testTemplateEmail()">{{ 'admin_email.btn.send_test'|trans }}</button>
            <button class="cancelDrawer btn outline medium" type="button" onclick="$().hideDrawer('templateDrawer')">{{ 'action.cancel'|trans }}</button>
            <button type="submit" form="templateForm" class="btn primary medium">{{ 'action.save'|trans }}</button>
        </div>
    </div>
</div>


    {# Test Connection Modal #}
    {% set testConnectionBody %}
        <div class="form-group" style="margin-bottom: 0;">
            <label class="form-label required">{{ 'admin_email.drawer.test_email_label'|trans }}</label>
            {{ ui.input('configTestEmailInput', 'email', 'admin_email.drawer.test_email_placeholder'|trans, '', 'ef-input-wrapper-full-width ef-input-rounded', 'ef-input-size-medium', {'required': 'required', 'style': 'width: 100%;'}) }}
        </div>
    {% endset %}

    {% set testConnectionFooter %}
        <div class="ef-space ef-space-horizontal ef-space-align-center" style="justify-content: flex-end; width: 100%;">
            <div class="ef-space-item" style="margin-right: 8px;">
                <button class="btn outline medium" type="button" onclick="closeTestConnectionModal()">{{ 'action.cancel'|trans }}</button>
            </div>
            <div class="ef-space-item">
                <button class="btn primary medium" type="button" onclick="executeTestConnection()" id="confirmTestConnectionBtn">{{ 'admin_email.drawer.test_conn'|trans }}</button>
            </div>
        </div>
    {% endset %}

    {{ ui.modal('testConnectionModal', 'admin_email.drawer.test_modal_title'|trans, testConnectionBody, testConnectionFooter, {
        'width': '500px',
        'onClose': 'closeTestConnectionModal()'
