    {# Test Template Email Modal #}
    {% set testTemplateEmailBody %}
        <div class="form-group" style="margin-bottom: 0;">
            <label class="form-label required">{{ 'admin_email.drawer.test_email_label'|trans }}</label>
            {{ ui.input('templateTestEmailInput', 'email', 'admin_email.drawer.test_email_placeholder'|trans, '', 'ef-input-wrapper-full-width ef-input-rounded', 'ef-input-size-medium', {'required': 'required', 'style': 'width: 100%;'}) }}
        </div>
    {% endset %}

    {% set testTemplateEmailFooter %}
        <div class="ef-space ef-space-horizontal ef-space-align-center" style="justify-content: flex-end; width: 100%;">
            <div class="ef-space-item" style="margin-right: 8px;">
                <button class="btn outline medium" type="button" onclick="closeTestTemplateEmailModal()">{{ 'action.cancel'|trans }}</button>
            </div>
            <div class="ef-space-item">
                <button class="btn primary medium" type="button" onclick="executeTestTemplateEmail()" id="confirmTestTemplateEmailBtn">{{ 'admin_email.btn.send_test'|trans }}</button>
            </div>
        </div>
    {% endset %}

    {{ ui.modal('testTemplateEmailModal', 'admin_email.btn.send_test'|trans, testTemplateEmailBody, testTemplateEmailFooter, {
        'width': '500px',
        'onClose': 'closeTestTemplateEmailModal()'
    }) }}
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="/lib/wangeditor/index.js"></script>
    <script>
        let editor;

        class InsertVariableMenu {
            constructor() {
                this.title = '插入变量';
                this.iconSvg = '<svg viewBox="0 0 1024 1024" xmlns="http://www.w3.org/2000/svg"><path d="M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64zm0 820c-205.4 0-372-166.6-372-372s166.6-372 372-372 372 166.6 372 372-166.6 372-372 372z"/><path d="M686.7 348.7c-3.1-3.1-8.2-3.1-11.3 0L512 512.1l-163.4-163.4c-3.1-3.1-8.2-3.1-11.3 0l-42.4 42.4c-3.1 3.1-3.1 8.2 0 11.3L458.3 565.8c3.1 3.1 8.2 3.1 11.3 0L686.7 402.4c3.1-3.1 3.1-8.2 0-11.3l-42.4-42.4z"/></svg>';
                this.tag = 'select';
                this.width = 140;
            }
            getOptions(editor) {
                if (typeof templateVariables === 'undefined' || templateVariables.length === 0) {
                    return [{ value: '', text: '暂无变量' }];
                }
                return templateVariables.map(v => ({
                    value: v.name,
                    text: v.name + (v.desc ? ` (${v.desc})` : '')
                }));
            }
            isActive(editor) { return false; }
            isDisabled(editor) { return false; }
            exec(editor, value) {
                if (value) {
                    insertVariableIntoEditor(value);
                }
            }
            getValue(editor) { return ''; }
        }

        $(document).ready(function() {
            const { createEditor, createToolbar, Boot } = window.wangEditor;

            try {
                Boot.registerMenu({
                    key: 'insertVariable',
                    factory() {
                        return new InsertVariableMenu();
                    }
                });
            } catch (e) {
                console.warn('Register menu error:', e);
            }

            editor = createEditor({
                selector: '#editor-text-container',
                html: '',
                config: {
                    placeholder: '请输入内容...',
                    onChange(editor) {
                        document.getElementById('templateBody').value = editor.getHtml();
                    }
                }
            });

            const toolbar = createToolbar({
                editor,
                selector: '#toolbar-container',
                config: {
                    insertKeys: {
                        index: 0,
                        keys: ['insertVariable']
                    }
                }
            });
            const iv = document.querySelector('#toolbar-container [data-menu-key="insertVariable"]');
            if (iv) iv.style.marginLeft = 'auto';
            
            // Handle tab from URL
            const urlParams = new URLSearchParams(window.location.search);
            const tab = urlParams.get('tab');
            if (tab) {
                const tabEl = document.querySelector(`.email-tab[onclick*="'${tab}'"]`);
                if (tabEl) {
                    switchTab(tab, tabEl);
                }
            }
        });

        function switchTab(tabId, el) {
            document.querySelectorAll('.email-tab').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
            
            document.querySelectorAll('.config-form, .template-list, .binding-list').forEach(s => s.classList.remove('active'));
            document.getElementById(tabId + '-section').classList.add('active');
        }

        function setEfSelectValue(inputId, value) {
            let input = document.getElementById(inputId);
            if (!input) return;
            input.value = value;
            let spanSelect = document.getElementById(inputId + '_select');
            if (!spanSelect) return;
            
            let contentId = spanSelect.getAttribute('contentid');
            let popup = document.getElementById(contentId);
            if (!popup) return;
            
            let option = popup.querySelector('.ef-select-option[value="' + value + '"]');
            if (option) {
                let text = option.querySelector('.ef-select-option-content').innerText;
                spanSelect.querySelector('.ef-select-view-value').innerText = text;
                spanSelect.querySelector('.ef-select-view-value').classList.remove('ef-select-view-value-hidden');
                spanSelect.querySelector('.ef-select-view-input').classList.add('ef-select-view-input-hidden');
                spanSelect.setAttribute('chosen', 'true');
                
                popup.querySelectorAll('.ef-select-option').forEach(opt => opt.classList.remove('ef-select-option-active'));
                option.classList.add('ef-select-option-active');
            } else if (value === '' || !value) {
                spanSelect.querySelector('.ef-select-view-value').innerText = '';
                spanSelect.querySelector('.ef-select-view-value').classList.add('ef-select-view-value-hidden');
                spanSelect.querySelector('.ef-select-view-input').classList.remove('ef-select-view-input-hidden');
                spanSelect.setAttribute('chosen', 'false');
                popup.querySelectorAll('.ef-select-option').forEach(opt => opt.classList.remove('ef-select-option-active'));
            }
        }

        function openConfigDrawerWithData(id = '', name = '', isDefault = '0', protocol = 'smtp', host = '', port = '465', encryption = 'ssl', username = '', senderName = '', senderAddress = '') {
            document.getElementById('configId').value = id;
            document.getElementById('configName').value = name;
            document.getElementById('configIsDefault').checked = (isDefault === '1' || isDefault === 1);
            setEfSelectValue('configProtocol', protocol);
            document.getElementById('configHost').value = host;
            
            let portInput = document.getElementById('configPort');
            portInput.value = port;
            portInput.setAttribute('num-value', port);
            
            setEfSelectValue('configEncryption', encryption);
            document.getElementById('configUsername').value = username;
            document.getElementById('configPassword').value = '';
            document.getElementById('configSenderName').value = senderName;
            document.getElementById('configSenderAddress').value = senderAddress;

            document.getElementById('configDrawerTitle').innerText = id ? '{{ 'admin_email.drawer.edit_title'|trans }}' : '{{ 'admin_email.drawer.add_title'|trans }}';
            $().showDrawer('configDrawer');
        }

        {% verbatim %}
        const presetTemplates = {
            welcome: '<div style="max-width:680px;margin:0 auto;padding:24px;background:#ffffff;border:1px solid #e5e7eb;border-radius:8px;"><div style="font-size:18px;font-weight:600;color:#111827;margin-bottom:8px;">欢迎加入我们</div><div style="font-size:14px;color:#374151;line-height:1.7;margin-bottom:16px;">您好，欢迎加入我们的团队！以下是常用入口与指引，请您尽快完成账号设置。</div><div style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:6px;padding:12px 16px;margin-bottom:12px;"><div style="font-size:14px;color:#111827;">初始账号：{{ username }}</div><div style="font-size:14px;color:#111827;">首次登录地址：{{ login_url }}</div></div><div style="font-size:12px;color:#6b7280;">如果有问题，请联系 HR 或 IT 支持。</div></div>',
            verification_code: '<div style="max-width:680px;margin:0 auto;padding:24px;background:#ffffff;border:1px solid #e5e7eb;border-radius:8px;"><div style="font-size:18px;font-weight:600;color:#111827;margin-bottom:8px;">验证码</div><div style="font-size:14px;color:#374151;line-height:1.7;margin-bottom:16px;">您好，您正在进行安全验证，以下是您的一次性验证码：</div><div style="font-size:28px;font-weight:700;color:#111827;letter-spacing:4px;background:#f9fafb;border:1px solid #e5e7eb;border-radius:6px;padding:12px 16px;margin-bottom:12px;text-align:center;">{{ code }}</div><div style="font-size:12px;color:#6b7280;">该验证码有效期 {{ expire_minutes }} 分钟，请勿泄露。</div></div>',
            password_reset: '<div style="max-width:680px;margin:0 auto;padding:24px;background:#ffffff;border:1px solid #e5e7eb;border-radius:8px;"><div style="font-size:18px;font-weight:600;color:#111827;margin-bottom:8px;">密码重置</div><div style="font-size:14px;color:#374151;line-height:1.7;margin-bottom:16px;">您好，您申请了重置密码，请点击以下链接完成操作：</div><a href="{{ reset_url }}" style="display:inline-block;background:#2563eb;color:#fff;text-decoration:none;border-radius:6px;padding:10px 16px;font-size:14px;">重置密码</a><div style="font-size:12px;color:#6b7280;margin-top:12px;">如果不是您本人操作，请忽略本邮件。</div></div>',
            announcement: '<div style="max-width:680px;margin:0 auto;padding:24px;background:#ffffff;border:1px solid #e5e7eb;border-radius:8px;"><div style="font-size:18px;font-weight:600;color:#111827;margin-bottom:8px;">公告通知</div><div style="font-size:14px;color:#374151;line-height:1.7;margin-bottom:16px;">{{ announcement_title }}</div><div style="font-size:14px;color:#374151;line-height:1.7;">{{ announcement_body }}</div></div>'
        };
        {% endverbatim %}

        function applyPresetTemplate() {
            const key = document.getElementById('presetTemplate').value;
            if (!key || !presetTemplates[key]) return;
            const html = presetTemplates[key];
            if (editor) {
                editor.setHtml(html);
                document.getElementById('templateBody').value = editor.getHtml();
            } else {
                const container = document.getElementById('editor-text-container');
                if (container) container.innerHTML = html;
                document.getElementById('templateBody').value = html;
            }
        }

        function openTemplateDrawerWithData(id = '', name = '', subject = '', desc = '', body = '', emailConfigId = '') {
            let url = '{{ path('admin_email_template_editor') }}';
            if (id) {
                url = '{{ path('admin_email_template_editor_with_id', {'id': 'ID_PLACEHOLDER'}) }}'.replace('ID_PLACEHOLDER', id);
            }
            window.open(url, '_blank');
        }

        let templateVariables = [];

        function addVariableBadge(varName, varDesc = '') {
            const existing = templateVariables.find(v => v.name === varName);
            if (existing) {
                existing.desc = varDesc;
            } else {
                templateVariables.push({name: varName, desc: varDesc});
            }
            renderVariables();
            updateDescriptionField();
        }

        function addVariable() {
            const nameInput = document.getElementById('newVariableName');
            const descInput = document.getElementById('newVariableDesc');
            const varName = nameInput.value.trim();
            const varDesc = descInput.value.trim();
            if (varName) {
                addVariableBadge(varName, varDesc);
                nameInput.value = '';
                descInput.value = '';
            }
        }

        function removeVariable(varName) {
            templateVariables = templateVariables.filter(v => v.name !== varName);
            renderVariables();
            updateDescriptionField();
        }

        function renderVariables() {
            const list = document.getElementById('variablesList');
            list.innerHTML = '';
            templateVariables.forEach(v => {
                const badge = document.createElement('div');
                badge.style.cssText = 'background: #e5f0ff; color: #0066cc; padding: 4px 8px; border-radius: 4px; font-size: 13px; display: flex; align-items: center; gap: 6px; cursor: pointer;';
                
                const textSpan = document.createElement('span');
                textSpan.innerText = v.name + (v.desc ? ` (${v.desc})` : '');
                textSpan.title = '点击插入到编辑器';
                textSpan.onclick = () => insertVariableIntoEditor(v.name);
                
                const delBtn = document.createElement('i');
                delBtn.className = 'fa-solid fa-xmark';
                delBtn.style.cursor = 'pointer';
                delBtn.onclick = (e) => {
                    e.stopPropagation();
                    removeVariable(v.name);
                };
                
                badge.appendChild(textSpan);
                badge.appendChild(delBtn);
                list.appendChild(badge);
            });
        }

        function updateDescriptionField() {
            document.getElementById('templateDescription').value = JSON.stringify(templateVariables);
        }

        function insertVariableIntoEditor(varName) {
            const textToInsert = '{' + '{ ' + varName + ' }' + '}';
            if (editor) {
                editor.insertText(textToInsert);
            } else {
                const textarea = document.getElementById('templateBody');
                const start = textarea.selectionStart;
                const end = textarea.selectionEnd;
                textarea.value = textarea.value.substring(0, start) + textToInsert + textarea.value.substring(end);
                textarea.selectionStart = textarea.selectionEnd = start + textToInsert.length;
                textarea.focus();
            }
        }

        function testConnection() {
            const form = document.getElementById('configForm');
            if (!form.reportValidity()) {
                return;
            }
            
            const senderAddress = document.getElementById('configSenderAddress').value;
            document.getElementById('configTestEmailInput').value = senderAddress;
            
            openModal('testConnectionModal');
            setTimeout(() => {
                document.getElementById('configTestEmailInput').focus();
            }, 100);
        }

        function closeTestConnectionModal() {
            closeModal('testConnectionModal');
        }

        function executeTestConnection() {
            const testEmailInput = document.getElementById('configTestEmailInput');
            const testEmail = testEmailInput.value;

            if (testEmail.trim() === '') {
                let alert = new Alert($('#testConnectionModal .ef-modal-body'));
                alert.error('{{ 'admin_email.flash.test_email_required'|trans }}', { percent: '90%', title: "{{ 'admin_email.flash.error'|trans }}", closable: true });
                return;
            }
            
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(testEmail.trim())) {
                let alert = new Alert($('#testConnectionModal .ef-modal-body'));
                alert.error('{{ 'admin_email.flash.invalid_email'|trans }}', { percent: '90%', title: "{{ 'admin_email.flash.error'|trans }}", closable: true });
                return;
            }

            const form = document.getElementById('configForm');
            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());
            data.testEmail = testEmail.trim();
            
            const btn = document.getElementById('confirmTestConnectionBtn');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> {{ 'admin_email.flash.testing'|trans }}';
            btn.disabled = true;

            ajax({
                method: 'POST',
                url: '{{ path('admin_email_config_test_connection') }}',
                contentType: 'application/x-www-form-urlencoded',
                data: data,
                success: function (response) {
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                    
                    if (response.code === 200) {
                        closeTestConnectionModal();
                        let alert = new Alert($('#configDrawer .ef-drawer-body'));
                        alert.success(response.message || '{{ 'admin_email.flash.test_success'|trans }}', { percent: '90%', title: "{{ 'admin_email.flash.success'|trans }}", closable: true });
                    } else {
                        let alert = new Alert($('#testConnectionModal .ef-modal-body'));
                        alert.error(response.message || '{{ 'admin_email.flash.test_failed'|trans }}', { percent: '90%', title: "{{ 'admin_email.flash.error'|trans }}", closable: true });
                    }
                },
                error: function (xhr, status, errorMsg) {
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                    let alert = new Alert($('#testConnectionModal .ef-modal-body'));
                    alert.error(errorMsg || '{{ 'admin_email.flash.ajax_error'|trans }}', { percent: '90%', title: "{{ 'admin_email.flash.error'|trans }}", closable: true });
                }
            });
        }
        function testTemplateEmail() {
            const form = document.getElementById('templateForm');
            if (!form.reportValidity()) {
                return;
            }
            
            // Show custom modal
            openModal('testTemplateEmailModal');
            setTimeout(() => {
                document.getElementById('templateTestEmailInput').focus();
            }, 100);
        }

        function closeTestTemplateEmailModal() {
            closeModal('testTemplateEmailModal');
            document.getElementById('templateTestEmailInput').value = '';
        }

        function executeTestTemplateEmail() {
            const testEmailInput = document.getElementById('templateTestEmailInput');
            const testEmail = testEmailInput.value;
            
            if (testEmail.trim() === '') {
                let alert = new Alert($('#testTemplateEmailModal .modal-body'));
                alert.error('{{ 'admin_email.flash.test_email_required'|trans }}', { percent: '90%', title: "{{ 'admin_email.flash.error'|trans }}", closable: true });
                return;
            }
            
            // Basic email validation
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(testEmail.trim())) {
                let alert = new Alert($('#testTemplateEmailModal .modal-body'));
                alert.error('{{ 'admin_email.flash.invalid_email'|trans }}', { percent: '90%', title: "{{ 'admin_email.flash.error'|trans }}", closable: true });
                return;
            }

            const form = document.getElementById('templateForm');
            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());
            
            // Get content from WangEditor if it exists
            if (editor) {
                data.bodyHtml = editor.getHtml();
            }

            data.testEmail = testEmail.trim();
            
            const btn = document.getElementById('confirmTestTemplateEmailBtn');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> {{ 'admin_email.flash.sending'|trans }}';
            btn.disabled = true;

            ajax({
                method: 'POST',
                url: '{{ path('admin_email_template_test_send') }}',
                contentType: 'application/x-www-form-urlencoded',
                data: data,
                success: function (response) {
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                    
                    if (response.code === 200) {
                        closeTestTemplateEmailModal();
                        let alert = new Alert($('#templateDrawer .ef-drawer-body'));
                        alert.success(response.message || '{{ 'admin_email.flash.send_success'|trans }}', { percent: '90%', title: "{{ 'admin_email.flash.success'|trans }}", closable: true });
                    } else {
                        let alert = new Alert($('#testTemplateEmailModal .modal-body'));
                        alert.error(response.message || '{{ 'admin_email.flash.send_failed'|trans }}', { percent: '90%', title: "{{ 'admin_email.flash.error'|trans }}", closable: true });
                    }
                },
                error: function (xhr, status, errorMsg) {
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                    let alert = new Alert($('#testTemplateEmailModal .modal-body'));
                    alert.error(errorMsg || '{{ 'admin_email.flash.ajax_error'|trans }}', { percent: '90%', title: "{{ 'admin_email.flash.error'|trans }}", closable: true });
                }
            });
        }
    </script>
{% endblock %}
