{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'admin_security.page_title'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" type="text/css" href="{{ asset('corporation.css', 'admin') }}">
    <style>
        .security-page {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            color: #1d1d1f;
        }
        .security-title {
            font-size: 28px;
            font-weight: 600;
            margin-bottom: 24px;
        }
        .security-tabs {
            display: flex;
            border-bottom: 1px solid #e5e5ea;
            margin-bottom: 32px;
        }
        .security-tab {
            padding: 12px 0;
            margin-right: 32px;
            font-size: 15px;
            font-weight: 500;
            color: #86868b;
            cursor: pointer;
            text-decoration: none;
        }
        .security-tab.active {
            color: #0066cc;
            border-bottom: 2px solid #0066cc;
        }
        .policy-section {
            background: #fff;
            border: 1px solid #e5e5ea;
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 24px;
        }
        .policy-section-title {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 16px;
            padding-bottom: 12px;
            border-bottom: 1px solid #f5f5f7;
        }
        .form-row {
            display: flex;
            align-items: center;
            margin-bottom: 16px;
        }
        .form-label {
            width: 200px;
            font-weight: 500;
            font-size: 14px;
            color: #1d1d1f;
        }
        .form-control {
            flex: 1;
            max-width: 300px;
        }
        .checkbox-group {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .checkbox-item {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            color: #1d1d1f;
        }
        .side-card {
            background: #f5f5f7;
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 16px;
        }
        .side-card-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 8px;
        }
        .side-card-text {
            font-size: 14px;
            color: #555;
            margin-bottom: 16px;
            line-height: 1.5;
        }
        .side-card-link {
            color: #0066cc;
            font-weight: 500;
            text-decoration: none;
            font-size: 14px;
        }
        .side-card-link:hover {
            text-decoration: underline;
        }
        .ai-chat-box {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 16px;
            margin-bottom: 16px;
        }
        .ai-input-group {
            display: flex;
            gap: 8px;
        }
        .ai-input {
            flex: 1;
            border: 1px solid #cbd5e1;
            border-radius: 6px;
            padding: 10px 16px;
            font-size: 14px;
            outline: none;
            transition: border-color 0.2s;
        }
        .ai-input:focus {
            border-color: #3b82f6;
        }
        .rule-tag {
            display: inline-block;
            background: #e0f2fe;
            color: #0369a1;
            padding: 4px 10px;
            border-radius: 16px;
            font-size: 12px;
            font-weight: 500;
            margin-right: 8px;
            margin-bottom: 8px;
        }
    </style>
{% endblock %}

{% block app_content_container %}
<div class="org-structure-container security-page">
    <div class="outside-wrapper" style="padding: 40px; max-width: 1200px; margin: 0; background: #fff; min-height: calc(100vh - 60px);">
        
        <div class="security-title">{{ 'admin_security.title'|trans }}</div>
        
        <div class="security-tabs">
            <a href="{{ path('admin_security_index') }}" class="security-tab">{{ 'admin_security.tabs.2fa_settings'|trans }}</a>
            <a href="{{ path('admin_security_password_policy') }}" class="security-tab active">{{ 'admin_security.tabs.password_policy'|trans }}</a>
        </div>

        <div class="ef-row ef-row-align-start ef-row-justify-start">
            <div class="ef-col-16" style="padding-right: 60px;">
                
                {% for message in app.flashes('success') %}
                    <div role="alert" class="ef-alert ef-alert-success" style="margin-bottom: 32px; border-radius: 12px; padding: 20px; background-color: #f0fdf4; color: #166534;">
                        <div class="ef-alert-icon" style="color: #16a34a;"><i class="fa-solid fa-circle-check" style="font-size: 18px;"></i></div>
                        <div class="ef-alert-body">
                            <div class="ef-alert-content" style="font-size: 14px;">{{ message }}</div>
                        </div>
                    </div>
                {% endfor %}

                <div role="alert" class="ef-alert ef-alert-info" style="margin-bottom: 32px; background-color: #f0f4f8; border: none; border-radius: 12px; padding: 20px;">
                    <div class="ef-alert-icon" style="color: #0066cc; align-self: flex-start; margin-top: 2px;">
                        <i class="fa-solid fa-shield-halved" style="font-size: 18px;"></i>
                    </div>
                    <div class="ef-alert-body">
                        <div class="ef-alert-title" style="font-weight: 600; font-size: 15px; margin-bottom: 4px; color: #1d1d1f;">认证与安全策略中心</div>
                        <div class="ef-alert-content" style="color: #555; font-size: 14px; line-height: 1.5;">配置密码强度规则与生命周期，把安全策略做成可配置、可扩展的规则引擎。</div>
                    </div>
                </div>

                <form action="{{ path('admin_security_password_policy_update') }}" method="post">
                    
                    <!-- 基础配置区 -->
                    <div class="policy-section">
                        <div class="policy-section-title">基础配置区 (Password Policy)</div>
                        
                        <div class="form-row">
                            <div class="form-label">最小长度</div>
                            <div class="form-control">
                                <span class="ef-input-wrapper">
                                    <input type="number" name="min_length" class="ef-input ef-input-size-medium" value="{{ policy.minLength }}" min="1" max="128">
                                </span>
                            </div>
                        </div>
                        
                        <div class="form-row">
                            <div class="form-label">最大长度</div>
                            <div class="form-control">
                                <span class="ef-input-wrapper">
                                    <input type="number" name="max_length" class="ef-input ef-input-size-medium" value="{{ policy.maxLength }}" min="1" max="128">
                                </span>
                            </div>
                        </div>

                        <div class="form-row" style="align-items: flex-start;">
                            <div class="form-label" style="margin-top: 4px;">必须包含</div>
                            <div class="form-control checkbox-group">
                                <label class="checkbox-item">
                                    <input type="checkbox" name="require_uppercase" {% if policy.requireUppercase %}checked{% endif %}> 大写字母
                                </label>
                                <label class="checkbox-item">
                                    <input type="checkbox" name="require_lowercase" {% if policy.requireLowercase %}checked{% endif %}> 小写字母
                                </label>
                                <label class="checkbox-item">
                                    <input type="checkbox" name="require_number" {% if policy.requireNumber %}checked{% endif %}> 数字
                                </label>
                                <label class="checkbox-item">
                                    <input type="checkbox" name="require_special" {% if policy.requireSpecial %}checked{% endif %}> 特殊字符
                                </label>
                            </div>
                        </div>

                        <div class="form-row" style="align-items: flex-start; margin-top: 24px;">
                            <div class="form-label" style="margin-top: 4px;">不允许包含</div>
                            <div class="form-control checkbox-group">
                                <label class="checkbox-item">
                                    <input type="checkbox" name="forbid_username" {% if policy.forbidUsername %}checked{% endif %}> 用户名 / 邮箱前缀
                                </label>
                                <label class="checkbox-item">
                                    <input type="checkbox" name="forbid_common_password" {% if policy.forbidCommonPassword %}checked{% endif %}> 常见弱密码（字典校验）
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- AI 智能配置区 -->
                    <div class="policy-section">
                        <div class="policy-section-title">
                            强度等级策略 (Strength Rules) 
                            <span class="rule-tag" style="background: #fdf4ff; color: #0284c7; border: 1px solid #e0f2fe; margin-left: 8px;">
                                <i class="fa-solid fa-wand-magic-sparkles"></i> AI 智能配置
                            </span>
                        </div>
                        
                        <div style="font-size: 14px; color: #64748b; margin-bottom: 16px;">
                            你可以通过自然语言直接配置复杂的密码强度规则组合。例如输入："把强密码规则设置为至少12位，必须包含大小写和数字"。
                        </div>

                        <div class="ai-chat-box">
                            <div class="ai-input-group">
                                <input type="text" class="ai-input" placeholder="输入自然语言配置指令，如：要求密码长度大于等于8位且包含特殊字符..." id="aiInstructionInput">
                                <button type="button" class="btn primary medium" style="border-radius: 6px; padding: 0 16px; white-space: nowrap;" onclick="generateRulesViaAI()">
                                    <i class="fa-solid fa-robot"></i> AI 解析
                                </button>
                            </div>
                            
                            <div id="aiResultArea" style="margin-top: 16px; padding-top: 16px; border-top: 1px dashed #e2e8f0; display: none;">
                                <div style="font-size: 13px; font-weight: 500; color: #475569; margin-bottom: 8px;">解析后的内部条件 (JSON DSL 预览):</div>
                                <div>
                                    <span class="rule-tag">[长度 ≥ 12]</span>
                                    <span class="rule-tag">[含数字]</span>
                                    <span class="rule-tag">[含大写]</span>
                                    <span class="rule-tag">[含小写]</span>
                                    <span class="rule-tag">[含特殊字符]</span>
                                    <span class="rule-tag">[排除用户名]</span>
                                </div>
                                <div style="font-size: 12px; color: #94a3b8; margin-top: 8px;">*此功能为 AI Agent 演示，后台将自动生成对应的 JSON DSL 表达式。</div>
                            </div>
                        </div>

                        <!-- 现有的规则列表占位 -->
                        <table class="ef-table ef-table-border" style="width: 100%; margin-top: 16px;">
                            <thead>
                                <tr class="ef-table-tr">
                                    <th class="ef-table-th">强度等级</th>
                                    <th class="ef-table-th">表达式 / 条件 (可视化)</th>
                                    <th class="ef-table-th" style="width: 100px;">操作</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% if rules|length > 0 %}
                                    {% for rule in rules %}
                                        <tr class="ef-table-tr">
                                            <td class="ef-table-td">{{ rule.name }}</td>
                                            <td class="ef-table-td">
                                                <code style="font-size: 12px; color: #d946ef; background: #fdf4ff; padding: 2px 6px; border-radius: 4px;">{{ rule.expression|json_encode }}</code>
                                            </td>
                                            <td class="ef-table-td">
                                                <a href="#" class="ef-link">编辑</a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                {% else %}
                                    <tr class="ef-table-tr">
                                        <td class="ef-table-td">弱</td>
                                        <td class="ef-table-td"><span class="rule-tag">[长度 ≥ 6]</span></td>
                                        <td class="ef-table-td"><a href="#" class="ef-link">编辑</a></td>
                                    </tr>
                                    <tr class="ef-table-tr">
                                        <td class="ef-table-td">中</td>
                                        <td class="ef-table-td"><span class="rule-tag">[长度 ≥ 8]</span> <span class="rule-tag">[含数字]</span></td>
                                        <td class="ef-table-td"><a href="#" class="ef-link">编辑</a></td>
                                    </tr>
                                    <tr class="ef-table-tr">
                                        <td class="ef-table-td">强</td>
                                        <td class="ef-table-td"><span class="rule-tag">[长度 ≥ 10]</span> <span class="rule-tag">[含数字]</span> <span class="rule-tag">[含大写字母]</span></td>
                                        <td class="ef-table-td"><a href="#" class="ef-link">编辑</a></td>
                                    </tr>
                                {% endif %}
                            </tbody>
                        </table>
                    </div>

                    <!-- 生命周期与附加策略 -->
                    <div class="policy-section">
                        <div class="policy-section-title">密码生命周期与登录策略</div>
                        
                        <div class="form-row">
                            <div class="form-label">密码有效期 (天)</div>
                            <div class="form-control">
                                <span class="ef-input-wrapper">
                                    <input type="number" name="expire_days" class="ef-input ef-input-size-medium" value="{{ policy.expireDays }}" min="0">
                                </span>
                                <div style="font-size: 12px; color: #86868b; margin-top: 4px;">0 表示永不过期</div>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-label">禁止重复历史密码次数</div>
                            <div class="form-control">
                                <span class="ef-input-wrapper">
                                    <input type="number" name="history_limit" class="ef-input ef-input-size-medium" value="{{ policy.historyLimit }}" min="0">
                                </span>
                                <div style="font-size: 12px; color: #86868b; margin-top: 4px;">记住最近 N 次密码，0 表示允许重复</div>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-label">连续失败锁定阈值</div>
                            <div class="form-control">
                                <span class="ef-input-wrapper">
                                    <input type="number" name="max_retry" class="ef-input ef-input-size-medium" value="{{ policy.maxRetry }}" min="0">
                                </span>
                                <div style="font-size: 12px; color: #86868b; margin-top: 4px;">失败 N 次后锁定账户</div>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-label">账户锁定时间 (分钟)</div>
                            <div class="form-control">
                                <span class="ef-input-wrapper">
                                    <input type="number" name="lock_minutes" class="ef-input ef-input-size-medium" value="{{ policy.lockMinutes }}" min="1">
                                </span>
                            </div>
                        </div>
                    </div>

                    <div style="margin-top: 24px; padding: 24px; background: #fff; border: 1px solid #e5e5ea; border-radius: 12px; display: flex; justify-content: center;">
                        <button type="submit" class="btn primary medium" style="border-radius: 20px; padding: 0 32px;">
                            <i class="fa-solid fa-save"></i> &nbsp;保存策略配置
                        </button>
                    </div>
                </form>

            </div>
            
            <div class="ef-col-8">
                <div class="side-card">
                    <div class="side-card-title">什么是密码强度规则？</div>
                    <div class="side-card-text">
                        将安全策略参数化、可视化。通过定义不同的强度等级（弱、中、强），您可以在前端注册、修改密码时为用户提供实时的强度提示。
                    </div>
                </div>

                <div class="side-card" style="background: #fdf4ff;">
                    <div class="side-card-title" style="color: #a21caf;"><i class="fa-solid fa-wand-magic-sparkles"></i> AI 辅助配置</div>
                    <div class="side-card-text">
                        我们引入了 <strong>PasswordPolicyAgent</strong>，您可以直接使用自然语言对话框来配置复杂的安全规则，AI 会自动将您的语言解析为标准的 JSON DSL 过滤表达式。
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        function generateRulesViaAI() {
            const input = document.getElementById('aiInstructionInput').value;
            if (!input) {
                ui.alert.show({title: '提示', content: '请输入指令', type: 'warning'});
                return;
            }
            
            const btn = document.querySelector('.ai-input-group button');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> 解析中...';
            btn.disabled = true;

            fetch('{{ path('api_admin_ai_parse_policy') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ text: input })
            })
            .then(response => response.json())
            .then(data => {
                btn.innerHTML = originalText;
                btn.disabled = false;
                
                if (data.error) {
                    ui.alert.show({title: '解析失败', content: data.error, type: 'error'});
                    return;
                }

                const resultArea = document.getElementById('aiResultArea');
                resultArea.style.display = 'block';
                
                // Clear existing tags except the label div and disclaimer
                const tagsContainer = resultArea.querySelector('div:nth-child(2)');
                tagsContainer.innerHTML = '';
                
                // Render DSL into UI tags
                const expression = data.expression;
                renderDslToTags(expression, tagsContainer);
                
            })
            .catch(error => {
                btn.innerHTML = originalText;
                btn.disabled = false;
                ui.alert.show({title: '网络错误', content: '请求 AI 服务失败，请检查网络或后端日志。', type: 'error'});
            });
        }

        function renderDslToTags(expression, container) {
            if (expression.and) {
                expression.and.forEach(cond => appendTag(cond, container));
            } else if (expression.field) {
                appendTag(expression, container);
            } else {
                container.innerHTML = '<span class="rule-tag" style="background: #fee2e2; color: #991b1b;">无法解析该指令</span>';
            }
        }

        function appendTag(cond, container) {
            let text = '';
            if (cond.field === 'length') {
                text = `长度 ${cond.operator} ${cond.value}`;
            } else if (cond.field === 'has_number' && cond.value === true) {
                text = `含数字`;
            } else if (cond.field === 'has_uppercase' && cond.value === true) {
                text = `含大写`;
            } else if (cond.field === 'has_lowercase' && cond.value === true) {
                text = `含小写`;
            } else if (cond.field === 'has_special' && cond.value === true) {
                text = `含特殊字符`;
            } else if (cond.field === 'has_case' && cond.value === 'mixed') {
                text = `含大小写`;
            } else {
                text = `${cond.field} ${cond.operator} ${cond.value}`;
            }

            const span = document.createElement('span');
            span.className = 'rule-tag';
            span.textContent = `[${text}]`;
            container.appendChild(span);
        }
    </script>
{% endblock %}
