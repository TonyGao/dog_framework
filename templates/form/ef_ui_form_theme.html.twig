{# 参照 symfony/twig-bridge/Resources/views/Form/ 下文件 #}
{% use 'form_div_layout.html.twig' %}

{% block form_start -%}
    {%- if attr is not defined or attr is not iterable -%}
        {%- set attr = {} -%}
    {%- endif -%}
    {% set attr = attr|merge({class: (attr.class|default('') ~ ' ef-form ef-form-layout-horizontal ef-form-size-medium ef-form-auto-label-width')|trim}) %}
    {{- parent() -}}
{%- endblock form_start %}

{%- block widget_attributes -%}
    {%- if attr is not defined or attr is not iterable -%}
        {%- set attr = {} -%}
    {%- endif -%}
    id="{{ attr.id is defined ? attr.id : id }}"
    name="{{ attr.name is defined ? attr.name : full_name }}"
    {%- if disabled %} disabled="disabled"{% endif -%}
    {%- if required %} required{% endif -%}
    {{ block('attributes') }}
{%- endblock widget_attributes -%}

{# Widgets #}

{%- block form_widget_simple -%}
    {%- if attr is not defined or attr is not iterable -%}
        {%- set attr = {} -%}
    {%- endif -%}

    {# 设置默认的 type 为 'text' #}
    {%- set type = type|default('text') -%}

    {# 处理 range 和 color 类型控件不支持 required 属性的情况 #}
    {%- if type == 'range' or type == 'color' -%}
        {%- set required = false -%}
    {%- endif -%}

    {# 检查是否有传入 readonly  属性，并为 input 元素添加相应的样式类 #}
    {%- set isReadonly = attr.readonly is defined and attr.readonly -%}
    {%- set class_attr = attr.class is defined ? attr.class : '' %}
    {%- set wrapper_class = attr.wrapper_class|default('') -%}
    {%- if attr.rounded|default(false) -%}
        {%- set wrapper_class = wrapper_class ~ ' ef-input-rounded' -%}
    {%- endif -%}
    {%- set wrapper_style = '' -%}
    {%- if attr.height|default(false) -%}
        {%- set wrapper_class = wrapper_class ~ ' ef-input-h' ~ attr.height -%}
        {%- set wrapper_style = 'height: ' ~ attr.height ~ 'px;' -%}
    {%- endif -%}
    {%- set attr = attr|merge({'wrapper_class': false, 'rounded': false, 'height': false}) -%}

    {# 处理各类文本输入框，使用自定义的样式 #}
    {%- if type in ['text', 'week', 'email', 'password', 'url', 'tel', 'color'] -%}
        {%- if type == 'color' -%}
            {%- set wrapper_style = wrapper_style ~ ' padding: 4px;' -%}
            {%- set class_attr = class_attr ~ ' ef-input-color' -%}
        {%- endif -%}
        <span class="ef-input-wrapper {{ wrapper_class }} {% if isReadonly %} ef-input-disabled {% endif %}" style="{{ wrapper_style }}">
            <input component="input" class="ef-input ef-input-size-medium {{ class_attr }}" 
                   {% if type != 'color' %}clearable="true"{% endif %}
                   type="{{ type }}" 
                   {{ block('widget_attributes') }} 
                   {% if value is not empty %}value="{{ value }}" {% endif %}
                   {% if isReadonly %} readonly="readonly" {% endif %}
                   {% if disabled %} disabled="disabled" {% endif %}
                   {% if type == 'color' %} style="padding: 0; cursor: pointer; border: none; background: transparent;" {% endif %}/>
        </span>
    {%- elseif type == 'search' -%}
        <span class="ef-input-wrapper {{ wrapper_class }} {% if isReadonly %} ef-input-disabled {% endif %}" style="{{ wrapper_style }}">
            <span class="ef-input-prefix"><i class="fa-solid fa-magnifying-glass"></i></span>
            <input component="input" class="ef-input ef-input-size-medium {{ class_attr }}" 
                   clearable="true" 
                   type="{{ type }}" 
                   {{ block('widget_attributes') }} 
                   {% if value is not empty %}value="{{ value }}" {% endif %}
                   {% if isReadonly %} readonly="readonly" {% endif %}
                   {% if disabled %} disabled="disabled" {% endif %}/>
        </span>
    {%- elseif type == 'range' -%}
        <input type="{{ type }}" class="ef-input {{ class_attr }} {% if isReadonly %} ef-input-disabled {% endif %}" style="width: 100%;" {{ block('widget_attributes') }} {% if value is not empty %}value="{{ value }}" {% endif %} {% if isReadonly %} readonly="readonly" {% endif %} {% if disabled %} disabled="disabled" {% endif %}/>
    {%- else -%}
        {# 处理其他类型的输入框 #}
        <input type="{{ type }}" {{ block('widget_attributes') }} 
               {% if value is not empty %}value="{{ value }}" {% endif %}
               {% if isReadonly %} readonly="readonly" {% endif %}
               {% if disabled %} disabled="disabled" {% endif %}/>
    {%- endif -%}
{%- endblock form_widget_simple -%}

{%- block textarea_widget -%}
  {%- set isReadonly = attr.readonly is defined and attr.readonly -%}
  {%- set class_attr = attr.class is defined ? attr.class : '' %}
  {%- set wrapper_class = attr.wrapper_class|default('') -%}
  {%- if attr.rounded|default(false) -%}
      {%- set wrapper_class = wrapper_class ~ ' ef-textarea-rounded' -%}
  {%- endif -%}
  {%- set wrapper_style = '' -%}
  {%- set min_rows = 3 -%}
  {%- if attr.rows is defined and attr.rows > 0 -%}
      {%- set min_rows = attr.rows -%}
  {%- endif -%}
  {%- set min_rows = max(min_rows, 3) -%}
  {%- set is_autosize = false -%}
  {%- if attr.autosize is defined and attr.autosize -%}
      {%- set is_autosize = true -%}
  {%- endif -%}
  {%- set attr = attr|merge({'wrapper_class': false, 'rounded': false, 'height': false, 'autosize': false}) -%}
  <div class="ef-textarea-wrapper {{ wrapper_class }} {% if isReadonly %} ef-textarea-disabled {% endif %}" style="{{ wrapper_style }}">
    <textarea component="textarea" {{ block('widget_attributes') }} class="ef-textarea {% if is_autosize %}resizeable{% endif %} {{ class_attr }}" min-rows="{{ min_rows }}" max-rows="10" clearable="true" placeholder="Please enter something">{{ value }}</textarea>
  </div>
{%- endblock textarea_widget -%}

{%- block submit_widget -%}
    <div class="ef-row ef-row-align-start ef-row-justify-start ef-form-item ef-form-item-layout-horizontal">
      <div class="ef-col ef-col-5 ef-form-item-label-col">
        <label class="ef-form-item-label"></label>
      </div>
      <div class="ef-col ef-col-19 ef-form-item-wrapper-col">
        <div class="ef-form-item-content-wrapper">
          <div class="ef-form-item-content ef-form-item-content-flex">
            <div class="ef-space ef-space-horizontal ef-space-align-center">
              {%- set type = type|default('submit') -%}
              {{ block('button_widget') }}
            </div>
          </div>
        </div>
      </div>
    </div>
{%- endblock submit_widget -%}

{% block button_widget -%}
  {%- if attr is not defined or attr is not iterable -%}
      {%- set attr = {} -%}
  {%- endif -%}
  <div class="ef-space-item">
    {% set attr = attr|merge({class: (attr.class|default('') ~ ' btn primary medium')|trim}) %}
    {{- parent() -}}
  </div>
{%- endblock %}

{# Labels #}

{% block form_label -%}
  {%- if label is same as(false) -%}
      {# No label, output nothing #}
  {%- elseif label is empty -%}
      {# Empty label, output nothing #}
  {%- else -%}
      {%- if label_attr is not defined or label_attr is not iterable -%}
          {%- set label_attr = {} -%}
      {%- endif -%}
      {%- set label_attr = label_attr|merge({ class: (label_attr.class|default('') ~ ' ' ~ (label_class|default('ef-form-item-label')))|trim }) -%}
      <label for="{{ id }}"{% with { attr: label_attr } %}{{ block('attributes') }}{% endwith %}>
          {%- if translation_domain is same as(false) -%}
              {{- label|raw -}}
          {%- else -%}
              {{- label|trans({}, translation_domain|default('messages')) -}}
          {%- endif -%}
      </label>
  {%- endif -%}
{%- endblock form_label %}

{# Rows #}

{% block form_row -%}
  <div class="ef-row ef-row-align-start ef-row-justify-start ef-form-item ef-form-item-layout-horizontal">
    <div class="ef-col ef-col-8 ef-form-item-label-col">
      {{- form_label(form) -}}
    </div>
    <div class="ef-col ef-col-16 ef-form-item-wrapper-col">
      <div class="ef-form-item-content-wrapper">
        <div class="ef-form-item-content ef-form-item-content-flex">
          {{- form_widget(form) -}}
        </div>
      </div>
    </div>
    {{- form_errors(form) -}}
  </div>
{%- endblock form_row %}

{% block choice_widget_expanded -%}
  {%- set is_radio = form.vars.expanded and not form.vars.multiple -%}
  <div {{ block('widget_container_attributes') }} class="ef-{{ is_radio ? 'radio' : 'checkbox' }}-group ef-{{ is_radio ? 'radio' : 'checkbox' }}-group-direction-horizontal">
    {%- for child in form %}
      <label class="ef-{{ is_radio ? 'radio' : 'checkbox' }}">
        <input type="{{ is_radio ? 'radio' : 'checkbox' }}" id="{{ child.vars.id }}" name="{{ child.vars.full_name }}" class="ef-{{ is_radio ? 'radio' : 'checkbox' }}-target" value="{{ child.vars.value }}" {% if child.vars.checked %}checked="checked"{% endif %} {% if child.vars.disabled %}disabled="disabled"{% endif %} />
        <span class="ef-icon-hover ef-{{ is_radio ? 'radio' : 'checkbox' }}-icon-hover">
          {% if is_radio %}
            <span class="ef-radio-icon"></span>
          {% else %}
            <div class="ef-checkbox-icon"></div>
          {% endif %}
        </span>
        <span class="ef-{{ is_radio ? 'radio' : 'checkbox' }}-label">
          {{- child.vars.label|trans({}, choice_translation_domain) -}}
        </span>
      </label>
    {% endfor -%}
  </div>
{%- endblock choice_widget_expanded %}

{% block checkbox_widget -%}
  <label class="ef-checkbox">
    <input type="checkbox" class="ef-checkbox-target" {{ block('widget_attributes') }}{% if value is defined %} value="{{ value }}"{% endif %}{% if checked %} checked="checked"{% endif %} />
    <span class="ef-icon-hover ef-checkbox-icon-hover">
        <div class="ef-checkbox-icon"></div>
    </span>
  </label>
{%- endblock checkbox_widget %}

{% block radio_widget -%}
  <label class="ef-radio">
    <input type="radio" class="ef-radio-target" {{ block('widget_attributes') }}{% if value is defined %} value="{{ value }}"{% endif %}{% if checked %} checked="checked"{% endif %} />
    <span class="ef-icon-hover ef-radio-icon-hover">
        <span class="ef-radio-icon"></span>
    </span>
  </label>
{%- endblock radio_widget %}

{% block file_widget -%}
  <div class="ef-upload-wrapper" style="display: flex; align-items: center; gap: 12px;">
    <button type="button" class="btn secondary medium {% if disabled %}disabled{% endif %}" onclick="this.nextElementSibling.click()">
        <i class="fa-solid fa-upload"></i> 选择文件
    </button>
    <input type="file" {{ block('widget_attributes') }} style="display: none;" onchange="this.nextElementSibling.textContent = this.files[0] ? this.files[0].name : '未选择任何文件'" />
    <span class="ef-upload-filename" style="color: #666; font-size: 14px; max-width: 200px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">未选择任何文件</span>
  </div>
{%- endblock file_widget %}

{% block button_row -%}
    {{- form_widget(form) -}}
{%- endblock button_row %}

{# Errors #}

{% block form_errors -%}
    {% if errors|length > 0 -%}
        <div class="ui pointing red label">
            <i class="warning sign icon"></i>
            {%- for error in errors -%}
                 {{ error.message }}
            {%- endfor -%}
        </div>
    {%- endif %}
{%- endblock form_errors %}

{%- block switch_widget -%}
{% set real_id = id %}
{% set id = id ~ '_hidden' %}
<button id="{{ real_id }}" type="button" role="switch" aria-checked="{% if checked %}true{% else %}false{% endif %}" class="ef-switch ef-switch-type-circle{% if checked %} ef-switch-checked{% endif %}">
  <input type="hidden" {{ block('widget_attributes') }} {% if value is not empty %}value="{{ value }}" {% endif %}/>
  <span class="ef-switch-handle">
    <span class="ef-switch-handle-icon"></span>
  </span>
</button>
{%- endblock switch_widget -%}

{%- block integer_widget -%}
    {%- set wrapper_class = attr.wrapper_class|default('') -%}
    {%- if attr.rounded|default(false) -%}
        {%- set wrapper_class = wrapper_class ~ ' ef-input-rounded' -%}
    {%- endif -%}
    {%- set wrapper_style = '' -%}
    {%- if attr.height|default(false) -%}
        {%- set wrapper_class = wrapper_class ~ ' ef-input-h' ~ attr.height -%}
        {%- set wrapper_style = 'height: ' ~ attr.height ~ 'px;' -%}
    {%- endif -%}
    {%- set attr = attr|merge({'wrapper_class': false, 'rounded': false, 'height': false}) -%}
	<span class="ef-input-wrapper ef-input-number ef-input-number-mode-embed ef-input-number-size-medium {{ wrapper_class }}" style="{{ wrapper_style }}">
    <input role="spinbutton"
      {{ block('widget_attributes') }}
      {% if attr.numValuemax is defined %}
        num-valuemax={{ attr.numValuemax }}
      {% endif %}
      {% if attr.numValuemin is defined %}
        num-valuemin="{{ attr.numValuemin }}"
      {% endif %}
      num-value=""
      {% if attr.step is defined %}
        step="{{ attr.step }}"
      {% endif %}
      precision="0"
      class="ef-input ef-input-size-medium number"
      type="text"
      placeholder="Please Enter"
      {% if value is not empty %}value="{{ value }}" {% endif %}
    >
    <span class="ef-input-suffix">
      <div class="ef-input-number-step">
        <button class="ef-input-number-step-button add" type="button" tabindex="-1">
          <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" class="ef-icon ef-icon-up" stroke-width="4" stroke-linecap="butt" stroke-linejoin="miter"><path d="M39.6 30.557 24.043 15 8.487 30.557"></path></svg>
        </button>
        <button class="ef-input-number-step-button subtract" type="button" tabindex="-1">
          <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" class="ef-icon ef-icon-down" stroke-width="4" stroke-linecap="butt" stroke-linejoin="miter"><path d="M39.6 17.443 24.043 33 8.487 17.443"></path></svg>
        </button>
      </div>
    </span>
  </span>
{%- endblock integer_widget -%}

{%- block money_widget -%}
    {%- set type = type|default('text') -%}
    {%- set isReadonly = attr.readonly is defined and attr.readonly -%}
    {%- set class_attr = attr.class is defined ? attr.class : '' %}
    {%- set wrapper_class = attr.wrapper_class|default('') -%}
    {%- if attr.rounded|default(false) -%}
        {%- set wrapper_class = wrapper_class ~ ' ef-input-rounded' -%}
    {%- endif -%}
    {%- set wrapper_style = '' -%}
    {%- if attr.height|default(false) -%}
        {%- set wrapper_class = wrapper_class ~ ' ef-input-h' ~ attr.height -%}
        {%- set wrapper_style = 'height: ' ~ attr.height ~ 'px;' -%}
    {%- endif -%}
    {%- set attr = attr|merge({'wrapper_class': false, 'rounded': false, 'height': false}) -%}
    
    {%- set currency_symbol -%}
        {{ money_pattern|replace({'{{ widget }}': ''})|trim }}
    {%- endset -%}
    
    <span class="ef-input-wrapper {{ wrapper_class }} {% if isReadonly %} ef-input-disabled {% endif %}" style="{{ wrapper_style }}">
        {% if money_pattern starts with '{{ widget }}' %}
            <input component="input" class="ef-input ef-input-size-medium {{ class_attr }}" 
                   clearable="true" 
                   type="{{ type }}" 
                   {{ block('widget_attributes') }} 
                   {% if value is not empty %}value="{{ value }}" {% endif %}
                   {% if isReadonly %} readonly="readonly" {% endif %}
                   {% if disabled %} disabled="disabled" {% endif %}/>
            <span class="ef-input-suffix" style="padding: 0 12px; color: var(--color-text-3);">{{ currency_symbol }}</span>
        {% else %}
            <span class="ef-input-prefix" style="padding: 0 12px; color: var(--color-text-3);">{{ currency_symbol }}</span>
            <input component="input" class="ef-input ef-input-size-medium {{ class_attr }}" 
                   clearable="true" 
                   type="{{ type }}" 
                   {{ block('widget_attributes') }} 
                   {% if value is not empty %}value="{{ value }}" {% endif %}
                   {% if isReadonly %} readonly="readonly" {% endif %}
                   {% if disabled %} disabled="disabled" {% endif %}/>
        {% endif %}
    </span>
{%- endblock money_widget -%}

{%- block percent_widget -%}
    {%- set type = type|default('text') -%}
    {%- set isReadonly = attr.readonly is defined and attr.readonly -%}
    {%- set class_attr = attr.class is defined ? attr.class : '' %}
    {%- set wrapper_class = attr.wrapper_class|default('') -%}
    {%- if attr.rounded|default(false) -%}
        {%- set wrapper_class = wrapper_class ~ ' ef-input-rounded' -%}
    {%- endif -%}
    {%- set wrapper_style = '' -%}
    {%- if attr.height|default(false) -%}
        {%- set wrapper_class = wrapper_class ~ ' ef-input-h' ~ attr.height -%}
        {%- set wrapper_style = 'height: ' ~ attr.height ~ 'px;' -%}
    {%- endif -%}
    {%- set attr = attr|merge({'wrapper_class': false, 'rounded': false, 'height': false}) -%}
    
    <span class="ef-input-wrapper {{ wrapper_class }} {% if isReadonly %} ef-input-disabled {% endif %}" style="{{ wrapper_style }}">
        <input component="input" class="ef-input ef-input-size-medium {{ class_attr }}" 
               clearable="true" 
               type="{{ type }}" 
               {{ block('widget_attributes') }} 
               {% if value is not empty %}value="{{ value }}" {% endif %}
               {% if isReadonly %} readonly="readonly" {% endif %}
               {% if disabled %} disabled="disabled" {% endif %}/>
        {% if symbol|default('%') %}
            <span class="ef-input-suffix" style="padding: 0 12px; color: var(--color-text-3);">{{ symbol|default('%') }}</span>
        {% endif %}
    </span>
{%- endblock percent_widget -%}

{%- block choice_widget_collapsed -%}
    {% set selectInputId = random() %}
    {% set selectContentId = random() %}
    {% set isDefault = value is not empty %}
    {% set real_id = id %}
    {% set id = id ~ '_hidden' %}
    {%- set wrapper_class = attr.wrapper_class|default('') -%}
    {%- if attr.rounded|default(false) -%}
        {%- set wrapper_class = wrapper_class ~ ' ef-input-rounded' -%}
    {%- endif -%}
    {%- set wrapper_style = '' -%}
    {%- if attr.height|default(false) -%}
        {%- set wrapper_class = wrapper_class ~ ' ef-input-h' ~ attr.height -%}
        {%- set wrapper_style = 'height: ' ~ attr.height ~ 'px;' -%}
    {%- endif -%}
    {%- set attr = attr|merge({'wrapper_class': false, 'rounded': false, 'height': false}) -%}
    <input type="hidden" component="select" {{ block('widget_attributes') }} {% if isDefault %} value="{{ value }}" {% endif %}/>
    <span
      class="ef-select-view-single ef-select ef-select-view ef-select-view-size-medium ef-select-view-search {{ wrapper_class }}"
      style="{{ wrapper_style }}"
      chosen="{{ isDefault ? 'true' : 'false' }}"
      for="{{ label }}"
      id="{{ selectInputId }}"
      contentId="{{ selectContentId }}"
      >
      <input id="{{ real_id }}" class="ef-select-view-input {% if isDefault %} ef-select-view-input-hidden {% endif %}" placeholder="Please select ...">
      {% set defaultLabel = '' %}
      {% set defaultTranslationParams = {} %}
      {%- for key, choice_attr in preferred_choices -%}
        {%- if choice_attr.value == value -%}
          {%- set defaultLabel = choice_attr.label -%}
          {%- set defaultTranslationParams = choice_attr.labelTranslationParameters|default({}) -%}
        {%- endif -%}
      {%- endfor -%}
      {%- for key, choice_attr in choices -%}
        {%- if choice_attr.value == value -%} {# 如果选项值等于默认值 #}
          {%- set defaultLabel = choice_attr.label -%}
          {%- set defaultTranslationParams = choice_attr.labelTranslationParameters|default({}) -%}
        {%- endif -%}
      {%- endfor -%}
      <span class="ef-select-view-value {% if not isDefault %} ef-select-view-value-hidden {% endif %}">{{ defaultLabel != '' ? (choice_translation_domain is same as(false) ? defaultLabel : defaultLabel|trans(defaultTranslationParams, choice_translation_domain)) : '' }}</span>
      <span class="ef-select-view-suffix">
        <span class="ef-select-view-icon">
          {% if isDefault %}
            <i class="fa-regular fa-circle-xmark"></i>
          {% endif %}

          {% if not isDefault %}
            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" class="ef-icon ef-icon-expand" stroke-width="4" stroke-linecap="butt" stroke-linejoin="miter" style="transform: rotate(-45deg);">
              <path d="M7 26v14c0 .552.444 1 .996 1H22m19-19V8c0-.552-.444-1-.996-1H26"></path>
            </svg>
          {% endif %}
        </span>
      </span>
    </span>
    <div class="ef-trigger-popup ef-trigger-position-bl"
         trigger-placement="bl"
         for="{{ label }}"
         style="z-index: 1001; pointer-events: auto; min-width: 200px;"
         id="{{ selectContentId }}"
         parentId="{{ selectInputId }}"
        >
      <div class="ef-trigger-popup-wrapper" style="transform-origin: 0px 0px;">
        <div class="ef-trigger-content">
          <div class="ef-select-dropdown">
            <div class="ef-scrollbar ef-scrollbar-type-embed" style="">
              <div class="ef-scrollbar-container ef-select-dropdown-list-wrapper">
                <ul class="ef-select-dropdown-list">
                  {%- if preferred_choices|length > 0 -%}
                      {% set options = preferred_choices %}
                      {% set render_preferred_choices = true %}
                        {{- block('choice_widget_options') -}}
                      {%- if choices|length > 0 and separator is not none -%}
                        <li id="{{ random() }}" class="ef-select-option ef-select-option-disabled"><span class="ef-select-option-content">{{ separator }}</span></li>
                      {%- endif -%}
                  {%- endif -%}
                  {%- set options = choices -%}
                  {%- set render_preferred_choices = false -%}
                  {{- block('choice_widget_options') -}}
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
{%- endblock choice_widget_collapsed -%}

{%- block choice_widget_options -%}
    {% for group_label, choice in options %}
        {%- if choice is iterable -%}
            <optgroup label="{{ choice_translation_domain is same as(false) ? group_label : group_label|trans({}, choice_translation_domain) }}">
                {% set options = choice %}
                {{- block('choice_widget_options') -}}
            </optgroup>
        {%- else -%}
            {# <option value="{{ choice.value }}"{% if choice.attr %}{% with { attr: choice.attr } %}{{ block('attributes') }}{% endwith %}{% endif %}{% if not render_preferred_choices|default(false) and choice is selectedchoice(value) %} selected="selected"{% endif %}>{{ choice_translation_domain is same as(false) ? choice.label : choice.label|trans(choice.labelTranslationParameters, choice_translation_domain) }}</option> #}
            <li id="{{ random() }}" value="{{ choice.value }}" class="ef-select-option {% if not render_preferred_choices|default(false) and choice is selectedchoice(value) %} ef-select-option-active {% endif %}"><span class="ef-select-option-content">{{ choice_translation_domain is same as(false) ? choice.label : choice.label|trans(choice.labelTranslationParameters, choice_translation_domain) }}</span></li>
        {%- endif -%}
    {% endfor %}
{%- endblock choice_widget_options -%}

{%- block date_widget -%}
    {%- if widget == 'single_text' -%}
        {%- set type = 'text' -%}
        {%- set attr = attr|merge({class: (attr.class|default('') ~ ' date-picker')|trim}) -%}
        {{- block('form_widget_simple') -}}
    {%- else -%}
        <div {{ block('widget_container_attributes') }}>
            {{- date_pattern|replace({
                '{{ year }}':  form_widget(form.year),
                '{{ month }}': form_widget(form.month),
                '{{ day }}':   form_widget(form.day),
            })|raw -}}
        </div>
    {%- endif -%}
{%- endblock date_widget -%}

{%- block datetime_widget -%}
    {%- if widget == 'single_text' -%}
        {%- set type = 'text' -%}
        {%- set attr = attr|merge({class: (attr.class|default('') ~ ' datetime-picker')|trim}) -%}
        {{- block('form_widget_simple') -}}
    {%- else -%}
        <div {{ block('widget_container_attributes') }}>
            {{- form_errors(form.date) -}}
            {{- form_errors(form.time) -}}
            {{- form_widget(form.date) -}}
            {{- form_widget(form.time) -}}
        </div>
    {%- endif -%}
{%- endblock datetime_widget -%}

{%- block time_widget -%}
    {%- if widget == 'single_text' -%}
        {%- set type = 'text' -%}
        {%- set attr = attr|merge({class: (attr.class|default('') ~ ' time-picker')|trim}) -%}
        {{- block('form_widget_simple') -}}
    {%- else -%}
        {%- set vars = widget == 'text' ? {attr: {size: 1}} : {} -%}
        <div {{ block('widget_container_attributes') }}>
            {{ form_widget(form.hour, vars) }}{% if with_minutes %}:{{ form_widget(form.minute, vars) }}{% endif %}{% if with_seconds %}:{{ form_widget(form.second, vars) }}{% endif %}
        </div>
    {%- endif -%}
{%- endblock time_widget -%}

{%- block week_widget -%}
    {%- if widget == 'single_text' -%}
        {%- set type = 'week' -%}
        {%- set attr = attr|merge({class: (attr.class|default('') ~ ' week-picker')|trim}) -%}
        {{- block('form_widget_simple') -}}
    {%- else -%}
        {%- set vars = widget == 'text' ? {attr: {size: 1}} : {} -%}
        <div {{ block('widget_container_attributes') }}>
            {{ form_widget(form.year, vars) }}-{{ form_widget(form.week, vars) }}
        </div>
    {%- endif -%}
{%- endblock week_widget -%}

{%- block timezone_widget -%}
    {%- if required and placeholder is none and not placeholder_in_choices and not multiple and (attr.size is not defined or attr.size <= 1) -%}
        {% set required = false %}
    {%- endif -%}
    {%- set wrapper_class = attr.wrapper_class|default('') -%}
    {%- if attr.rounded|default(false) -%}
        {%- set wrapper_class = wrapper_class ~ ' ef-input-rounded' -%}
    {%- endif -%}
    <span class="ef-select-view-single ef-select ef-select-view ef-select-view-size-medium {{ wrapper_class }}" style="height: 36px; line-height: 36px;">
        <select {{ block('widget_attributes') }}{% if multiple %} multiple="multiple"{% endif %} class="ef-input" style="border:none; width: 100%; height: 100%; outline: none; background: transparent; padding: 0 12px;">
            {%- if placeholder is not none -%}
                <option value=""{% if placeholder_attr|default({}) %}{% with {attr: placeholder_attr} %}{{ block('attributes') }}{% endwith %}{% endif %}{% if required and value is empty %} selected="selected"{% endif %}>{{ placeholder != '' ? (translation_domain is same as(false) ? placeholder : placeholder|trans({}, translation_domain)) }}</option>
            {%- endif -%}
            {%- if preferred_choices|length > 0 -%}
                {% set options = preferred_choices %}
                {% set render_preferred_choices = true %}
                {{- block('timezone_widget_options') -}}
                {%- if choices|length > 0 and separator is not none -%}
                    {%- if separator_html is not defined or separator_html is same as(false) -%}
                        <option disabled="disabled">{{ separator }}</option>
                    {% else %}
                        {{ separator|raw }}
                    {% endif %}
                {%- endif -%}
            {%- endif -%}
            {%- set options = choices -%}
            {%- set render_preferred_choices = false -%}
            {{- block('timezone_widget_options') -}}
        </select>
    </span>
{%- endblock timezone_widget -%}

{%- block timezone_widget_options -%}
    {% for group_label, choice in options %}
        {%- if choice is iterable -%}
            <optgroup label="{{ choice_translation_domain is same as(false) ? group_label : group_label|trans({}, choice_translation_domain) }}">
                {% set options = choice %}
                {{- block('timezone_widget_options') -}}
            </optgroup>
        {%- else -%}
            <option value="{{ choice.value }}"{% if choice.attr %}{% with {attr: choice.attr} %}{{ block('attributes') }}{% endwith %}{% endif %}{% if (not render_preferred_choices|default(false) or not (duplicate_preferred_choices ?? true)) and choice is selectedchoice(value) %} selected="selected"{% endif %}>{{ choice_translation_domain is same as(false) ? choice.label : choice.label|trans(choice.labelTranslationParameters, choice_translation_domain) }}</option>
        {%- endif -%}
    {% endfor %}
{%- endblock timezone_widget_options -%}

{%- block collection_widget -%}
    {% if prototype is defined and not prototype.rendered %}
        {%- set prototype_html = '<div class="ef-space ef-space-horizontal ef-space-align-center ef-collection-item" style="margin-bottom: 12px; width: 100%; display: flex;"><div style="flex: 1;">' ~ form_widget(prototype) ~ '</div><span class="ef-collection-remove" style="cursor: pointer; color: #999; padding: 4px 8px; transition: color 0.2s; margin-left: 4px;" title="删除" onmouseover="this.style.color=\'#ff4d4f\'" onmouseout="this.style.color=\'#999\'"><i class="fa-solid fa-trash-can"></i></span></div>' -%}
        {%- set attr = attr|merge({'data-prototype': prototype_html}) -%}
    {% endif %}
    <div class="ef-collection-container" {{ block('widget_container_attributes') }} style="width: 100%;">
        <div class="ef-collection-items">
            {% for child in form %}
                <div class="ef-space ef-space-horizontal ef-space-align-center ef-collection-item" style="margin-bottom: 12px; width: 100%; display: flex;">
                    <div style="flex: 1;">
                        {{- form_widget(child) -}}
                    </div>
                    {% if form.vars.allow_delete|default(true) %}
                    <span class="ef-collection-remove" style="cursor: pointer; color: #999; padding: 4px 8px; transition: color 0.2s; margin-left: 4px;" title="删除" onmouseover="this.style.color='#ff4d4f'" onmouseout="this.style.color='#999'">
                        <i class="fa-solid fa-trash-can"></i>
                    </span>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
        {% if form.vars.allow_add|default(true) %}
            <div style="margin-top: 8px;">
                <button type="button" class="btn outline medium ef-collection-add-btn" style="width: 100%; border-style: dashed; border-color: #d9d9d9; color: #666; background: #fafafa; display: flex; justify-content: center; align-items: center; gap: 8px;">
                    <i class="fa-solid fa-plus"></i> {{ 'action.add'|trans({}, 'messages')|default('添加一项') }}
                </button>
            </div>
        {% endif %}
    </div>
    <script>
    if (typeof window.efCollectionInitialized === 'undefined') {
        window.efCollectionInitialized = true;
        document.addEventListener('click', function(e) {
            const removeBtn = e.target.closest('.ef-collection-remove');
            if (removeBtn) {
                const item = removeBtn.closest('.ef-collection-item');
                if (item) {
                    item.remove();
                }
                return;
            }
            const addBtn = e.target.closest('.ef-collection-add-btn');
            if (addBtn) {
                const container = addBtn.closest('.ef-collection-container');
                const itemsContainer = container.querySelector('.ef-collection-items');
                const prototype = container.getAttribute('data-prototype');
                if (prototype) {
                    const index = itemsContainer.children.length;
                    const newHtml = prototype.replace(/__name__/g, index);
                    itemsContainer.insertAdjacentHTML('beforeend', newHtml);
                }
            }
        });
    }
    </script>
{%- endblock collection_widget -%}

{%- block repeated_row -%}
    {%- set first_id = form.first.vars.id -%}
    {%- set second_id = form.second.vars.id -%}
    <div class="ef-repeated-wrapper" data-first-id="{{ first_id }}" data-second-id="{{ second_id }}">
        {{- form_row(form.first) -}}
        {{- form_row(form.second) -}}
    </div>
    <script>
    if (typeof window.efRepeatedInitialized === 'undefined') {
        window.efRepeatedInitialized = true;
        document.addEventListener('input', function(e) {
            if (e.target.tagName === 'INPUT') {
                document.querySelectorAll('.ef-repeated-wrapper').forEach(wrapper => {
                    const firstId = wrapper.getAttribute('data-first-id');
                    const secondId = wrapper.getAttribute('data-second-id');
                    if (e.target.id === firstId || e.target.id === secondId) {
                        const firstInput = document.getElementById(firstId);
                        const secondInput = document.getElementById(secondId);
                        
                        if (firstInput && secondInput) {
                            let errorMsg = secondInput.closest('.ef-form-item-wrapper-col')?.querySelector('.ef-repeated-error');
                            if (!errorMsg) {
                                const col = secondInput.closest('.ef-form-item-wrapper-col');
                                if (col) {
                                    errorMsg = document.createElement('div');
                                    errorMsg.className = 'ef-repeated-error';
                                    errorMsg.style.cssText = 'color: #ff4d4f; font-size: 12px; margin-top: 4px; display: none;';
                                    errorMsg.textContent = '两次输入的内容不一致';
                                    col.appendChild(errorMsg);
                                }
                            }
                            
                            const wrapperEl = secondInput.closest('.ef-input-wrapper');
                            if (secondInput.value && firstInput.value !== secondInput.value) {
                                if (errorMsg) errorMsg.style.display = 'block';
                                if (wrapperEl) wrapperEl.style.borderColor = '#ff4d4f';
                            } else {
                                if (errorMsg) errorMsg.style.display = 'none';
                                if (wrapperEl) wrapperEl.style.borderColor = '';
                            }
                        }
                    }
                });
            }
        });
    }
    </script>
{%- endblock repeated_row -%}

{% block reset_widget -%}
  {%- if attr is not defined or attr is not iterable -%}
      {%- set attr = {} -%}
  {%- endif -%}
  <div class="ef-space-item">
    {% set attr = attr|merge({class: (attr.class|default('') ~ ' btn outline medium')|trim}) %}
    <button type="{{ type|default('reset') }}" {{ block('button_attributes') }}>
        {%- if translation_domain is same as(false) -%}
            {{- label -}}
        {%- else -%}
            {{- label|trans(label_translation_parameters, translation_domain) -}}
        {%- endif -%}
    </button>
  </div>
{%- endblock reset_widget %}
