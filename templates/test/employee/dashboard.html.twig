            <button class="icon-btn"><i class="fa-regular fa-bell"></i></button>
            <button class="invite-btn"><i class="fa-solid fa-user-plus"></i> {{ 'dashboard.invite'|trans }}</button>
        </div>
    </div>

    <!-- Welcome -->
    <div class="welcome-section">
