{% extends 'base.html.twig' %}

{% block title %}Account Setup{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        body {
            background-color: #f3f4f6;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }
        .setup-card {
            background: white;
            border-radius: 8px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            width: 100%;
            max-width: 480px;
            padding: 2.5rem;
            box-sizing: border-box;
        }
        .setup-header {
            margin-bottom: 2rem;
            text-align: center;
        }
        .setup-header h1 {
            font-size: 1.5rem;
            font-weight: 600;
            color: #111827;
            margin: 0 0 0.5rem 0;
        }
        .setup-header p {
            color: #6b7280;
            margin: 0;
            font-size: 0.875rem;
            line-height: 1.5;
        }
        .form-group {
            margin-bottom: 1.5rem;
        }
        .form-label {
            display: block;
            font-size: 0.875rem;
            font-weight: 500;
            color: #374151;
            margin-bottom: 0.5rem;
        }
        .btn-full {
            width: 100%;
            justify-content: center;
            margin-top: 1rem;
        }
        .step-indicator {
            display: flex;
            justify-content: center;
            margin-bottom: 2rem;
            gap: 0.5rem;
        }
        .step-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background-color: #e5e7eb;
        }
        .step-dot.active {
            background-color: #2563eb;
        }
    </style>
{% endblock %}

{% block body %}
<div class="setup-card">
    <div class="step-indicator">
        <div class="step-dot active"></div>
        <div class="step-dot"></div>
    </div>
    
    <div class="setup-header">
        <h1>{{ 'setup.password.title'|trans }}</h1>
        <p>{{ 'setup.password.subtitle'|trans|raw }}</p>
    </div>

    {% for message in app.flashes('error') %}
        <div role="alert" class="ef-alert ef-alert-error" style="margin-bottom: 1.5rem;">
            <div class="ef-alert-icon">
                <i class="fa-solid fa-circle-exclamation"></i>
            </div>
            <div class="ef-alert-body">
                <div class="ef-alert-content">{{ message }}</div>
            </div>
        </div>
    {% endfor %}

    {% for message in app.flashes('success') %}
        <div role="alert" class="ef-alert ef-alert-success" style="margin-bottom: 1.5rem;">
            <div class="ef-alert-icon">
                <i class="fa-solid fa-circle-check"></i>
            </div>
            <div class="ef-alert-body">
                <div class="ef-alert-content">{{ message }}</div>
            </div>
        </div>
    {% endfor %}

    <form method="post">
        <div class="form-group">
            <label for="password" class="form-label">{{ 'setup.password.new_password'|trans }}</label>
            <span class="ef-input-wrapper" style="width: 100%;">
                <input class="ef-input ef-input-size-medium text" type="password" id="password" name="password" required minlength="8" placeholder="{{ 'setup.password.placeholder.min_chars'|trans }}">
            </span>
        </div>
        
        <div class="form-group">
            <label for="confirm_password" class="form-label">{{ 'setup.password.confirm_password'|trans }}</label>
            <span class="ef-input-wrapper" style="width: 100%;">
                <input class="ef-input ef-input-size-medium text" type="password" id="confirm_password" name="confirm_password" required minlength="8" placeholder="{{ 'setup.password.placeholder.re_enter'|trans }}">
            </span>
        </div>

        <button type="submit" class="btn primary medium btn-full">
            {{ 'setup.password.update_btn'|trans }} <i class="fa-solid fa-arrow-right" style="margin-left: 8px;"></i>
        </button>
    </form>
</div>
{% endblock %}
